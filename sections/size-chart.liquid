{%- comment -%}
  Section: size-chart.liquid
  Purpose: Standalone size guide page section for Bikini Booth.
  Also drives the size-chart-modal snippet when rendered on product pages.

  Block order logic:
  - A "tab" block opens a new tab panel.
  - All "size_row" blocks that follow belong to that tab, until the next "tab" block.
  - No Tab ID linking needed — order in the editor is everything.
{%- endcomment -%}

<section
  class="sc-section"
  id="size-chart-{{ section.id }}"
  aria-label="Size Guide"
>
  <div class="sc-container">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="sc-section-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="sc-section-heading">
            <svg class="sc-heading-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="sc-section-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="sc-card">

      <div class="sc-top-bar">
        <div class="sc-unit-toggle" role="group" aria-label="Unit of measurement">
          <button type="button" class="sc-unit-btn sc-unit-on" data-unit="in" aria-pressed="true">in</button>
          <button type="button" class="sc-unit-btn sc-unit-off" data-unit="cm" aria-pressed="false">cm</button>
        </div>
      </div>

      {%- liquid
        assign tab_count = 0
        for block in section.blocks
          if block.type == 'tab'
            assign tab_count = tab_count | plus: 1
          endif
        endfor
      -%}

      {%- if tab_count > 0 -%}

        <div class="sc-tabs" role="tablist" aria-label="Size categories">
          {%- assign tab_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <button
                type="button"
                class="sc-tab{%- if tab_index == 0 %} is-active{%- endif -%}"
                role="tab"
                aria-selected="{%- if tab_index == 0 -%}true{%- else -%}false{%- endif -%}"
                aria-controls="sc-panel-{{ section.id }}-{{ block.id }}"
                id="sc-tab-{{ section.id }}-{{ block.id }}"
                data-tab="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.tab_label | default: 'Tops' -}}
              </button>
              {%- assign tab_index = tab_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="sc-panels">
          {%- assign current_tab = nil -%}
          {%- assign tab_index = 0 -%}
          {%- assign open_panel = false -%}
          {%- assign panel_has_rows = false -%}

          {%- for block in section.blocks -%}

            {%- if block.type == 'tab' -%}

              {%- if open_panel -%}
                      {%- unless panel_has_rows -%}
                        <tr><td colspan="4" class="sc-empty-cell">No sizing data added yet.</td></tr>
                      {%- endunless -%}
                      </tbody></table></div>
                    {%- if current_tab.settings.fit_notes != blank -%}
                      <div class="sc-fit-notes">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                        <div class="sc-fit-notes__text">{{ current_tab.settings.fit_notes }}</div>
                      </div>
                    {%- endif -%}
                    {%- if current_tab.settings.between_sizes != blank -%}
                      <div class="sc-between-sizes">
                        <strong>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12H3M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4"/></svg>
                          Between sizes?
                        </strong>
                        {{ current_tab.settings.between_sizes }}
                      </div>
                    {%- endif -%}
                  </div>
              {%- endif -%}

              {%- assign current_tab = block -%}
              {%- assign is_first = false -%}
              {%- if tab_index == 0 -%}{%- assign is_first = true -%}{%- endif -%}
              <div
                id="sc-panel-{{ section.id }}-{{ block.id }}"
                class="sc-panel{%- if is_first %} is-active{%- endif -%}"
                role="tabpanel"
                aria-labelledby="sc-tab-{{ section.id }}-{{ block.id }}"
                {%- unless is_first %} hidden{%- endunless -%}
                {{ block.shopify_attributes }}
              >
                <div class="sc-table-wrap">
                  <table class="sc-table" aria-label="{{ block.settings.tab_label }} size chart">
                    <thead>
                      <tr>
                        <th scope="col">Size</th>
                        <th scope="col"><span class="unit-in">Bust (in)</span><span class="unit-cm" hidden>Bust (cm)</span></th>
                        <th scope="col"><span class="unit-in">Waist (in)</span><span class="unit-cm" hidden>Waist (cm)</span></th>
                        <th scope="col"><span class="unit-in">Hips (in)</span><span class="unit-cm" hidden>Hips (cm)</span></th>
                      </tr>
                    </thead>
                    <tbody>
              {%- assign open_panel = true -%}
              {%- assign tab_index = tab_index | plus: 1 -%}
              {%- assign panel_has_rows = false -%}

            {%- elsif block.type == 'size_row' and open_panel -%}
              {%- assign panel_has_rows = true -%}
              <tr {{ block.shopify_attributes }}>
                <td class="sc-size-label">{{ block.settings.size_label | default: 'XS' }}</td>
                <td><span class="unit-in">{{ block.settings.bust_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.bust_cm | default: '—' }}</span></td>
                <td><span class="unit-in">{{ block.settings.waist_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.waist_cm | default: '—' }}</span></td>
                <td><span class="unit-in">{{ block.settings.hips_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.hips_cm | default: '—' }}</span></td>
              </tr>
            {%- endif -%}
          {%- endfor -%}

          {%- if open_panel -%}
                  {%- unless panel_has_rows -%}
                    <tr><td colspan="4" class="sc-empty-cell">No sizing data added yet.</td></tr>
                  {%- endunless -%}
                  </tbody></table></div>
                {%- if current_tab.settings.fit_notes != blank -%}
                  <div class="sc-fit-notes">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                    <div class="sc-fit-notes__text">{{ current_tab.settings.fit_notes }}</div>
                  </div>
                {%- endif -%}
                {%- if current_tab.settings.between_sizes != blank -%}
                  <div class="sc-between-sizes">
                    <strong>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12H3M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4"/></svg>
                      Between sizes?
                    </strong>
                    {{ current_tab.settings.between_sizes }}
                  </div>
                {%- endif -%}
              </div>
          {%- endif -%}

        </div>

      {%- else -%}
        <p class="sc-empty">Add a Size Category Tab block in the theme editor to get started.</p>
      {%- endif -%}

    </div>

    {%- if section.settings.measure_link_label != blank and section.settings.measure_link_url != blank -%}
      <p class="sc-measure-link">
        <a href="{{ section.settings.measure_link_url }}">{{ section.settings.measure_link_label }}</a>
      </p>
    {%- endif -%}

  </div>
</section>


<style>
  #size-chart-{{ section.id }} {
    padding: {{ section.settings.padding_top | default: 48 }}px 20px {{ section.settings.padding_bottom | default: 48 }}px;
    background: #faf8f4;
  }

  #size-chart-{{ section.id }} .sc-container {
    max-width: 760px;
    margin: 0 auto;
  }

  #size-chart-{{ section.id }} .sc-section-header {
    text-align: center;
    margin-bottom: 28px;
  }

  #size-chart-{{ section.id }} .sc-section-heading {
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2a2520;
    margin: 0 0 6px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  @media (min-width: 768px) {
    #size-chart-{{ section.id }} .sc-section-heading { font-size: 1.5rem; }
  }

  #size-chart-{{ section.id }} .sc-heading-icon {
    flex-shrink: 0;
  }

  #size-chart-{{ section.id }} .sc-section-subheading {
    font-size: 0.875rem;
    color: #8a8077;
    margin: 0;
    letter-spacing: 0.02em;
  }

  #size-chart-{{ section.id }} .sc-card {
    background: #ffffff;
    border: 0.5px solid #e0dbd3;
    border-radius: 12px;
    overflow: hidden;
  }

  #size-chart-{{ section.id }} .sc-top-bar {
    display: flex;
    justify-content: flex-end;
    padding: 14px 18px 0;
  }

  #size-chart-{{ section.id }} .sc-unit-toggle {
    display: inline-flex;
    border: 1.5px solid #49c6be;
    border-radius: 999px;
    overflow: hidden;
  }

  #size-chart-{{ section.id }} .sc-unit-btn {
    display: inline-block;
    padding: 4px 14px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    border: none;
    transition: background 0.15s, color 0.15s;
  }

  #size-chart-{{ section.id }} .sc-unit-on {
    background: #49c6be;
    color: #ffffff;
  }

  #size-chart-{{ section.id }} .sc-unit-off {
    background: #ffffff;
    color: #49c6be;
  }

  #size-chart-{{ section.id }} .sc-tabs {
    display: flex;
    border-bottom: 1px solid #e8e4dd;
    padding: 0 6px;
    margin-top: 10px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #size-chart-{{ section.id }} .sc-tabs::-webkit-scrollbar { display: none; }

  #size-chart-{{ section.id }} .sc-tab {
    display: inline-block;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 14px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #a09890;
    cursor: pointer;
    white-space: nowrap;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }

  #size-chart-{{ section.id }} .sc-tab.is-active {
    color: #49c6be;
    border-bottom-color: #49c6be;
    font-weight: 500;
  }

  #size-chart-{{ section.id }} .sc-tab:not(.is-active):hover {
    color: #2a2520;
    border-bottom-color: #c5e8e6;
  }

  #size-chart-{{ section.id }} .sc-panels {
    padding: 20px 18px 4px;
  }

  #size-chart-{{ section.id }} .sc-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 14px;
    border: 0.5px solid #e8e4dd;
    border-radius: 8px;
    overflow: hidden;
  }

  #size-chart-{{ section.id }} .sc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    color: #2a2520;
    min-width: 320px;
  }

  #size-chart-{{ section.id }} .sc-table thead tr {
    background: #faf8f4;
  }

  #size-chart-{{ section.id }} .sc-table th {
    padding: 9px 13px;
    text-align: left;
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #8a8077;
    white-space: nowrap;
    border-bottom: 0.5px solid #e8e4dd;
  }

  #size-chart-{{ section.id }} .sc-table td {
    padding: 10px 13px;
    border-top: 0.5px solid #f0ece6;
  }

  #size-chart-{{ section.id }} .sc-table tbody tr:last-child td { border-bottom: none; }
  #size-chart-{{ section.id }} .sc-table tbody tr:hover td { background: #faf8f4; }
  #size-chart-{{ section.id }} .sc-size-label { font-weight: 500; }

  #size-chart-{{ section.id }} .sc-empty-cell {
    text-align: center;
    color: #a09890;
    font-size: 0.8125rem;
    padding: 24px 13px;
  }

  #size-chart-{{ section.id }} .sc-fit-notes {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    background: #f5fbfa;
    border-left: 1.5px solid #49c6be;
    padding: 10px 14px;
    margin-bottom: 12px;
    font-size: 0.8125rem;
    color: #3a3530;
    line-height: 1.65;
  }

  #size-chart-{{ section.id }} .sc-fit-notes svg { flex-shrink: 0; margin-top: 2px; }
  #size-chart-{{ section.id }} .sc-fit-notes__text p { margin: 0; }

  #size-chart-{{ section.id }} .sc-between-sizes {
    background: #faf8f4;
    border-radius: 6px;
    padding: 11px 14px;
    margin-bottom: 20px;
    font-size: 0.8125rem;
    color: #6a6560;
    line-height: 1.65;
  }

  #size-chart-{{ section.id }} .sc-between-sizes strong {
    display: flex;
    align-items: center;
    gap: 7px;
    color: #2a2520;
    font-weight: 500;
    margin-bottom: 4px;
    font-size: 0.8125rem;
  }

  #size-chart-{{ section.id }} .sc-between-sizes strong svg { flex-shrink: 0; }
  #size-chart-{{ section.id }} .sc-between-sizes p { margin: 0; }

  #size-chart-{{ section.id }} .sc-measure-link {
    text-align: center;
    margin-top: 16px;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  #size-chart-{{ section.id }} .sc-measure-link a {
    color: #49c6be;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s;
  }

  #size-chart-{{ section.id }} .sc-measure-link a:hover { opacity: 0.75; }

  #size-chart-{{ section.id }} .sc-empty {
    font-size: 0.8125rem;
    color: #a09890;
    padding: 32px 20px;
    text-align: center;
    margin: 0;
  }
</style>


<script>
(function () {
  'use strict';

  var section = document.getElementById('size-chart-{{ section.id }}');
  if (!section) return;

  var unitBtns = section.querySelectorAll('.sc-unit-btn');
  unitBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var unit = btn.dataset.unit;
      unitBtns.forEach(function (b) {
        b.classList.toggle('sc-unit-on', b.dataset.unit === unit);
        b.classList.toggle('sc-unit-off', b.dataset.unit !== unit);
        b.setAttribute('aria-pressed', b.dataset.unit === unit ? 'true' : 'false');
      });
      section.querySelectorAll('.unit-in').forEach(function (el) { el.hidden = unit !== 'in'; });
      section.querySelectorAll('.unit-cm').forEach(function (el) { el.hidden = unit !== 'cm'; });
    });
  });

  var tabs   = section.querySelectorAll('.sc-tab');
  var panels = section.querySelectorAll('.sc-panel');

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var targetId = 'sc-panel-{{ section.id }}-' + tab.dataset.tab;
      tabs.forEach(function (t) {
        var active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach(function (panel) {
        var active = panel.id === targetId;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    });
  });

})();
</script>


{% schema %}
{
  "name": "Size Chart",
  "tag": "section",
  "class": "size-chart-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find your perfect fit."
    },
    {
      "type": "header",
      "content": "Modal Trigger (used by size-chart-modal snippet)"
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Modal heading",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Trigger link label",
      "default": "Size Guide"
    },
    {
      "type": "header",
      "content": "How to Measure"
    },
    {
      "type": "text",
      "id": "measure_link_label",
      "label": "Link label",
      "default": "How to measure yourself →"
    },
    {
      "type": "url",
      "id": "measure_link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Size Category Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Bikini Tops"
        },
        {
          "type": "richtext",
          "id": "fit_notes",
          "label": "Fit notes",
          "info": "Shown below the table as a highlighted callout.",
          "default": "<p>Our tops run true to size. For extra coverage, size up one.</p>"
        },
        {
          "type": "richtext",
          "id": "between_sizes",
          "label": "Between sizes tip",
          "default": "<p>If you're between sizes, we recommend sizing up for a more relaxed fit, or sizing down for a snugger hold.</p>"
        }
      ]
    },
    {
      "type": "size_row",
      "name": "Size Row",
      "settings": [
        {
          "type": "text",
          "id": "size_label",
          "label": "Size",
          "default": "XS"
        },
        {
          "type": "text",
          "id": "bust_in",
          "label": "Bust (inches)",
          "default": "32–33\""
        },
        {
          "type": "text",
          "id": "bust_cm",
          "label": "Bust (cm)",
          "default": "81–84"
        },
        {
          "type": "text",
          "id": "waist_in",
          "label": "Waist (inches)",
          "default": "24–25\""
        },
        {
          "type": "text",
          "id": "waist_cm",
          "label": "Waist (cm)",
          "default": "61–64"
        },
        {
          "type": "text",
          "id": "hips_in",
          "label": "Hips (inches)",
          "default": "34–35\""
        },
        {
          "type": "text",
          "id": "hips_cm",
          "label": "Hips (cm)",
          "default": "86–89"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Size Chart"
    }
  ]
}
{% endschema %}
