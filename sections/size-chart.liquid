{%- comment -%}
  Section: size-chart.liquid
  Purpose: Standalone size guide page section for Bikini Booth.
  Also drives the size-chart-modal snippet when rendered on product pages.

  Block order logic (UNCHANGED):
  - A "tab" block opens a new tab panel.
  - All "size_row" blocks that follow belong to that tab, until the next "tab" block.
  - No Tab ID linking needed — order in the editor is everything.

  June 2026 redesign (visual only):
  - Editorial tropical-resort styling per design reference.
  - Data, tab logic, and in/cm conversion are PRESERVED untouched.
  - All JS hooks preserved: #size-chart-{id}, .sc-unit-btn[data-unit], .unit-in/.unit-cm,
    .sc-tab[data-tab], .sc-panel, sc-panel-{id}-{block.id}.
  - All styles scoped to #size-chart-{{ section.id }} — nothing leaks globally or into the modal.
{%- endcomment -%}

{%- comment -%} Reusable inline SVGs (currentColor = recoloured by parent) {%- endcomment -%}
{%- capture sc_palm_svg -%}<svg viewBox="0 0 48 54" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M24 21c-1 11-2 21-3 32"/><path d="M24 21C16 15 8 16 3 20c7-2 15-1 21 3"/><path d="M24 21c8-6 16-5 21-1-7-2-15-1-21 3"/><path d="M24 21C20 12 14 8 7 7c8 2 14 7 17 16"/><path d="M24 21c4-9 10-13 17-14-8 2-14 7-17 16"/><path d="M24 21c0-9 0-14 0-19"/><path d="M17 53h14"/></svg>{%- endcapture -%}
{%- capture sc_shell_svg -%}<svg viewBox="0 0 32 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 4C9 5 4 12 3 21c2 1 4 0 5 2 2-1 4 0 5 1 1-1 3-1 6 0 2-1 4-2 5-1 1-2 3-1 5-2C28 12 23 5 16 4Z"/><path d="M16 4L13 23"/><path d="M16 4L19 23"/><path d="M16 4L8 21"/><path d="M16 4L24 21"/></svg>{%- endcapture -%}
{%- capture sc_torso_paths -%}<path d="M42 14h16"/><path d="M42 14c-2 8-7 13-14 17-9 4-13 10-14 17"/><path d="M58 14c2 8 7 13 14 17 9 4 13 10 14 17"/><path d="M14 48c1 14 8 24 12 36 4 12 2 20-2 28"/><path d="M86 48c-1 14-8 24-12 36-4 12-2 20 2 28"/><path d="M24 112c6 10 14 12 26 12s20-2 26-12"/><path d="M32 46c6 10 14 12 18 7 4 5 12 3 18-7"/><path d="M50 31v15"/><path d="M30 100c8 10 14 12 20 12s12-2 20-12"/>{%- endcapture -%}

<section
  class="sc-section"
  id="size-chart-{{ section.id }}"
  aria-label="Size Guide"
>
  <span class="sc-palm-bg sc-palm-bg--l" aria-hidden="true">{{ sc_palm_svg }}</span>
  <span class="sc-palm-bg sc-palm-bg--r" aria-hidden="true">{{ sc_palm_svg }}</span>

  <div class="sc-container">

    {%- comment -%} 1. HERO {%- endcomment -%}
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="sc-hero">
        <span class="sc-hero__icon" aria-hidden="true">{{ sc_palm_svg }}</span>
        {%- if section.settings.heading != blank -%}
          <h2 class="sc-hero__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="sc-hero__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.intro_text != blank -%}
          <p class="sc-hero__intro">{{ section.settings.intro_text }}</p>
        {%- endif -%}
        <div class="sc-divider" aria-hidden="true">
          <span class="sc-divider__line"></span>
          <span class="sc-divider__shell">{{ sc_shell_svg }}</span>
          <span class="sc-divider__line"></span>
        </div>
      </header>
    {%- endif -%}

    {%- comment -%} 2. HOW TO MEASURE (additive — no sizing logic) {%- endcomment -%}
    {%- if section.settings.show_measure_guide -%}
      <section class="sc-measure" aria-label="How to measure">
        <h2 class="sc-measure__title">How to Measure</h2>
        <div class="sc-measure__grid">
          <div class="sc-measure__col">
            <span class="sc-measure__art" aria-hidden="true"><svg viewBox="0 0 100 140" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">{{ sc_torso_paths }}<path d="M9 53h82" stroke-dasharray="3.5 4"/></svg></span>
            <div class="sc-measure__copy">
              <h3 class="sc-measure__label">Bust</h3>
              <p class="sc-measure__text">Measure around the fullest part of your bust.</p>
            </div>
          </div>
          <div class="sc-measure__col">
            <span class="sc-measure__art" aria-hidden="true"><svg viewBox="0 0 100 140" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">{{ sc_torso_paths }}<path d="M16 84h68" stroke-dasharray="3.5 4"/></svg></span>
            <div class="sc-measure__copy">
              <h3 class="sc-measure__label">Waist</h3>
              <p class="sc-measure__text">Measure around the narrowest part of your waist.</p>
            </div>
          </div>
          <div class="sc-measure__col">
            <span class="sc-measure__art" aria-hidden="true"><svg viewBox="0 0 100 140" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">{{ sc_torso_paths }}<path d="M11 106h78" stroke-dasharray="3.5 4"/></svg></span>
            <div class="sc-measure__copy">
              <h3 class="sc-measure__label">Hips</h3>
              <p class="sc-measure__text">Measure around the fullest part of your hips.</p>
            </div>
          </div>
        </div>
      </section>
    {%- endif -%}

    <div class="sc-card">

      {%- liquid
        assign tab_count = 0
        for block in section.blocks
          if block.type == 'tab'
            assign tab_count = tab_count | plus: 1
          endif
        endfor
      -%}

      {%- if tab_count > 0 -%}

        {%- comment -%} 3. CATEGORY TABS {%- endcomment -%}
        <div class="sc-tabs" role="tablist" aria-label="Size categories">
          {%- assign tab_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <button
                type="button"
                class="sc-tab{%- if tab_index == 0 %} is-active{%- endif -%}"
                role="tab"
                aria-selected="{%- if tab_index == 0 -%}true{%- else -%}false{%- endif -%}"
                aria-controls="sc-panel-{{ section.id }}-{{ block.id }}"
                id="sc-tab-{{ section.id }}-{{ block.id }}"
                data-tab="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.tab_label | default: 'Tops' -}}
              </button>
              {%- assign tab_index = tab_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} 4. CM / IN TOGGLE (markup + JS hooks preserved; restyled + recentred) {%- endcomment -%}
        <div class="sc-top-bar">
          <div class="sc-unit-toggle" role="group" aria-label="Unit of measurement">
            <button type="button" class="sc-unit-btn sc-unit-on" data-unit="in" aria-pressed="true">in</button>
            <button type="button" class="sc-unit-btn sc-unit-off" data-unit="cm" aria-pressed="false">cm</button>
          </div>
        </div>

        {%- comment -%} 5. SIZING TABLES + 6. FIT CARDS {%- endcomment -%}
        <div class="sc-panels">
          {%- assign current_tab = nil -%}
          {%- assign tab_index = 0 -%}
          {%- assign open_panel = false -%}
          {%- assign panel_has_rows = false -%}

          {%- for block in section.blocks -%}

            {%- if block.type == 'tab' -%}

              {%- if open_panel -%}
                      {%- unless panel_has_rows -%}
                        <tr><td colspan="4" class="sc-empty-cell">No sizing data added yet.</td></tr>
                      {%- endunless -%}
                      </tbody></table></div>
                    <p class="sc-table-hint" aria-hidden="true">Swipe to view more &rarr;</p>
                    {%- if current_tab.settings.fit_notes != blank or current_tab.settings.between_sizes != blank -%}
                      <div class="sc-fit-cards">
                        {%- if current_tab.settings.fit_notes != blank -%}
                          <div class="sc-fit-card sc-fit-card--note">
                            <span class="sc-fit-card__icon" aria-hidden="true">{{ sc_shell_svg }}</span>
                            <div class="sc-fit-card__body">
                              <h3 class="sc-fit-card__title">Fit Note</h3>
                              <div class="sc-fit-card__text">{{ current_tab.settings.fit_notes }}</div>
                            </div>
                          </div>
                        {%- endif -%}
                        {%- if current_tab.settings.between_sizes != blank -%}
                          <div class="sc-fit-card sc-fit-card--between">
                            <span class="sc-fit-card__icon sc-fit-card__icon--gold" aria-hidden="true">{{ sc_palm_svg }}</span>
                            <div class="sc-fit-card__body">
                              <h3 class="sc-fit-card__title">Between Sizes?</h3>
                              <div class="sc-fit-card__text">{{ current_tab.settings.between_sizes }}</div>
                            </div>
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
              {%- endif -%}

              {%- assign current_tab = block -%}
              {%- assign is_first = false -%}
              {%- if tab_index == 0 -%}{%- assign is_first = true -%}{%- endif -%}
              <div
                id="sc-panel-{{ section.id }}-{{ block.id }}"
                class="sc-panel{%- if is_first %} is-active{%- endif -%}"
                role="tabpanel"
                aria-labelledby="sc-tab-{{ section.id }}-{{ block.id }}"
                {%- unless is_first %} hidden{%- endunless -%}
                {{ block.shopify_attributes }}
              >
                <div class="sc-table-wrap">
                  <table class="sc-table" aria-label="{{ block.settings.tab_label }} size chart">
                    <thead>
                      <tr>
                        <th scope="col">Size</th>
                        <th scope="col"><span class="unit-in">Bust (in)</span><span class="unit-cm" hidden>Bust (cm)</span></th>
                        <th scope="col"><span class="unit-in">Waist (in)</span><span class="unit-cm" hidden>Waist (cm)</span></th>
                        <th scope="col"><span class="unit-in">Hips (in)</span><span class="unit-cm" hidden>Hips (cm)</span></th>
                      </tr>
                    </thead>
                    <tbody>
              {%- assign open_panel = true -%}
              {%- assign tab_index = tab_index | plus: 1 -%}
              {%- assign panel_has_rows = false -%}

            {%- elsif block.type == 'size_row' and open_panel -%}
              {%- assign panel_has_rows = true -%}
              <tr {{ block.shopify_attributes }}>
                <td class="sc-size-label"><span class="sc-size-badge">{{ block.settings.size_label | default: 'XS' }}</span></td>
                <td><span class="unit-in">{{ block.settings.bust_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.bust_cm | default: '—' }}</span></td>
                <td><span class="unit-in">{{ block.settings.waist_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.waist_cm | default: '—' }}</span></td>
                <td><span class="unit-in">{{ block.settings.hips_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.hips_cm | default: '—' }}</span></td>
              </tr>
            {%- endif -%}
          {%- endfor -%}

          {%- if open_panel -%}
                  {%- unless panel_has_rows -%}
                    <tr><td colspan="4" class="sc-empty-cell">No sizing data added yet.</td></tr>
                  {%- endunless -%}
                  </tbody></table></div>
                <p class="sc-table-hint" aria-hidden="true">Swipe to view more &rarr;</p>
                {%- if current_tab.settings.fit_notes != blank or current_tab.settings.between_sizes != blank -%}
                  <div class="sc-fit-cards">
                    {%- if current_tab.settings.fit_notes != blank -%}
                      <div class="sc-fit-card sc-fit-card--note">
                        <span class="sc-fit-card__icon" aria-hidden="true">{{ sc_shell_svg }}</span>
                        <div class="sc-fit-card__body">
                          <h3 class="sc-fit-card__title">Fit Note</h3>
                          <div class="sc-fit-card__text">{{ current_tab.settings.fit_notes }}</div>
                        </div>
                      </div>
                    {%- endif -%}
                    {%- if current_tab.settings.between_sizes != blank -%}
                      <div class="sc-fit-card sc-fit-card--between">
                        <span class="sc-fit-card__icon sc-fit-card__icon--gold" aria-hidden="true">{{ sc_palm_svg }}</span>
                        <div class="sc-fit-card__body">
                          <h3 class="sc-fit-card__title">Between Sizes?</h3>
                          <div class="sc-fit-card__text">{{ current_tab.settings.between_sizes }}</div>
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
          {%- endif -%}

        </div>

      {%- else -%}
        <p class="sc-empty">Add a Size Category Tab block in the theme editor to get started.</p>
      {%- endif -%}

    </div>

    {%- if section.settings.measure_link_label != blank and section.settings.measure_link_url != blank -%}
      <p class="sc-measure-link">
        <a href="{{ section.settings.measure_link_url }}">{{ section.settings.measure_link_label }}</a>
      </p>
    {%- endif -%}

    {%- comment -%} 7. FINAL FIT SUPPORT CTA {%- endcomment -%}
    {%- if section.settings.show_cta -%}
      {%- assign sc_cta_url = section.settings.cta_button_url | default: '/pages/contact' -%}
      <aside class="sc-cta" aria-label="Fit support">
        <span class="sc-cta__wave" aria-hidden="true">
          <svg viewBox="0 0 300 80" preserveAspectRatio="none"><path d="M0 40c40-12 70 12 110 0s70 12 110 0 70 10 80 2v38H0Z" fill="#ffffff" opacity=".22"/><path d="M0 54c40-10 70 10 110 0s70 10 110 0 70 8 80 2v22H0Z" fill="#ffffff" opacity=".15"/></svg>
        </span>
        <div class="sc-cta__inner">
          {%- if section.settings.cta_heading != blank -%}
            <h2 class="sc-cta__title">{{ section.settings.cta_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.cta_text != blank -%}
            <p class="sc-cta__text">{{ section.settings.cta_text }}</p>
          {%- endif -%}
          {%- if section.settings.cta_button_label != blank -%}
            <a class="sc-cta__btn" href="{{ sc_cta_url }}">{{ section.settings.cta_button_label }}</a>
          {%- endif -%}
        </div>
      </aside>
    {%- endif -%}

  </div>
</section>


<style>
  #size-chart-{{ section.id }} {
    --sc-teal: #49c6be;
    --sc-teal-deep: #0a5c56;
    --sc-ink: #234542;
    --sc-ink-soft: #5d6b69;
    --sc-sand: #fbf6ee;
    --sc-white: #ffffff;
    --sc-card: #fdfbf6;
    --sc-line: #e7ddcd;
    --sc-aqua: #e9f4f1;
    --sc-aqua-line: #cfe7e2;
    --sc-peach: #faf1e6;
    --sc-gold: #c79a59;
    --sc-row-tint: #fcf9f3;
    --sc-serif: var(--font-display, 'Cormorant Garamond', 'Cormorant', 'Hoefler Text', Georgia, 'Times New Roman', serif);

    position: relative;
    overflow: hidden;
    padding: {{ section.settings.padding_top | default: 48 }}px 20px {{ section.settings.padding_bottom | default: 48 }}px;
    background: var(--sc-sand);
    color: var(--sc-ink);
  }

  #size-chart-{{ section.id }} .sc-container {
    position: relative;
    z-index: 1;
    max-width: 980px;
    margin: 0 auto;
  }

  /* ---- Palm-leaf background shadows ---- */
  #size-chart-{{ section.id }} .sc-palm-bg {
    position: absolute;
    top: -56px;
    z-index: 0;
    width: min(46vw, 540px);
    color: #cadfd9;
    opacity: 0.5;
    pointer-events: none;
  }
  #size-chart-{{ section.id }} .sc-palm-bg svg { width: 100%; height: auto; }
  #size-chart-{{ section.id }} .sc-palm-bg--l { left: -150px; transform: scaleX(-1) rotate(-10deg); }
  #size-chart-{{ section.id }} .sc-palm-bg--r { right: -150px; transform: rotate(-10deg); }

  /* ---- 1. Hero ---- */
  #size-chart-{{ section.id }} .sc-hero {
    text-align: center;
    padding: 6px 0 4px;
  }
  #size-chart-{{ section.id }} .sc-hero__icon {
    display: inline-block;
    width: 40px;
    color: var(--sc-teal-deep);
  }
  #size-chart-{{ section.id }} .sc-hero__icon svg { width: 100%; height: auto; }
  #size-chart-{{ section.id }} .sc-hero__title {
    font-family: var(--sc-serif);
    font-weight: 500;
    font-size: clamp(2.6rem, 8vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sc-teal-deep);
    margin: 8px 0 0;
  }
  #size-chart-{{ section.id }} .sc-hero__subtitle {
    font-family: var(--sc-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.3rem, 3.6vw, 1.85rem);
    text-transform: capitalize;
    color: var(--sc-teal-deep);
    margin: 2px 0 16px;
  }
  #size-chart-{{ section.id }} .sc-hero__intro {
    max-width: 440px;
    margin: 0 auto;
    color: var(--sc-ink-soft);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  #size-chart-{{ section.id }} .sc-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    max-width: 340px;
    margin: 26px auto 0;
  }
  #size-chart-{{ section.id }} .sc-divider__line {
    flex: 1;
    height: 1px;
    background: var(--sc-teal);
    opacity: 0.45;
  }
  #size-chart-{{ section.id }} .sc-divider__shell {
    flex-shrink: 0;
    width: 26px;
    color: var(--sc-teal);
  }
  #size-chart-{{ section.id }} .sc-divider__shell svg { width: 100%; height: auto; }

  /* ---- 2. How to Measure ---- */
  #size-chart-{{ section.id }} .sc-measure {
    background: var(--sc-card);
    border: 1px solid var(--sc-line);
    border-radius: 18px;
    padding: 34px 26px;
    margin: 40px 0 0;
  }
  #size-chart-{{ section.id }} .sc-measure__title {
    text-align: center;
    font-family: var(--sc-serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 4vw, 2rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sc-teal-deep);
    margin: 0 0 28px;
  }
  #size-chart-{{ section.id }} .sc-measure__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
  }
  #size-chart-{{ section.id }} .sc-measure__col {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }
  #size-chart-{{ section.id }} .sc-measure__art {
    flex-shrink: 0;
    width: 64px;
    color: var(--sc-teal);
  }
  #size-chart-{{ section.id }} .sc-measure__art svg { width: 100%; height: auto; }
  #size-chart-{{ section.id }} .sc-measure__label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sc-teal-deep);
    margin: 4px 0 8px;
  }
  #size-chart-{{ section.id }} .sc-measure__text {
    margin: 0;
    color: var(--sc-ink-soft);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* ---- Open card wrapper (borderless: editorial layout) ---- */
  #size-chart-{{ section.id }} .sc-card {
    background: transparent;
    margin-top: 40px;
  }

  /* ---- 3. Tabs ---- */
  #size-chart-{{ section.id }} .sc-tabs {
    display: flex;
    gap: 8px;
    border-bottom: 1px solid var(--sc-line);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #size-chart-{{ section.id }} .sc-tabs::-webkit-scrollbar { display: none; }
  @media (min-width: 768px) {
    #size-chart-{{ section.id }} .sc-tabs { justify-content: center; }
  }
  #size-chart-{{ section.id }} .sc-tab {
    flex-shrink: 0;
    background: var(--sc-white);
    border: 1px solid var(--sc-line);
    border-bottom: 3px solid transparent;
    border-radius: 10px 10px 0 0;
    padding: 14px 22px;
    margin-bottom: -1px;
    font-family: inherit;
    font-size: 0.74rem;
    font-weight: 400;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #6f6a63;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  #size-chart-{{ section.id }} .sc-tab:not(.is-active):hover {
    color: var(--sc-teal-deep);
    border-bottom-color: var(--sc-aqua-line);
  }
  #size-chart-{{ section.id }} .sc-tab.is-active {
    background: var(--sc-aqua);
    color: var(--sc-teal-deep);
    border-color: var(--sc-aqua-line);
    border-bottom: 3px solid var(--sc-teal);
    font-weight: 600;
  }
  #size-chart-{{ section.id }} .sc-tab:focus-visible {
    outline: 2px solid var(--sc-teal);
    outline-offset: 2px;
  }

  /* ---- 4. Unit toggle ---- */
  #size-chart-{{ section.id }} .sc-top-bar {
    display: flex;
    justify-content: center;
    padding: 24px 0 4px;
  }
  #size-chart-{{ section.id }} .sc-unit-toggle {
    display: inline-flex;
    padding: 3px;
    background: var(--sc-white);
    border: 1.5px solid var(--sc-teal);
    border-radius: 999px;
  }
  #size-chart-{{ section.id }} .sc-unit-btn {
    border: none;
    border-radius: 999px;
    padding: 7px 24px;
    font-family: inherit;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }
  #size-chart-{{ section.id }} .sc-unit-on {
    background: var(--sc-teal-deep);
    color: var(--sc-white);
  }
  #size-chart-{{ section.id }} .sc-unit-off {
    background: transparent;
    color: var(--sc-teal-deep);
  }
  #size-chart-{{ section.id }} .sc-unit-btn:focus-visible {
    outline: 2px solid var(--sc-teal);
    outline-offset: 2px;
  }

  /* ---- 5. Tables ---- */
  #size-chart-{{ section.id }} .sc-panels { padding: 22px 0 4px; }

  #size-chart-{{ section.id }} .sc-table-wrap {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--sc-line);
    border-radius: 12px;
  }
  #size-chart-{{ section.id }} .sc-table {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-size: 0.95rem;
    color: var(--sc-ink);
  }
  #size-chart-{{ section.id }} .sc-table thead tr { background: var(--sc-teal-deep); }
  #size-chart-{{ section.id }} .sc-table th {
    padding: 16px 18px;
    text-align: center;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--sc-white);
    white-space: nowrap;
  }
  #size-chart-{{ section.id }} .sc-table td {
    padding: 15px 18px;
    text-align: center;
    border-top: 1px solid var(--sc-line);
  }
  #size-chart-{{ section.id }} .sc-table tbody tr:nth-child(even) { background: var(--sc-row-tint); }
  #size-chart-{{ section.id }} .sc-table tbody tr:hover td { background: var(--sc-aqua); }
  #size-chart-{{ section.id }} .sc-size-label { white-space: nowrap; }
  #size-chart-{{ section.id }} .sc-size-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    padding: 6px 10px;
    border: 1.5px solid var(--sc-teal);
    border-radius: 8px;
    color: var(--sc-teal-deep);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }
  #size-chart-{{ section.id }} .sc-empty-cell {
    text-align: center;
    color: #a09890;
    font-size: 0.9rem;
    padding: 26px 13px;
  }
  #size-chart-{{ section.id }} .sc-table-hint {
    display: none;
    margin: 8px 2px 0;
    font-size: 0.72rem;
    font-style: italic;
    letter-spacing: 0.03em;
    color: var(--sc-teal);
  }

  /* ---- 6. Fit cards ---- */
  #size-chart-{{ section.id }} .sc-fit-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin: 28px 0 4px;
  }
  @media (min-width: 768px) {
    #size-chart-{{ section.id }} .sc-fit-cards { grid-template-columns: 1fr 1fr; }
  }
  #size-chart-{{ section.id }} .sc-fit-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 24px 26px;
    border-radius: 16px;
  }
  #size-chart-{{ section.id }} .sc-fit-card--note { background: var(--sc-aqua); }
  #size-chart-{{ section.id }} .sc-fit-card--between { background: var(--sc-peach); }
  #size-chart-{{ section.id }} .sc-fit-card__icon {
    flex-shrink: 0;
    width: 36px;
    color: var(--sc-teal);
  }
  #size-chart-{{ section.id }} .sc-fit-card__icon--gold { color: var(--sc-gold); }
  #size-chart-{{ section.id }} .sc-fit-card__icon svg { width: 100%; height: auto; }
  #size-chart-{{ section.id }} .sc-fit-card__title {
    font-family: var(--sc-serif);
    font-weight: 500;
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sc-teal-deep);
    margin: 0 0 6px;
  }
  #size-chart-{{ section.id }} .sc-fit-card__text {
    color: var(--sc-ink-soft);
    font-size: 0.92rem;
    line-height: 1.65;
  }
  #size-chart-{{ section.id }} .sc-fit-card__text p { margin: 0; }

  /* ---- Optional "how to measure" link (legacy editable setting) ---- */
  #size-chart-{{ section.id }} .sc-measure-link {
    text-align: center;
    margin-top: 18px;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }
  #size-chart-{{ section.id }} .sc-measure-link a {
    color: var(--sc-teal-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s;
  }
  #size-chart-{{ section.id }} .sc-measure-link a:hover { opacity: 0.7; }

  /* ---- 7. CTA banner ---- */
  #size-chart-{{ section.id }} .sc-cta {
    position: relative;
    overflow: hidden;
    margin-top: 40px;
    padding: 48px 26px;
    border-radius: 20px;
    text-align: center;
    background: linear-gradient(180deg, #dcefe9 0%, #cde8e3 100%);
  }
  #size-chart-{{ section.id }} .sc-cta__wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    line-height: 0;
  }
  #size-chart-{{ section.id }} .sc-cta__wave svg { width: 100%; height: 100%; }
  #size-chart-{{ section.id }} .sc-cta__inner { position: relative; z-index: 1; }
  #size-chart-{{ section.id }} .sc-cta__title {
    font-family: var(--sc-serif);
    font-weight: 500;
    font-size: clamp(1.7rem, 5vw, 2.4rem);
    color: var(--sc-teal-deep);
    margin: 0 0 8px;
  }
  #size-chart-{{ section.id }} .sc-cta__text {
    color: var(--sc-ink-soft);
    font-size: 0.95rem;
    margin: 0 0 22px;
  }
  #size-chart-{{ section.id }} .sc-cta__btn {
    display: inline-block;
    padding: 14px 32px;
    border: 1.5px solid var(--sc-teal-deep);
    border-radius: 4px;
    background: transparent;
    color: var(--sc-teal-deep);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  #size-chart-{{ section.id }} .sc-cta__btn:hover {
    background: var(--sc-teal-deep);
    color: var(--sc-white);
  }
  #size-chart-{{ section.id }} .sc-cta__btn:focus-visible {
    outline: 2px solid var(--sc-teal-deep);
    outline-offset: 3px;
  }

  /* ---- Empty state ---- */
  #size-chart-{{ section.id }} .sc-empty {
    font-size: 0.9rem;
    color: #a09890;
    padding: 32px 20px;
    text-align: center;
    margin: 0;
  }

  /* ---- Tablet / mobile ---- */
  @media (min-width: 768px) {
    #size-chart-{{ section.id }} .sc-measure__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 599px) {
    #size-chart-{{ section.id }} { padding-left: 16px; padding-right: 16px; }
    #size-chart-{{ section.id }} .sc-palm-bg { width: 62vw; opacity: 0.4; }
    #size-chart-{{ section.id }} .sc-tabs { gap: 6px; }
    #size-chart-{{ section.id }} .sc-tab { padding: 13px 16px; }
    #size-chart-{{ section.id }} .sc-table-hint { display: block; }
    #size-chart-{{ section.id }} .sc-fit-card { padding: 20px; }
  }
</style>


<script>
(function () {
  'use strict';

  var section = document.getElementById('size-chart-{{ section.id }}');
  if (!section) return;

  var unitBtns = section.querySelectorAll('.sc-unit-btn');
  unitBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var unit = btn.dataset.unit;
      unitBtns.forEach(function (b) {
        b.classList.toggle('sc-unit-on', b.dataset.unit === unit);
        b.classList.toggle('sc-unit-off', b.dataset.unit !== unit);
        b.setAttribute('aria-pressed', b.dataset.unit === unit ? 'true' : 'false');
      });
      section.querySelectorAll('.unit-in').forEach(function (el) { el.hidden = unit !== 'in'; });
      section.querySelectorAll('.unit-cm').forEach(function (el) { el.hidden = unit !== 'cm'; });
    });
  });

  var tabs   = section.querySelectorAll('.sc-tab');
  var panels = section.querySelectorAll('.sc-panel');

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var targetId = 'sc-panel-{{ section.id }}-' + tab.dataset.tab;
      tabs.forEach(function (t) {
        var active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach(function (panel) {
        var active = panel.id === targetId;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    });
  });

})();
</script>


