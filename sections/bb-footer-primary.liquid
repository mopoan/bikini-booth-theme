{%- comment -%}
  Avoid style-loader / component-inputs.css here: it injects mid-page and can interfere with global chrome (header icons, fixed header).
  Newsletter inputs are styled in this file’s {% style %} block.
{%- endcomment -%}
{%- comment -%} Strip hyphens/underscores so custom element + JS class names stay valid for static section ids. {%- endcomment -%}
{% assign ai_gen_id = section.id | replace: '_', '' | replace: '-', '' | downcase %}

{%- liquid
  assign bb_footer_show_additional = false
  if section.settings.use_preset_quick_links == false
    if section.settings.additional_info_heading != blank
      assign bb_footer_show_additional = true
    endif
    unless section.settings.additional_info_line_1 == blank and section.settings.additional_info_line_2 == blank and section.settings.additional_info_line_3 == blank and section.settings.additional_info_line_4 == blank and section.settings.additional_info_line_5 == blank and section.settings.additional_info_line_6 == blank
      assign bb_footer_show_additional = true
    endunless
  endif

  assign bb_footer_use_five_col = section.settings.use_preset_quick_links
  if bb_footer_use_five_col
    assign bb_footer_grid_cols = 4
    if section.settings.show_newsletter
      assign bb_footer_grid_cols = 5
    endif
  else
    assign bb_footer_grid_cols = 2
    if bb_footer_show_additional
      assign bb_footer_grid_cols = bb_footer_grid_cols | plus: 1
    endif
    if section.settings.show_newsletter
      assign bb_footer_grid_cols = bb_footer_grid_cols | plus: 1
    endif
  endif

  assign bb_footer_about_page = section.settings.about_page
  if bb_footer_about_page == blank
    assign bb_footer_about_page = pages['about-us']
  endif
  assign bb_footer_about_href = section.settings.about_path_about_us
  if bb_footer_about_href == blank
    assign bb_footer_about_href = section.settings.ql_path_about
  endif
  if bb_footer_about_page != blank and bb_footer_about_href == blank
    assign bb_footer_about_href = bb_footer_about_page.url
  endif

  assign bb_footer_privacy_href = section.settings.privacy_path
  if bb_footer_privacy_href == blank
    if pages.privacy != blank
      assign bb_footer_privacy_href = pages.privacy.url
    elsif pages['privacy-policy'] != blank
      assign bb_footer_privacy_href = pages['privacy-policy'].url
    else
      assign bb_footer_privacy_href = '/pages/privacy'
    endif
  endif
  assign bb_footer_terms_href = section.settings.terms_path
  if bb_footer_terms_href == blank
    if pages.terms != blank
      assign bb_footer_terms_href = pages.terms.url
    elsif pages['terms-and-conditions'] != blank
      assign bb_footer_terms_href = pages['terms-and-conditions'].url
    else
      assign bb_footer_terms_href = '/pages/terms'
    endif
  elsif bb_footer_terms_href == '/pages/terms-and-conditions' and pages.terms != blank
    assign bb_footer_terms_href = pages.terms.url
  endif
-%}

{% style %}
  /* Custom element <footer-columns-*> defaults to inline in HTML; force block layout */
  .bb-footer-primary.ai-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-footer-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ bb_footer_grid_cols }}, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: start;
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five {
    column-gap: clamp(2rem, 3.5vw, 3.25rem);
    row-gap: 2rem;
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .bb-sf-clean-card {
    padding: 0;
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .bb-sf-clean-card .ai-footer-heading-{{ ai_gen_id }},
  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .bb-sf-card__title--loop {
    margin: 0 0 1rem;
    font-family: var(--bb-font-futura, "Futura LT Pro", Futura, "Century Gothic", sans-serif);
    font-size: max(0.8125rem, {{ section.settings.heading_size | minus: 2 }}px);
    font-weight: 700;
    line-height: 1.25;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: {{ section.settings.heading_color }};
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .ai-footer-menu-{{ ai_gen_id }} a {
    color: {{ section.settings.heading_color }};
    font-family: var(--bb-font-futura, "Futura LT Pro", Futura, "Century Gothic", sans-serif);
    font-weight: 400;
  }

  .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .ai-footer-menu-{{ ai_gen_id }} a:hover {
    color: {{ section.settings.link_hover_color }};
    opacity: 0.85;
  }

