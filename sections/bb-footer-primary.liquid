    .ai-footer-{{ ai_gen_id }} .ai-footer-contact-inner-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    .ai-footer-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }

    .ai-footer-{{ ai_gen_id }} .bb-sf-clean-card {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      padding: 1.25rem 1.1rem;
      text-align: center;
    }

    /* stretch so white cards share one full width (center was shrink-wrapping per column) */
    .ai-footer-{{ ai_gen_id }} .ai-footer-column-{{ ai_gen_id }} {
      align-items: stretch;
      width: 100%;
      max-width: 100%;
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-column-{{ ai_gen_id }} > .bb-subframe-newsletter--follow-box {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-logo-inline-{{ ai_gen_id }} {
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} ul.bb-footer-primary__social.bb-sf-social-rows {
      align-items: center;
      justify-content: center;
      width: 100%;
    }

    .ai-footer-{{ ai_gen_id }} ul.bb-footer-primary__social.bb-sf-social-rows:not(.bb-sf-social-rows--labeled) {
      margin-top: 1.75rem;
    }

    .ai-footer-{{ ai_gen_id }} .bb-sf-bottom-bar-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .bb-sf-copyright {
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-menu-{{ ai_gen_id }} {
      align-items: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-menu-{{ ai_gen_id }} li {
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-additional-lines-{{ ai_gen_id }} {
      align-items: center;
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-tagline-{{ ai_gen_id }} {
      margin-left: auto;
      margin-right: auto;
    }

    .ai-footer-{{ ai_gen_id }} .bb-subframe-newsletter--follow-box {
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-col-newsletter-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .ai-footer-{{ ai_gen_id }} .bb-subframe-newsletter--follow-box .bb-sf-card__title--loop,
    .ai-footer-{{ ai_gen_id }} .bb-subframe-newsletter--follow-box .bb-sf-card__sub,
    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .bb-subframe-newsletter--follow-box .bb-sf-card__sub {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five .bb-subframe-newsletter--follow-box .bb-sf-card__sub {
      max-width: min(17.5rem, 100%);
    }

    .ai-footer-{{ ai_gen_id }} .bb-sf-subscribe-row {
      max-width: 22rem;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five {
      grid-template-columns: minmax(0, 1.5fr) repeat(3, minmax(0, 1fr)) minmax(0, 1.4fr);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}.ai-footer-container--five {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 750px) and (max-width: 1024px) {
    .ai-footer-{{ ai_gen_id }} .ai-footer-container-{{ ai_gen_id }}:not(.ai-footer-container--five) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstyle %}

<div
  class="bb-footer-primary ai-footer-{{ ai_gen_id }}"
  {% if bb_footer_about_page != blank %}data-bb-about-page-url="{{ bb_footer_about_page.url | escape }}"{% endif %}
  {{ section.shopify_attributes }}
>
  <div class="ai-footer-container-{{ ai_gen_id }}{% if bb_footer_use_five_col %} ai-footer-container--five{% endif %}">
    {%- comment -%} Column 1: Subframe “Follow us” card — social links hard-coded (theme Social settings are not reliable for this section). {%- endcomment -%}
    <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-brand-{{ ai_gen_id }}">
      <div class="bb-sf-clean-card bb-sf-clean-card--follow">
        {%- comment -%} Treat missing checkbox as "on" (legacy section JSON); only explicit false hides logo. {%- endcomment -%}
        {%- unless section.settings.show_footer_logo == false -%}
          {%- if section.settings.footer_logo != blank -%}
            <div class="ai-footer-logo-inline-{{ ai_gen_id }}">
              <a href="{{ routes.root_url }}" class="ai-footer-logo-link-{{ ai_gen_id }}" aria-label="{{ shop.name }}">
                <img
                  src="{{ section.settings.footer_logo | image_url: width: 400 }}"
                  srcset="{{ section.settings.footer_logo | image_url: width: 200 }} 200w, {{ section.settings.footer_logo | image_url: width: 400 }} 400w"
                  sizes="(max-width: 749px) 55vw, 160px"
                  alt="{{ shop.name | escape }}"
                  width="{{ section.settings.footer_logo.width | default: 200 }}"
                  height="{{ section.settings.footer_logo.height | default: 80 }}"
                  loading="lazy"
                >
              </a>
            </div>
          {%- elsif settings.logo != blank -%}
            <div class="ai-footer-logo-inline-{{ ai_gen_id }}">
              <a href="{{ routes.root_url }}" class="ai-footer-logo-link-{{ ai_gen_id }}" aria-label="{{ shop.name }}">
                <img
                  src="{{ settings.logo | image_url: width: 400 }}"
                  srcset="{{ settings.logo | image_url: width: 200 }} 200w, {{ settings.logo | image_url: width: 400 }} 400w"
                  sizes="(max-width: 749px) 55vw, 160px"
                  alt="{{ shop.name | escape }}"
                  width="{{ settings.logo.width | default: 200 }}"
                  height="{{ settings.logo.height | default: 80 }}"
                  loading="lazy"
                >
              </a>
            </div>
          {%- endif -%}
        {%- endunless -%}
        {%- if section.settings.column_1_content != blank -%}
          <div class="ai-footer-text-{{ ai_gen_id }} ai-footer-tagline-{{ ai_gen_id }}">{{ section.settings.column_1_content }}</div>
        {%- endif -%}
        {%- comment -%} Only explicit Theme Editor "off" hides social (legacy JSON may omit the checkbox). {%- endcomment -%}
        {%- unless section.settings.show_social_icons == false -%}
          {%- liquid
            if settings.social_media_roundness
              assign bb_footer_social_ig = 'instagram_r'
              assign bb_footer_social_pi = 'pinterest_r'
              assign bb_footer_social_fb = 'facebook_r'
              assign bb_footer_social_tt = 'tiktok_r'
            else
              assign bb_footer_social_ig = 'instagram'
              assign bb_footer_social_pi = 'pinterest'
              assign bb_footer_social_fb = 'facebook'
              assign bb_footer_social_tt = 'tiktok'
            endif
            assign bb_footer_social_class = 'bb-footer-primary__social bb-sf-social-rows'
            unless bb_footer_use_five_col
              assign bb_footer_social_class = bb_footer_social_class | append: ' bb-sf-social-rows--labeled'
            endunless
          -%}
          {%- capture bb_footer_icon_ig -%}{%- render 'icons-list-social', icon_name: bb_footer_social_ig -%}{%- endcapture -%}
          {%- capture bb_footer_icon_pi -%}{%- render 'icons-list-social', icon_name: bb_footer_social_pi -%}{%- endcapture -%}
          {%- capture bb_footer_icon_fb -%}{%- render 'icons-list-social', icon_name: bb_footer_social_fb -%}{%- endcapture -%}
          {%- capture bb_footer_icon_tt -%}{%- render 'icons-list-social', icon_name: bb_footer_social_tt -%}{%- endcapture -%}
          <ul class="{{ bb_footer_social_class }}" role="list">
            <li>
              <a href="https://www.instagram.com/bikinibooth_official/" class="bb-sf-social-row__link" rel="noopener noreferrer" target="_blank">
                <span class="bb-sf-social-row__icon" aria-hidden="true">{{ bb_footer_icon_ig | strip }}</span>
                <span class="bb-sf-social-row__label">Instagram</span>
              </a>
            </li>
            <li>
              <a href="https://www.facebook.com/bikiniboothofficial/" class="bb-sf-social-row__link" rel="noopener noreferrer" target="_blank">
                <span class="bb-sf-social-row__icon" aria-hidden="true">{{ bb_footer_icon_fb | strip }}</span>
                <span class="bb-sf-social-row__label">Facebook</span>
              </a>
            </li>
            <li>
              <a href="https://uk.pinterest.com/bikinibooth_official/" class="bb-sf-social-row__link" rel="noopener noreferrer" target="_blank">
                <span class="bb-sf-social-row__icon" aria-hidden="true">{{ bb_footer_icon_pi | strip }}</span>
                <span class="bb-sf-social-row__label">Pinterest</span>
              </a>
            </li>
            <li>
              <a href="https://www.tiktok.com/@bikinibooth_official" class="bb-sf-social-row__link" rel="noopener noreferrer" target="_blank">
                <span class="bb-sf-social-row__icon" aria-hidden="true">{{ bb_footer_icon_tt | strip }}</span>
                <span class="bb-sf-social-row__label">TikTok</span>
              </a>
            </li>
          </ul>
        {%- endunless -%}
        {%- if bb_footer_use_five_col == false and section.settings.column_1_heading != blank -%}
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ section.settings.column_1_heading }}</h3>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Column 2: Shop {%- endcomment -%}
    <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-shop-{{ ai_gen_id }}">
      <div class="bb-sf-clean-card">
        {%- if section.settings.column_2_heading != blank -%}
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ section.settings.column_2_heading }}</h3>
        {%- endif -%}
        {%- if section.settings.column_2_content != blank -%}
          <div class="ai-footer-text-{{ ai_gen_id }}">{{ section.settings.column_2_content }}</div>
        {%- endif -%}
        {%- if section.settings.use_preset_quick_links -%}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {%- if section.settings.ql_path_new_arrivals != blank -%}
              <li><a href="{{ section.settings.ql_path_new_arrivals | escape }}">{{ section.settings.ql_label_new_arrivals | default: 'New Arrivals' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.ql_path_best_sellers != blank -%}
              <li><a href="{{ section.settings.ql_path_best_sellers | escape }}">{{ section.settings.ql_label_best_sellers | default: 'Best Sellers' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.ql_path_swimwear != blank -%}
              <li><a href="{{ section.settings.ql_path_swimwear | escape }}">{{ section.settings.ql_label_swimwear | default: 'Swimwear' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.ql_path_resortwear != blank -%}
              <li><a href="{{ section.settings.ql_path_resortwear | escape }}">{{ section.settings.ql_label_resortwear | default: 'Resortwear' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.ql_path_accessories != blank -%}
              <li><a href="{{ section.settings.ql_path_accessories | escape }}">{{ section.settings.ql_label_accessories | default: 'Accessories' | escape }}</a></li>
            {%- endif -%}
          </ul>
        {%- elsif section.settings.column_2_menu != blank -%}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {%- for link in section.settings.column_2_menu.links -%}
              <li><a href="{% render 'bb-footer-link-href', link: link, about_page: bb_footer_about_page %}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if bb_footer_use_five_col == false and section.settings.column_3_menu != blank -%}
          {%- if section.settings.column_3_heading != blank -%}
            <h3 class="ai-footer-heading-{{ ai_gen_id }} ai-footer-heading-sub-{{ ai_gen_id }}">{{ section.settings.column_3_heading }}</h3>
          {%- endif -%}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {%- for link in section.settings.column_3_menu.links -%}
              <li><a href="{% render 'bb-footer-link-href', link: link, about_page: bb_footer_about_page %}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if bb_footer_use_five_col -%}
      {%- comment -%} Column 3: Customer Care {%- endcomment -%}
      <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-care-{{ ai_gen_id }}">
        <div class="bb-sf-clean-card">
          {%- if section.settings.column_cc_heading != blank -%}
            <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ section.settings.column_cc_heading }}</h3>
          {%- endif -%}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {%- if section.settings.cc_path_contact != blank -%}
              <li><a href="{{ section.settings.cc_path_contact | escape }}">{{ section.settings.cc_label_contact | default: 'Contact' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.cc_path_shipping != blank -%}
              <li><a href="{{ section.settings.cc_path_shipping | escape }}">{{ section.settings.cc_label_shipping | default: 'Shipping & Returns' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.cc_path_faqs != blank -%}
              <li><a href="{{ section.settings.cc_path_faqs | escape }}">{{ section.settings.cc_label_faqs | default: "FAQ's" | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.cc_path_size_guide != blank -%}
              <li><a href="{{ section.settings.cc_path_size_guide | escape }}">{{ section.settings.cc_label_size_guide | default: 'Size Guide' | escape }}</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>

      {%- comment -%} Column 4: About {%- endcomment -%}
      <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-about-{{ ai_gen_id }}">
        <div class="bb-sf-clean-card">
          {%- if section.settings.column_about_heading != blank -%}
            <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ section.settings.column_about_heading }}</h3>
          {%- endif -%}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {%- if bb_footer_about_href != blank -%}
              <li><a href="{{ bb_footer_about_href | escape }}">{{ section.settings.about_label_about_us | default: 'About Us' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.about_path_stores != blank -%}
              <li><a href="{{ section.settings.about_path_stores | escape }}">{{ section.settings.about_label_stores | default: 'Our Stores' | escape }}</a></li>
            {%- endif -%}
            {%- if section.settings.about_path_reviews != blank -%}
              <li><a href="{{ section.settings.about_path_reviews | escape }}" rel="noopener noreferrer"{% if section.settings.about_path_reviews contains 'http' %} target="_blank"{% endif %}>{{ section.settings.about_label_reviews | default: 'Store Reviews' | escape }}</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>
    {%- endif -%}

    {%- if bb_footer_show_additional -%}
      {%- comment -%} Column: Additional information (between quick links and newsletter). {%- endcomment -%}
      <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-additional-{{ ai_gen_id }}">
        <div class="bb-sf-clean-card">
          {%- if section.settings.additional_info_heading != blank -%}
            <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ section.settings.additional_info_heading }}</h3>
          {%- endif -%}
          {%- unless section.settings.additional_info_line_1 == blank and section.settings.additional_info_line_2 == blank and section.settings.additional_info_line_3 == blank and section.settings.additional_info_line_4 == blank and section.settings.additional_info_line_5 == blank and section.settings.additional_info_line_6 == blank -%}
            <ul class="ai-footer-additional-lines-{{ ai_gen_id }}">
              {%- for i in (1..6) -%}
                {%- assign line_key = 'additional_info_line_' | append: i -%}
                {%- assign url_key = line_key | append: '_url' -%}
                {%- assign line_text = section.settings[line_key] -%}
                {%- assign line_url = section.settings[url_key] -%}
                {%- if line_text != blank -%}
                  <li>
                    {%- if line_url != blank -%}
                      <a href="{{ line_url }}">{{ line_text | escape }}</a>
                    {%- else -%}
                      {{ line_text | escape }}
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endunless -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Column: Subframe “Stay in the loop” + TextField row (Shopify customer form) {%- endcomment -%}
    {%- if section.settings.show_newsletter -%}
      <div class="ai-footer-column-{{ ai_gen_id }} ai-footer-col-newsletter-{{ ai_gen_id }}">
        <div class="bb-subframe bb-subframe-newsletter bb-subframe-newsletter--follow-box" id="bb-footer-nl-{{ section.id }}">
          <div class="bb-sf-clean-card">
            {%- if section.settings.newsletter_heading != blank -%}
              <h2 class="bb-sf-card__title--loop">{{ section.settings.newsletter_heading }}</h2>
            {%- endif -%}
            {%- if section.settings.newsletter_subtext != blank -%}
              <p class="bb-sf-card__sub">{{ section.settings.newsletter_subtext }}</p>
            {%- endif -%}
            {%- form 'customer', class: 'bb-subframe-newsletter__form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              {%- if form.errors -%}
                <div class="bb-subframe-newsletter__errors">{{ form.errors | default_errors }}</div>
              {%- endif -%}
              <div class="bb-sf-subscribe-row">
                <label class="visually-hidden" for="bb-footer-nl-email-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                <input
                  id="bb-footer-nl-email-{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="bb-sf-subscribe-input bb-subframe-newsletter__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email' }}"
                  required
                >
                <button type="submit" class="bb-sf-subscribe-btn bb-subframe-newsletter__submit" name="commit" aria-label="{{ section.settings.newsletter_button_label | default: 'Subscribe' | escape }}">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h12M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="bb-subframe-newsletter__status" tabindex="-1">{{ 'newsletter.success' | t }}</p>
              {%- endif -%}
            {%- endform -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- liquid
    assign bb_show_contact = false
    if section.settings.show_contact_row
      if section.settings.contact_phone != blank or section.settings.contact_email != blank or section.settings.contact_location != blank
        assign bb_show_contact = true
      endif
    endif
    assign bb_show_currency_inline = false
    if section.settings.show_currency_row and localization.available_countries.size > 1
      assign bb_show_currency_inline = true
    endif
    assign bb_show_policy_links = false
    if section.settings.show_policy_links
      if bb_footer_privacy_href != blank or bb_footer_terms_href != blank
        assign bb_show_policy_links = true
      endif
    endif
    assign bb_show_bottom = false
    if bb_show_contact or section.settings.show_copyright_bar or bb_show_policy_links or bb_show_currency_inline
      assign bb_show_bottom = true
    endif
  -%}
  {%- if bb_show_bottom -%}
    {%- if bb_show_contact -%}
      <hr class="bb-sf-rule" role="presentation">
      <div class="ai-footer-contact-{{ ai_gen_id }}">
        <div class="ai-footer-contact-inner-{{ ai_gen_id }}">
          {%- if section.settings.contact_phone != blank -%}
            {%- assign bb_tel = section.settings.contact_phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' -%}
            <div class="ai-footer-contact-item-{{ ai_gen_id }}">
              <span class="theme-icon" aria-hidden="true">{% render 'icons-list', icon_name: 'phone' %}</span>
              <a href="tel:{{ bb_tel }}">{{ section.settings.contact_phone | escape }}</a>
            </div>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
            <div class="ai-footer-contact-item-{{ ai_gen_id }}">
              <span class="theme-icon" aria-hidden="true">{% render 'icons-list', icon_name: 'mail' %}</span>
              <a href="mailto:{{ section.settings.contact_email | strip | escape }}">{{ section.settings.contact_email | escape }}</a>
            </div>
          {%- endif -%}
          {%- if section.settings.contact_location != blank -%}
            <div class="ai-footer-contact-item-{{ ai_gen_id }}">
              <span class="theme-icon" aria-hidden="true">{% render 'icons-list', icon_name: 'marker' %}</span>
              <span>{{ section.settings.contact_location | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    {%- if section.settings.show_copyright_bar or bb_show_policy_links or bb_show_currency_inline -%}
      {%- if bb_show_contact -%}
        <hr class="bb-sf-rule bb-sf-rule--tight" role="presentation">
      {%- else -%}
        <hr class="bb-sf-rule" role="presentation">
      {%- endif -%}
      <div class="bb-sf-bottom-bar-{{ ai_gen_id }}">
        {%- if section.settings.show_copyright_bar -%}
          <p class="bb-sf-copyright">
            {%- if section.settings.copyright_text != blank -%}
              {{ section.settings.copyright_text }}
            {%- else -%}
              © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
            {%- endif -%}
          </p>
        {%- endif -%}
        {%- if bb_show_policy_links or bb_show_currency_inline -%}
          <ul class="bb-sf-policy-links-{{ ai_gen_id }}">
            {%- if bb_show_currency_inline -%}
              <li class="bb-sf-policy-currency">
                {%- render 'bb-footer-currency-selector' -%}
              </li>
              {%- if bb_show_policy_links -%}
                <li class="bb-sf-policy-sep" aria-hidden="true">|</li>
              {%- endif -%}
            {%- endif -%}
            {%- if bb_footer_privacy_href != blank -%}
              <li><a href="{{ bb_footer_privacy_href | escape }}">{{ section.settings.privacy_label | default: 'Privacy Policy' | escape }}</a></li>
            {%- endif -%}
            {%- if bb_footer_privacy_href != blank and bb_footer_terms_href != blank -%}
              <li class="bb-sf-policy-sep" aria-hidden="true">|</li>
            {%- endif -%}
            {%- if bb_footer_terms_href != blank -%}
              <li><a href="{{ bb_footer_terms_href | escape }}">{{ section.settings.terms_label | default: 'Terms of Service' | escape }}</a></li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{%- if request.design_mode and bb_footer_about_page != blank -%}
  <script>
    (function () {
      var root = document.querySelector('.bb-footer-primary[data-bb-about-page-url]');
      if (!root || !window.Shopify || !Shopify.designMode) return;
      var aboutUrl = root.getAttribute('data-bb-about-page-url');
      if (!aboutUrl) return;
      root.querySelectorAll('a[href*="/pages/about"]').forEach(function (anchor) {
        var href = anchor.getAttribute('href') || '';
        if (href.indexOf('about-us') === -1) {
          anchor.setAttribute('href', aboutUrl);
        }
      });
    })();
  </script>
{%- endif -%}

