{% comment %}
  Minimal newsletter block (typically homepage only; footer has bb-footer-primary newsletter).
{% endcomment %}
{%- liquid
  assign bb_nl_show = false
  if template.name == 'index' or section.settings.show_on_all_pages
    assign bb_nl_show = true
  endif
-%}
{%- if bb_nl_show -%}
{%- if section.settings.bg_color != blank -%}
  <style>
    #bb-newsletter-{{ section.id }} { background-color: {{ section.settings.bg_color }}; }
  </style>
{%- endif -%}
<section class="bb-subframe bb-subframe-newsletter" id="bb-newsletter-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="bb-subframe-newsletter__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="bb-subframe-newsletter__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="bb-subframe-newsletter__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'bb-subframe-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.errors -%}
        <div class="bb-subframe-newsletter__errors">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="bb-subframe-newsletter__row">
        <label class="visually-hidden" for="bb-newsletter-email-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
        <input
          id="bb-newsletter-email-{{ section.id }}"
          type="email"
          name="contact[email]"
          class="bb-subframe-newsletter__input"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          placeholder="{{ section.settings.placeholder | default: 'Email address' | escape }}"
          required
        >
        <button type="submit" class="bb-subframe-newsletter__submit" name="commit">
          <span class="bb-subframe-newsletter__submit-text">{{ section.settings.button_label | default: 'Subscribe' | escape }}</span>
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="bb-subframe-newsletter__status" tabindex="-1">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "BB - Newsletter",
  "tag": "section",
  "class": "bb-subframe-newsletter-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_on_all_pages",
      "label": "Show on all page types",
      "default": false,
      "info": "Leave off so this block only appears on the home page (footer has signup elsewhere)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Sign up for new arrivals and exclusive offers."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "info": "Leave empty to use the theme default."
    }
  ],
  "presets": [
    {
      "name": "BB - Newsletter"
    }
  ]
}
{% endschema %}
