    });

    /* Drag to pan when enlarged */
    lbImg.addEventListener('mousedown', function (e) {
      if (!lbEnlarged) return;
      e.preventDefault();
      lbDragging = true; lbMoved = false;
      lbStartX = e.clientX; lbStartY = e.clientY;
      lbBaseX = lbPanX; lbBaseY = lbPanY;
      lbImg.style.cursor = 'grabbing';
    });

    /* Delegated controls + backdrop / empty-stage close */
    lb.addEventListener('click', function (e) {
      if (e.target.closest('[data-bb-lb-close]')) { closeLightbox(); return; }
      if (e.target.closest('[data-bb-lb-prev]'))  { lbGo(-1); return; }
      if (e.target.closest('[data-bb-lb-next]'))  { lbGo(1);  return; }
      if (e.target === lbStage) { closeLightbox(); }
    });
  }

  /* Document-level drag move/up — named so they unbind on section unload */
  function onLbDocMove(e) {
    if (!lbDragging) return;
    var dx = e.clientX - lbStartX, dy = e.clientY - lbStartY;
    if (Math.abs(dx) > 3 || Math.abs(dy) > 3) lbMoved = true;
    lbPanX = lbBaseX + dx; lbPanY = lbBaseY + dy;
    lbClampPan();
    lbApplyTransform();
  }
  function onLbDocUp() {
    if (!lbDragging) return;
    lbDragging = false;
    if (lbEnlarged) lbImg.style.cursor = 'grab';
  }
  document.addEventListener('mousemove', onLbDocMove);
  document.addEventListener('mouseup', onLbDocUp);

  /* ── Document-level listeners use named handlers so they can be removed on
     Shopify section reload — prevents duplicate-listener stacking in the editor ── */
  function onDocKeydown(e) {
    if (lbOpen) {
      if (e.key === 'Escape')     { e.preventDefault(); closeLightbox(); return; }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); lbGo(-1); return; }
      if (e.key === 'ArrowRight') { e.preventDefault(); lbGo(1);  return; }
      if (e.key === 'Tab') {
        var f = lbFocusables();
        if (f.length) {
          var first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }
      return;
    }
    if (e.key === 'Escape' && isZoomed) setZoom(false);
  }
  function onRequestSlide(e) {
    var idx = resolveRequestedIndex(e.detail);
    if (idx !== null) goTo(idx);
  }
  document.addEventListener('keydown', onDocKeydown);
  document.addEventListener('bb:requestSlide', onRequestSlide);

  document.addEventListener('shopify:section:unload', function onUnload(e) {
    if (!e.detail || e.detail.sectionId !== '{{ section.id }}') return;
    document.removeEventListener('keydown', onDocKeydown);
    document.removeEventListener('bb:requestSlide', onRequestSlide);
    document.removeEventListener('mousemove', onLbDocMove);
    document.removeEventListener('mouseup', onLbDocUp);
    document.body.style.overflow = '';                                 /* release scroll lock if open */
    if (lb && lb.parentNode) { lb.parentNode.removeChild(lb); }        /* remove the portaled lightbox node */
    document.removeEventListener('shopify:section:unload', onUnload);  /* remove self -> no accumulation */
    Array.prototype.forEach.call(slides, function (s) {
      var v = s.querySelector('.bb-media__video');
      if (v) { try { v.pause(); } catch (err) {} }
    });
  });

  /* ── Wire video custom controls + keep their state in sync ── */
  Array.prototype.forEach.call(stage.querySelectorAll('.bb-media__slide--video'), function (slide) {
    var v = slide.querySelector('.bb-media__video');
    if (!v) return;
    var playBtn = slide.querySelector('.bb-media__vbtn--play');
    var muteBtn = slide.querySelector('.bb-media__vbtn--mute');
    if (playBtn) playBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      if (v.paused) tryPlay(v); else v.pause();
    });
    if (muteBtn) muteBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      v.muted = !v.muted;
      updateVideoButtons(v);
    });
    if (!cfg.nativeControls) {
      v.addEventListener('click', function (e) {
        e.stopPropagation();
        if (v.paused) tryPlay(v); else v.pause();
      });
    }
    v.addEventListener('play',  function () { updateVideoButtons(v); });
    v.addEventListener('pause', function () { updateVideoButtons(v); });
    v.addEventListener('volumechange', function () { updateVideoButtons(v); });
    updateVideoButtons(v);
  });

  /* ── Initial active media: set stage mode, autoplay first slide if it's a video ── */
  setStageMode();
  (function () {
    var v0 = getVideo(activeIdx);
    if (v0 && cfg.autoplay && !reduceMotion) tryPlay(v0);
  })();

})();
</script>


