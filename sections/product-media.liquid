{%- comment -%}
  Section: product-media.liquid
  Purpose: Product image gallery — 9:16 portrait stage, vertical thumbnail strip
           on desktop left, dot navigation on mobile. Desktop image lightbox.
  Injects: bb-product-layout snippet for two-column page grid.
{%- endcomment -%}

{% render 'bb-product-layout' %}

{%- assign thumb_position = section.settings.thumb_position -%}
{%- assign image_fit      = section.settings.image_fit -%}
{%- assign bg_color       = section.settings.bg_color -%}
{%- assign border_radius  = section.settings.border_radius -%}
{%- assign enable_zoom    = section.settings.enable_zoom -%}
{%- assign enable_lightbox = section.settings.enable_lightbox -%}
{%- assign enable_dots    = section.settings.enable_dots -%}
{%- assign sticky         = section.settings.sticky_gallery -%}

{%- comment -%} Video settings {%- endcomment -%}
{%- assign vid_autoplay   = section.settings.video_autoplay -%}
{%- assign vid_loop       = section.settings.video_loop -%}
{%- assign vid_muted      = section.settings.video_muted -%}
{%- assign vid_controls   = section.settings.video_controls -%}
{%- assign vid_show_play  = section.settings.video_custom_playpause -%}
{%- assign vid_show_mute  = section.settings.video_custom_mute -%}
{%- assign vid_thumb_play = section.settings.video_thumb_play_icon -%}

<div
  class="bb-media bb-media--thumbs-{{ thumb_position }}"
  id="bb-media-{{ section.id }}"
  data-zoom="{{ enable_zoom }}"
>
  {%- comment -%} ── Thumbnail strip (desktop left / desktop bottom / hidden) ── {%- endcomment -%}
  {%- if product.media.size > 1 and thumb_position != 'hidden' -%}
    <div
      class="bb-media__thumbs"
      id="bb-media-thumbs-{{ section.id }}"
      role="tablist"
      aria-label="Product media thumbnails"
    >
      {%- assign t_img_i = 0 -%}
      {%- for media in product.media -%}
        {%- assign t_is_video = false -%}
        {%- if media.media_type == 'video' -%}{%- assign t_is_video = true -%}{%- endif -%}
        <button
          type="button"
          class="bb-media__thumb{%- if forloop.first %} is-active{%- endif -%}{%- if t_is_video %} bb-media__thumb--video{%- endif -%}"
          role="tab"
          aria-selected="{%- if forloop.first -%}true{%- else -%}false{%- endif -%}"
          aria-label="{{ media.alt | escape | default: product.title }} — {% if t_is_video %}video{% else %}image{% endif %} {{ forloop.index }}"
          data-index="{{ forloop.index0 }}"
          data-media-index="{{ forloop.index0 }}"
          {%- unless t_is_video %} data-image-index="{{ t_img_i }}"{%- endunless %}
          data-media-type="{{ media.media_type }}"
        >
          <img
            src="{{ media.preview_image | image_url: width: 160, height: 200, crop: 'center' }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="{{ section.settings.thumb_width }}"
            height="{{ section.settings.thumb_height }}"
            loading="lazy"
          >
          {%- if t_is_video and vid_thumb_play -%}
            <span class="bb-media__thumb-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20"/></svg>
            </span>
          {%- endif -%}
        </button>
        {%- unless t_is_video -%}{%- assign t_img_i = t_img_i | plus: 1 -%}{%- endunless -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Main image stage ── {%- endcomment -%}
  <div class="bb-media__stage-wrap">
    <div
      class="bb-media__stage"
      id="bb-media-stage-{{ section.id }}"
      aria-label="Product images"
    >

      {%- if product.media.size > 0 -%}
        {%- assign img_i = 0 -%}
        {%- for media in product.media -%}
          {%- if media.media_type == 'video' -%}
            <div
              class="bb-media__slide bb-media__slide--video{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
              data-media-index="{{ forloop.index0 }}"
              data-media-type="video"
              role="group"
              aria-label="{{ media.alt | escape | default: product.title }} — video {{ forloop.index }} of {{ product.media.size }}"
              aria-hidden="{%- unless forloop.first -%}true{%- else -%}false{%- endunless -%}"
            >
              <video
                class="bb-media__video"
                playsinline
                preload="metadata"
                poster="{{ media.preview_image | image_url: width: 1000 }}"
                {%- if vid_muted %} muted{%- endif -%}
                {%- if vid_loop %} loop{%- endif -%}
                {%- if vid_controls %} controls controlsList="{% if section.settings.video_hide_download %}nodownload {% endif %}{% if section.settings.video_hide_fullscreen %}nofullscreen {% endif %}{% if section.settings.video_hide_remote %}noremoteplayback{% endif %}"{%- endif -%}
                {%- if section.settings.video_hide_remote %} disableremoteplayback{%- endif -%}
              >
                {%- for source in media.sources -%}
                  {%- if source.mime_type contains 'video' -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endif -%}
                {%- endfor -%}
              </video>
              {%- if vid_show_play or vid_show_mute -%}
                <div class="bb-media__vcontrols"{%- if vid_controls %} hidden{%- endif -%}>
                  {%- if vid_show_play -%}
                    <button type="button" class="bb-media__vbtn bb-media__vbtn--play" aria-label="Play video">
                      <svg class="bb-icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20"/></svg>
                      <svg class="bb-icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
                    </button>
                  {%- endif -%}
                  {%- if vid_show_mute -%}
                    <button type="button" class="bb-media__vbtn bb-media__vbtn--mute" aria-label="{% if vid_muted %}Unmute video{% else %}Mute video{% endif %}">
                      <svg class="bb-icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"{%- unless vid_muted %} style="display:none"{%- endunless -%}><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                      <svg class="bb-icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"{%- if vid_muted %} style="display:none"{%- endif -%}><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- else -%}
            <div
              class="bb-media__slide{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
              data-media-index="{{ forloop.index0 }}"
              data-image-index="{{ img_i }}"
              data-media-type="image"
              role="img"
              aria-label="{{ media.alt | escape | default: product.title }} — image {{ forloop.index }} of {{ product.media.size }}"
              aria-hidden="{%- unless forloop.first -%}true{%- else -%}false{%- endunless -%}"
            >
              <img
                src="{{ media.preview_image | image_url: width: 1000 }}"
                srcset="
                  {{ media.preview_image | image_url: width: 480 }}  480w,
                  {{ media.preview_image | image_url: width: 750 }}  750w,
                  {{ media.preview_image | image_url: width: 1000 }} 1000w
                "
                sizes="(max-width: 767px) 100vw, 40vw"
                alt="{{ media.alt | escape | default: product.title }}"
                width="{{ media.preview_image.width }}"
                height="{{ media.preview_image.height }}"
                loading="{%- if forloop.first -%}eager{%- else -%}lazy{%- endif -%}"
                class="bb-media__img"
              >
            </div>
            {%- assign img_i = img_i | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="bb-media__slide is-active bb-media__no-image" data-media-type="none">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c0b4a8" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p>No media</p>
        </div>
      {%- endif -%}

      {%- comment -%} Zoom button (images only; JS hides it on video slides) {%- endcomment -%}
      {%- if enable_zoom and product.media.size > 0 -%}
        <button
          type="button"
          class="bb-media__zoom-btn"
          id="bb-media-zoom-{{ section.id }}"
          aria-label="Zoom image"
          aria-pressed="false"
        >
          <svg class="bb-zoom-in" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          <svg class="bb-zoom-out" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
      {%- endif -%}

      {%- comment -%} Mobile dots {%- endcomment -%}
      {%- if enable_dots and product.media.size > 1 -%}
        <div class="bb-media__dots" aria-hidden="true" id="bb-media-dots-{{ section.id }}">
          {%- for media in product.media -%}
            <div
              class="bb-media__dot{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
            ></div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} ── Prev / next arrows ── {%- endcomment -%}
    {%- if product.media.size > 1 -%}
      <button type="button" class="bb-media__arrow bb-media__arrow--prev" id="bb-media-prev-{{ section.id }}" aria-label="Previous image">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button type="button" class="bb-media__arrow bb-media__arrow--next" id="bb-media-next-{{ section.id }}" aria-label="Next image">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}
  </div>

  {%- comment -%} ── Desktop image lightbox (IMAGES ONLY — videos never open it) ── {%- endcomment -%}
  {%- if enable_lightbox -%}
    {%- assign bb_lb_count = 0 -%}
    {%- for media in product.media -%}{%- if media.media_type == 'image' -%}{%- assign bb_lb_count = bb_lb_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
    {%- if bb_lb_count > 0 -%}
      <div
        class="bb-lightbox"
        id="bb-lightbox-{{ section.id }}"
        role="dialog"
        aria-modal="true"
        aria-label="Product image viewer"
        hidden
      >
        <div class="bb-lightbox__backdrop" data-bb-lb-close></div>

        <button type="button" class="bb-lightbox__close" data-bb-lb-close aria-label="Close image viewer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>

        {%- if bb_lb_count > 1 -%}
          <button type="button" class="bb-lightbox__nav bb-lightbox__nav--prev" data-bb-lb-prev aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="bb-lightbox__nav bb-lightbox__nav--next" data-bb-lb-next aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}

        <div class="bb-lightbox__stage" data-bb-lb-stage>
          <img class="bb-lightbox__img" id="bb-lightbox-img-{{ section.id }}" src="" alt="" draggable="false">
        </div>

        {%- if bb_lb_count > 1 -%}
          <div class="bb-lightbox__counter" data-bb-lb-counter aria-hidden="true"></div>
        {%- endif -%}
      </div>

      <script type="application/json" id="bb-lightbox-data-{{ section.id }}">
        [
          {%- assign bb_lb_i = 0 -%}
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              {%- if bb_lb_i > 0 -%},{%- endif -%}
              {"mediaIndex": {{ forloop.index0 }}, "normal": {{ media.preview_image | image_url: width: 1600 | json }}, "hi": {{ media.preview_image | image_url: width: 2400 | json }}, "alt": {{ media.alt | default: product.title | json }}}
              {%- assign bb_lb_i = bb_lb_i | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      </script>
    {%- endif -%}
  {%- endif -%}

</div>


<style>
  /* ── Section wrapper ── */
  #bb-media-{{ section.id }} {
    display: flex !important;
    flex-direction: row !important;
    gap: {{ section.settings.thumb_gap }}px;
    background: {{ bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    align-items: flex-start;
  }

  /* ── Stage wrap fills remaining space ── */
  #bb-media-{{ section.id }} .bb-media__stage-wrap {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  /* ── Prev / next arrows ── */
  #bb-media-{{ section.id }} .bb-media__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #49c6be;
    background: rgba(255, 255, 255, 0.85);
    color: #49c6be;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    z-index: 5;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }
  #bb-media-{{ section.id }} .bb-media__arrow svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  #bb-media-{{ section.id }} .bb-media__arrow:hover {
    background: #49c6be;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(73, 198, 190, 0.35);
  }
  #bb-media-{{ section.id }} .bb-media__arrow--prev { left: 12px; }
  #bb-media-{{ section.id }} .bb-media__arrow--next { right: 12px; }

  /* ── Stage: enforces 9:16 aspect ratio ── */
  #bb-media-{{ section.id }} .bb-media__stage {
    position: relative;
    width: 100%;
    {%- case section.settings.aspect_ratio -%}
      {%- when '9:16' -%}
        aspect-ratio: 9 / 16;
      {%- when '3:4' -%}
        aspect-ratio: 3 / 4;
      {%- when '1:1' -%}
        aspect-ratio: 1 / 1;
      {%- when 'natural' -%}
        aspect-ratio: auto;
        min-height: 400px;
    {%- endcase -%}
    background: {{ bg_color }};
    border-radius: {{ border_radius }}px;
    overflow: hidden;
    cursor: crosshair;
  }

  /* ── Slides (crossfade on desktop, horizontal slide on mobile) ── */
  #bb-media-{{ section.id }} .bb-media__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateX(0);
    transition: transform 0.35s ease, opacity 0.35s ease;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }
  /* Outgoing slide stays opaque while it slides out (mobile) */
  #bb-media-{{ section.id }} .bb-media__slide.is-leaving {
    opacity: 1;
    z-index: 1;
  }

  /* ── Images ── */
  #bb-media-{{ section.id }} .bb-media__img {
    width: 100%;
    height: 100%;
    object-fit: {{ image_fit }};
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
    transform-origin: center center;
  }

  /* ── Video ── */
  #bb-media-{{ section.id }} .bb-media__slide--video {
    background: {{ section.settings.video_bg_color }};
  }
  #bb-media-{{ section.id }} .bb-media__video {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.video_object_fit }};
    object-position: center center;
    display: block;
    background: {{ section.settings.video_bg_color }};
  }
  /* Video slides never use the zoom crosshair */
  #bb-media-{{ section.id }} .bb-media__stage.is-video { cursor: default; }

  /* Custom video controls */
  #bb-media-{{ section.id }} .bb-media__vcontrols {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    gap: 8px;
    z-index: 4;
  }
  #bb-media-{{ section.id }} .bb-media__vcontrols[hidden] { display: none; }
  #bb-media-{{ section.id }} .bb-media__vbtn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #49c6be;
    background: rgba(255, 255, 255, 0.85);
    color: #49c6be;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s ease, color 0.15s ease;
  }
  #bb-media-{{ section.id }} .bb-media__vbtn:hover { background: #49c6be; color: #ffffff; }
  #bb-media-{{ section.id }} .bb-media__vbtn svg { width: 16px; height: 16px; display: block; }

  /* Play icon overlay on video thumbnails */
  #bb-media-{{ section.id }} .bb-media__thumb-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 50%;
    color: #ffffff;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__thumb-play svg { width: 10px; height: 10px; }

  /* Visible focus states */
  #bb-media-{{ section.id }} .bb-media__thumb:focus-visible,
  #bb-media-{{ section.id }} .bb-media__arrow:focus-visible,
  #bb-media-{{ section.id }} .bb-media__vbtn:focus-visible,
  #bb-media-{{ section.id }} .bb-media__zoom-btn:focus-visible {
    outline: 2px solid #49c6be;
    outline-offset: 2px;
  }

  /* ── Hover zoom (desktop) ── */
  @media (hover: hover) {
    #bb-media-{{ section.id }} .bb-media__stage:hover .bb-media__slide.is-active .bb-media__img {
      transform: scale(1.04);
    }
  }

  /* ── Click zoom ── */
  /* Reveal the FULL image when zoomed: switch from the cropped stage fit to
     'contain' so nothing is cut off, then scale + pan to inspect it. */
  #bb-media-{{ section.id }} .bb-media__stage.is-zoomed .bb-media__slide.is-active .bb-media__img {
    transform: scale(1.7);
    object-fit: contain;
    object-position: center center;
    cursor: zoom-out;
  }

  /* ── No image placeholder ── */
  #bb-media-{{ section.id }} .bb-media__no-image {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    opacity: 1;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__no-image p {
    font-size: 0.75rem;
    color: #c0b4a8;
  }

  /* ── Zoom button ── */
  #bb-media-{{ section.id }} .bb-media__zoom-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    background: rgba(255,255,255,0.9);
    border: 0.5px solid #e0dbd3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.15s;
  }
  #bb-media-{{ section.id }} .bb-media__zoom-btn:hover { background: #ffffff; }

  /* ── Mobile dots ── */
  #bb-media-{{ section.id }} .bb-media__dots {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    display: none;
    justify-content: center;
    gap: 5px;
    z-index: 2;
  }
  #bb-media-{{ section.id }} .bb-media__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    transition: background 0.2s, width 0.2s;
    cursor: pointer;
  }
  #bb-media-{{ section.id }} .bb-media__dot.is-active {
    background: #ffffff;
    width: 14px;
    border-radius: 3px;
  }

  /* ── Thumbnail strip — left (desktop default) ── */
  #bb-media-{{ section.id }} .bb-media__thumbs {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.thumb_gap }}px;
    flex-shrink: 0;
    width: {{ section.settings.thumb_width }}px;
    max-height: 80vh;
    overflow-y: auto;
    scrollbar-width: none;
    padding: 2px;
  }
  #bb-media-{{ section.id }} .bb-media__thumbs::-webkit-scrollbar { display: none; }

  /* ── Thumbnail button ── */
  #bb-media-{{ section.id }} .bb-media__thumb {
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ border_radius | divided_by: 2 }}px;
    overflow: hidden;
    border: 1.5px solid transparent;
    background: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s;
    display: block;
    position: relative;
  }
  #bb-media-{{ section.id }} .bb-media__thumb.is-active {
    border-color: #49c6be;
  }
  #bb-media-{{ section.id }} .bb-media__thumb:not(.is-active):hover {
    border-color: #c5e8e6;
  }
  #bb-media-{{ section.id }} .bb-media__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
