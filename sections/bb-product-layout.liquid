{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  DOM order (must match product.json order):
  1. media   — left col, rows 1–5, sticky
  2. sp      — left col, row 6 (directly below media)
  3. info    — right col row 1
  4. trust   — right col row 2
  5. fit     — right col row 3
  6. ctl     — right col row 4
  7. acc     — right col row 5
  8. recs    — full width row 7
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     ."
        "recs   recs" !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }
  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section.bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>

<script>
(function () {
  'use strict';

  function applyGridAreas() {
    if (window.innerWidth < 900) return;

    var assignments = [
      { cls: 'bb-product-media-section', area: 'media', extra: { position: 'sticky', top: '0', height: '100vh', overflow: 'hidden', alignSelf: 'start', gridRow: '1 / 6' } },
      { cls: 'bb-product-sp-section',    area: 'sp',    extra: { alignSelf: 'start' } },
      { cls: 'bb-product-info-section',  area: 'info' },
      { cls: 'bb-product-trust-section', area: 'trust' },
      { cls: 'bb-product-fit-section',   area: 'fit' },
      { cls: 'bb-product-ctl-section',   area: 'ctl' },
      { cls: 'bb-product-acc-section',   area: 'acc' }
    ];

    assignments.forEach(function (item) {
      var el = document.querySelector('.shopify-section.' + item.cls);
      if (!el) return;
      el.style.setProperty('grid-area', item.area, 'important');
      el.style.minWidth = '0';
      if (item.extra) {
        if (item.extra.position)  el.style.position  = item.extra.position;
        if (item.extra.top)       el.style.top        = item.extra.top;
        if (item.extra.height)    el.style.setProperty('height', item.extra.height, 'important');
        if (item.extra.overflow)  el.style.overflow   = item.extra.overflow;
        if (item.extra.alignSelf) el.style.alignSelf  = item.extra.alignSelf;
        if (item.extra.gridRow)   el.style.setProperty('grid-row', item.extra.gridRow, 'important');
      }
    });

    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyGridAreas);
  } else {
    applyGridAreas();
  }
  setTimeout(applyGridAreas, 100);

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(applyGridAreas, 150);
  });

})();
</script>
