{%- comment -%}
  Section: product-social-proof.liquid
  Purpose: Social proof panel — block-based UGC pool + Google reviews.

  UGC blocks: each block is either a video (URL) or image (image_picker) + Instagram handle.
  On page load JS picks 3 random UGC blocks and displays them in a 9:16 portrait grid.
  Reviews: block-based, one picked at random per page load, links to direct Google review URL.
{%- endcomment -%}

{%- assign ugc_blocks    = section.blocks | where: 'type', 'ugc_item' -%}
{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}

<div class="bb-sp" id="bb-sp-{{ section.id }}">

  {%- comment -%} ── Section heading ── {%- endcomment -%}
  <div class="bb-sp__head">
    <p class="bb-sp__title">
      {{- section.settings.sp_section_title | default: 'As worn by our community' -}}
    </p>
    <p class="bb-sp__subtitle">
      {%- if section.settings.sp_section_subtitle != blank -%}
        {{ section.settings.sp_section_subtitle }}
      {%- elsif section.settings.sp_instagram_handle != blank -%}
        Tag us {{ section.settings.sp_instagram_handle }} for a chance to be featured
      {%- else -%}
        Tag us for a chance to be featured
      {%- endif -%}
    </p>
  </div>

  {%- comment -%} ── UGC grid: 1 tall left + 2 stacked right ── {%- endcomment -%}
  <div
    class="bb-sp__ugc-grid"
    id="bb-sp-ugc-{{ section.id }}"
    aria-label="Community photos and videos"
  >
    {%- comment -%} Hidden data pool — JS reads and picks 3 random items {%- endcomment -%}
    <div class="bb-sp__ugc-pool" aria-hidden="true" style="display:none;">
      {%- for block in ugc_blocks -%}
        <div
          class="bb-sp__ugc-pool-item"
          data-type="{{ block.settings.media_type }}"
          data-video="{{ block.settings.video_url | escape }}"
          data-image="{{ block.settings.image | image_url: width: 800 | escape }}"
          data-handle="{{ block.settings.instagram_handle | escape }}"
          {{ block.shopify_attributes }}
        ></div>
      {%- endfor -%}
    </div>

    {%- comment -%} Skeleton placeholders while JS loads {%- endcomment -%}
    <div class="bb-sp__ugc-tall bb-sp__ugc-skeleton" aria-hidden="true"></div>
    <div class="bb-sp__ugc-stack">
      <div class="bb-sp__ugc-small bb-sp__ugc-skeleton" aria-hidden="true"></div>
      <div class="bb-sp__ugc-small bb-sp__ugc-skeleton" aria-hidden="true"></div>
    </div>
  </div>

  {%- comment -%} ── Review pool — JS picks one at random ── {%- endcomment -%}
  {%- if review_blocks.size > 0 -%}
    <div class="bb-sp__review-pool" id="bb-sp-reviews-{{ section.id }}">
      {%- for block in review_blocks -%}
        {%- assign rating = block.settings.rating | default: 5 -%}
        <div
          class="bb-sp__review{%- unless forloop.first %} bb-sp__review--hidden{%- endunless -%}"
          data-google-url="{{ block.settings.google_url | escape }}"
          role="article"
          aria-label="Customer review by {{ block.settings.author }}"
          {{ block.shopify_attributes }}
        >
          <div class="bb-sp__review-top">
            <div class="bb-sp__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="#49c6be" stroke="#49c6be" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#d0cbc4" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if block.settings.google_url != blank -%}
              <span class="bb-sp__google-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#8a8077" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Google review
              </span>
            {%- endif -%}
          </div>
          <div class="bb-sp__review-text">{{ block.settings.quote }}</div>
          <div class="bb-sp__review-author">
            {%- if block.settings.initials != blank -%}
              <div class="bb-sp__review-avatar" aria-hidden="true">
                {{ block.settings.initials | upcase | truncate: 2, '' }}
              </div>
            {%- endif -%}
            {%- if block.settings.author != blank -%}
              <span class="bb-sp__review-name">{{ block.settings.author }}</span>
            {%- endif -%}
            {%- if block.settings.verified -%}
              <span class="bb-sp__verified">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#3a7d44" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Verified on Google
              </span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Instagram follow CTA ── {%- endcomment -%}
  {%- if section.settings.sp_instagram_handle != blank -%}
    <a
      href="https://instagram.com/{{ section.settings.sp_instagram_handle | remove: '@' }}"
      class="bb-sp__ig-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Follow {{ section.settings.sp_instagram_handle }} on Instagram"
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      Follow {{ section.settings.sp_instagram_handle }}
    </a>
  {%- endif -%}

</div>


<style>
  #bb-sp-{{ section.id }} {
    padding: 20px;
    background: #faf8f4;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #bb-sp-{{ section.id }} .bb-sp__head { display: flex; flex-direction: column; gap: 3px; }
  #bb-sp-{{ section.id }} .bb-sp__title { font-size: 0.625rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: #2a2520; }
  #bb-sp-{{ section.id }} .bb-sp__subtitle { font-size: 0.6875rem; color: #8a8077; }

  /* ── UGC grid — aspect-ratio based so it scales at any width ── */
  #bb-sp-{{ section.id }} .bb-sp__ugc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    aspect-ratio: 2 / 1.4;
    position: relative;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-tall {
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    background: #e8e4dc;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-stack {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-small {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    background: #e8e4dc;
    min-height: 0;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-skeleton {
    background: #ede9e2;
    animation: bb-sp-pulse 1.4s ease-in-out infinite;
  }

  @keyframes bb-sp-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(42,37,32,0.55));
    padding: 20px 8px 7px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-handle {
    font-size: 0.5625rem;
    color: #ffffff;
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #bb-sp-{{ section.id }} .bb-sp__ugc-badge {
    position: absolute;
    top: 7px; right: 7px;
    width: 22px; height: 22px;
    background: rgba(0,0,0,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #bb-sp-{{ section.id }} .bb-sp__unmute {
    position: absolute;
    top: 7px; left: 7px;
    background: rgba(255,255,255,0.88);
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 0.5rem;
    color: #2a2520;
    letter-spacing: 0.04em;
    display: none;
    pointer-events: none;
  }

  /* ── Review pool ── */
  #bb-sp-{{ section.id }} .bb-sp__review-pool { display: flex; flex-direction: column; }
  #bb-sp-{{ section.id }} .bb-sp__review {
    background: #ffffff;
    border: 0.5px solid #e8e4dd;
    border-radius: 8px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  #bb-sp-{{ section.id }} .bb-sp__review:hover { border-color: #49c6be; }
  #bb-sp-{{ section.id }} .bb-sp__review--hidden { display: none; }
  #bb-sp-{{ section.id }} .bb-sp__review-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  #bb-sp-{{ section.id }} .bb-sp__stars { display: flex; gap: 3px; flex-shrink: 0; }
  #bb-sp-{{ section.id }} .bb-sp__google-badge { display: inline-flex; align-items: center; gap: 3px; font-size: 0.5625rem; color: #8a8077; }
  #bb-sp-{{ section.id }} .bb-sp__review-text { font-size: 0.6875rem; color: #3a3530; line-height: 1.65; font-style: italic; }
  #bb-sp-{{ section.id }} .bb-sp__review-author { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
  #bb-sp-{{ section.id }} .bb-sp__review-avatar { width: 22px; height: 22px; border-radius: 50%; background: #f0ece6; display: flex; align-items: center; justify-content: center; font-size: 0.5rem; font-weight: 500; color: #8a8077; flex-shrink: 0; }
  #bb-sp-{{ section.id }} .bb-sp__review-name { font-size: 0.625rem; color: #6a6560; }
  #bb-sp-{{ section.id }} .bb-sp__verified { display: inline-flex; align-items: center; gap: 3px; font-size: 0.5625rem; color: #3a7d44; }

  #bb-sp-{{ section.id }} .bb-sp__ig-link { display: inline-flex; align-items: center; gap: 5px; font-size: 0.6875rem; color: #49c6be; text-decoration: underline; text-underline-offset: 2px; transition: opacity 0.15s; align-self: flex-start; }
  #bb-sp-{{ section.id }} .bb-sp__ig-link:hover { opacity: 0.75; }

  @media (max-width: 767px) {
    #bb-sp-{{ section.id }} { padding: 16px 14px; border-top: 0.5px solid #e8e4dd; }
    #bb-sp-{{ section.id }} .bb-sp__ugc-grid { aspect-ratio: 1.5 / 1; }
  }
</style>


<script>
(function () {
  'use strict';

  var grid = document.getElementById('bb-sp-ugc-{{ section.id }}');
  if (!grid) return;

  var poolItems = Array.from(grid.querySelectorAll('.bb-sp__ugc-pool-item'));

  if (poolItems.length === 0) {
    grid.style.display = 'none';
  } else {

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
      }
      return a;
    }

    var shuffled = shuffle(poolItems).slice(0, 3);

    function igSvg() {
      return '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>';
    }

    function escHtml(str) {
      return (str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function makeOverlay(handle) {
      if (!handle) return null;
      var div = document.createElement('div');
      div.className = 'bb-sp__ugc-overlay';
      div.innerHTML = igSvg() + '<span class="bb-sp__ugc-handle">' + escHtml(handle) + '</span>';
      return div;
    }

    function buildVideo(data) {
      var video         = document.createElement('video');
      video.className   = 'bb-sp__ugc-media';
      video.src         = data.video;
      video.autoplay    = true;
      video.muted       = true;
      video.loop        = true;
      video.playsInline = true;
      video.setAttribute('playsinline', '');
      video.setAttribute('muted', '');

      var badge = document.createElement('div');
      badge.className = 'bb-sp__ugc-badge';
      badge.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="#ffffff" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>';

      var unmute = document.createElement('div');
      unmute.className = 'bb-sp__unmute';
      unmute.textContent = 'Tap to unmute';

      var muted = true;
      var els = [video, badge, unmute];
      var overlay = makeOverlay(data.handle);
      if (overlay) els.push(overlay);

      video.play().catch(function () {});

      return {
        els: els,
        clickHandler: function () {
          muted = !muted;
          video.muted = muted;
          unmute.style.display = muted ? 'none' : 'block';
        }
      };
    }

    function buildImage(data) {
      var img       = document.createElement('img');
      img.className = 'bb-sp__ugc-media';
      img.src       = data.image;
      img.alt       = data.handle ? 'Photo by ' + data.handle : 'Community photo';
      img.loading   = 'lazy';

      var els = [img];
      var overlay = makeOverlay(data.handle);
      if (overlay) els.push(overlay);

      return { els: els, clickHandler: null };
    }

    function populateSlot(slotEl, item) {
      var data = {
        type:   item.dataset.type,
        video:  item.dataset.video,
        image:  item.dataset.image,
        handle: item.dataset.handle
      };

      slotEl.classList.remove('bb-sp__ugc-skeleton');

      var built = data.type === 'video' ? buildVideo(data) : buildImage(data);
      built.els.forEach(function (el) { slotEl.appendChild(el); });
      if (built.clickHandler) slotEl.addEventListener('click', built.clickHandler);
    }

    var tallSlot = grid.querySelector('.bb-sp__ugc-tall');
    var smalls   = grid.querySelectorAll('.bb-sp__ugc-small');

    if (shuffled[0] && tallSlot) populateSlot(tallSlot, shuffled[0]);
    if (shuffled[1] && smalls[0]) populateSlot(smalls[0], shuffled[1]);
    else if (smalls[0])           smalls[0].style.display = 'none';
    if (shuffled[2] && smalls[1]) populateSlot(smalls[1], shuffled[2]);
    else if (smalls[1])           smalls[1].style.display = 'none';
  }

  /* ── Review random rotation ── */
  (function () {
    var pool = document.getElementById('bb-sp-reviews-{{ section.id }}');
    if (!pool) return;

    var reviews = pool.querySelectorAll('.bb-sp__review');
    if (reviews.length === 0) return;

    var randomIdx = Math.floor(Math.random() * reviews.length);
    reviews.forEach(function (r, i) {
      r.classList.toggle('bb-sp__review--hidden', i !== randomIdx);
    });

    reviews.forEach(function (r) {
      var googleUrl = r.dataset.googleUrl || '';
      if (!googleUrl) return;
      r.setAttribute('role', 'link');
      r.setAttribute('tabindex', '0');
      r.addEventListener('click', function () {
        window.open(googleUrl, '_blank', 'noopener,noreferrer');
      });
      r.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          window.open(googleUrl, '_blank', 'noopener,noreferrer');
        }
      });
    });
  })();

})();
</script>


{% schema %}
{
  "name": "Product social proof",
  "tag": "div",
  "class": "bb-product-sp-section",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "sp_section_title",
      "label": "Title",
      "default": "As worn by our community"
    },
    {
      "type": "text",
      "id": "sp_section_subtitle",
      "label": "Subtitle",
      "info": "Leave blank to auto-generate from Instagram handle."
    },
    {
      "type": "text",
      "id": "sp_instagram_handle",
      "label": "Brand Instagram handle",
      "default": "@bikinibooth"
    }
  ],
  "blocks": [
    {
      "type": "ugc_item",
      "name": "UGC item",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Used for image type, or as video thumbnail."
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "Paste the Shopify Files URL of your .mp4 or .mov video. Go to Content → Files, upload your video, then copy its URL."
        },
        {
          "type": "text",
          "id": "instagram_handle",
          "label": "Instagram handle",
          "info": "e.g. @maya_k — shown as overlay on the media item."
        }
      ]
    },
    {
      "type": "review",
      "name": "Google review",
      "settings": [
        {
          "type": "url",
          "id": "google_url",
          "label": "Direct Google review URL"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review quote",
          "default": "The most flattering bikini I've ever owned."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer name",
          "default": "Sofia P."
        },
        {
          "type": "text",
          "id": "initials",
          "label": "Initials (avatar)",
          "default": "SP"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified on Google badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product social proof",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "The most flattering bikini I've ever owned. Wore it every day in Koh Samui — the fit is perfect and the fabric holds up beautifully.",
            "author": "Sofia P. — Bangkok",
            "initials": "SP",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
