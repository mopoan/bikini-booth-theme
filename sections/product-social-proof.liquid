{%- comment -%}
  ============================================================================
  Section: Product Social Proof  —  Bikini Booth
  File:    sections/product-social-proof.liquid
  Wrapper: .shopify-section.bb-product-sp-section  (grid item)
  Inner:   .bb-sp                                  (visual root / styling scope)
  ----------------------------------------------------------------------------
  Full-width social proof block for OS 2.0 product templates.
  Placed by snippets/bb-product-layout.liquid into the "sp" grid area
  (full-width row between the accordions and recommendations).

  Block-based & merchant-editable:
    - "Customer photo" blocks  -> UGC collage (image OR muted video)
    - "Review" blocks          -> featured review card(s)
    - "Trust stat" blocks      -> stat bar

  Notes:
    - All colours/spacing/type are driven by per-instance CSS custom
      properties set inline on the root element, so multiple instances
      never clash and static CSS lives in {% raw %}{% stylesheet %}{% endraw %}.
    - JS is a self-initialising custom element (<bb-social-proof>), safe for
      theme-editor section reloads, and respects prefers-reduced-motion.
    - No external libraries.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings

  # Soft tints derived from the accent so the editor only needs one accent colour
  assign soft_icon = s.accent_color | color_mix: s.background_color, 14
  assign star_empty = s.accent_color | color_mix: s.background_color, 30

  # Detect which block types are present (so empty regions don't render)
  assign has_ugc = false
  assign has_review = false
  assign has_stat = false
  for block in section.blocks
    case block.type
      when 'ugc'
        assign has_ugc = true
      when 'review'
        assign has_review = true
      when 'stat'
        assign has_stat = true
    endcase
  endfor

  assign align = s.heading_alignment
-%}

<style>
  {{ s.heading_font | font_face: font_display: 'swap' }}
  {{ s.heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ s.heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ s.body_font | font_face: font_display: 'swap' }}
</style>

<bb-social-proof
  class="bb-sp bb-sp--align-{{ align }}"
  style="
    --bb-sp-accent: {{ s.accent_color }};
    --bb-sp-bg: {{ s.background_color }};
    --bb-sp-card: {{ s.card_color }};
    --bb-sp-heading: {{ s.heading_color }};
    --bb-sp-text: {{ s.text_color }};
    --bb-sp-muted: {{ s.muted_color }};
    --bb-sp-border: {{ s.border_color }};
    --bb-sp-soft: {{ soft_icon }};
    --bb-sp-star-empty: {{ star_empty }};
    --bb-sp-radius: {{ s.corner_radius }}px;
    --bb-sp-max: {{ s.content_width }}px;
    --bb-sp-pt: {{ s.padding_top }}px;
    --bb-sp-pb: {{ s.padding_bottom }}px;
    --bb-sp-pt-m: {{ s.padding_top | times: 0.62 | round }}px;
    --bb-sp-pb-m: {{ s.padding_bottom | times: 0.62 | round }}px;
    --bb-sp-h-size: {{ s.heading_size }}px;
    --bb-sp-heading-font: {{ s.heading_font.family }}, {{ s.heading_font.fallback_families }};
    --bb-sp-body-font: {{ s.body_font.family }}, {{ s.body_font.fallback_families }};
  "
>
  <div class="bb-sp__inner">

    {%- if s.show_header -%}
      <header class="bb-sp__header">
        {%- if s.eyebrow != blank -%}
          <p class="bb-sp__eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}

        {%- if s.heading != blank -%}
          <h2 class="bb-sp__heading">{{ s.heading }}</h2>
        {%- endif -%}

        {%- if s.show_subtext and s.subtext != blank -%}
          <div class="bb-sp__subtext rte">{{ s.subtext }}</div>
        {%- endif -%}

        {%- if s.show_instagram and s.instagram_url != blank and s.instagram_label != blank -%}
          <a
            class="bb-sp__ig"
            href="{{ s.instagram_url }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="bb-sp__ig-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <rect x="2.6" y="2.6" width="18.8" height="18.8" rx="5.4" fill="none" stroke="currentColor" stroke-width="1.6"/>
              <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="1.6"/>
              <circle cx="17.4" cy="6.6" r="1.15" fill="currentColor"/>
            </svg>
            <span>{{ s.instagram_label }}</span>
          </a>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if has_ugc and s.show_ugc or has_review and s.show_reviews -%}
      <div class="bb-sp__main">

        {%- if has_ugc and s.show_ugc -%}
          <div class="bb-sp__media">
            <div class="bb-sp-ugc bb-sp-ugc--{{ s.media_layout }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'ugc' -%}
                  {%- liquid
                    assign b = block.settings
                    assign is_link = false
                    if b.link != blank
                      assign is_link = true
                    endif
                    assign tile_tag = 'div'
                    if is_link
                      assign tile_tag = 'a'
                    endif
                    assign tile_alt = b.alt | default: b.handle | default: 'Bikini Booth customer photo'
                  -%}
                  <{{ tile_tag }}
                    class="bb-sp-ugc__item bb-sp-ugc__item--{{ b.size }}"
                    {% if is_link %}href="{{ b.link }}" target="_blank" rel="noopener noreferrer" aria-label="{% if b.handle != blank %}View {{ b.handle }} on Instagram{% else %}View customer photo{% endif %}"{% endif %}
                    {{ block.shopify_attributes }}
                  >
                    {%- if b.video != blank -%}
                      <video
                        class="bb-sp-ugc__media"
                        muted
                        loop
                        playsinline
                        preload="metadata"
                        {% if b.image != blank %}poster="{{ b.image | image_url: width: 900 }}"{% endif %}
                        {% if b.handle != blank %}aria-label="{{ b.handle }} video"{% else %}aria-label="Customer video"{% endif %}
                      >
                        {%- for source in b.video.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- elsif b.image != blank -%}
                      {{
                        b.image
                        | image_url: width: 1100
                        | image_tag:
                          class: 'bb-sp-ugc__media',
                          loading: 'lazy',
                          widths: '275, 400, 550, 825, 1100',
                          sizes: '(max-width: 749px) 50vw, 22vw',
                          alt: tile_alt
                      }}
                    {%- else -%}
                      <div class="bb-sp-ugc__media bb-sp-ugc__media--ph">
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'bb-sp-ph' }}
                      </div>
                    {%- endif -%}

                    {%- if b.handle != blank -%}
                      <span class="bb-sp-ugc__handle">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="14" height="14">
                          <rect x="2.6" y="2.6" width="18.8" height="18.8" rx="5.4" fill="none" stroke="currentColor" stroke-width="1.8"/>
                          <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="1.8"/>
                          <circle cx="17.4" cy="6.6" r="1.15" fill="currentColor"/>
                        </svg>
                        {{ b.handle }}
                      </span>
                    {%- endif -%}
                  </{{ tile_tag }}>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if s.show_badge and s.badge_line_1 != blank -%}
              <div class="bb-sp-badge" aria-hidden="true">
                <svg class="bb-sp-badge__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 21c-.5-4 .2-7 .8-9.4"/>
                  <path d="M12.8 11.6c-1.6-1.4-4-1.6-6 .2"/>
                  <path d="M12.8 11.6c1.8-1.2 4.2-1 5.8 1"/>
                  <path d="M12.8 11.6c-.8-2 0-4.4 2.4-5.6"/>
                  <path d="M12.8 11.6c-1-1.8-3.2-2.8-5.8-2.2"/>
                </svg>
                <span class="bb-sp-badge__text">
                  <span>{{ s.badge_line_1 }}</span>
                  {%- if s.badge_line_2 != blank -%}<span>{{ s.badge_line_2 }}</span>{%- endif -%}
                </span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if has_review and s.show_reviews -%}
          <div class="bb-sp__reviews">
            {%- for block in section.blocks -%}
              {%- if block.type == 'review' -%}
                {%- liquid
                  assign r = block.settings
                  assign rating = r.rating | default: 5
                  assign pct = rating | times: 20
                  assign has_src_link = false
                  if r.source_link != blank
                    assign has_src_link = true
                  endif
                -%}
                <article class="bb-sp-review" {{ block.shopify_attributes }}>
                  <div class="bb-sp-review__top">
                    <div class="bb-sp-stars" role="img" aria-label="Rated {{ rating }} out of 5 stars">
                      <span class="bb-sp-stars__row bb-sp-stars__row--empty" aria-hidden="true">★★★★★</span>
                      <span class="bb-sp-stars__row bb-sp-stars__row--full" style="width: {{ pct }}%;" aria-hidden="true">★★★★★</span>
                    </div>

                    {%- if r.source_image != blank -%}
                      {%- capture source_img -%}<img class="bb-sp-review__source-img" src="{{ r.source_image | image_url: width: 260 }}" alt="{{ r.source_label | default: 'Verified reviews' }}" loading="lazy" height="34">{%- endcapture -%}
                      {%- if has_src_link -%}
                        <a class="bb-sp-review__source-link" href="{{ r.source_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ r.source_label | default: 'Verified reviews' }} — view on Google">{{ source_img }}</a>
                      {%- else -%}
                        {{ source_img }}
                      {%- endif -%}
                    {%- elsif r.source_label != blank -%}
                      {%- capture source_inner -%}<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="16" height="16" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-1.2 14.3l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4z"/></svg>{{ r.source_label }}{%- endcapture -%}
                      {%- if has_src_link -%}
                        <a class="bb-sp-review__source bb-sp-review__source--link" href="{{ r.source_link }}" target="_blank" rel="noopener noreferrer">{{ source_inner }}</a>
                      {%- else -%}
                        <span class="bb-sp-review__source">{{ source_inner }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </div>

                  {%- if r.quote != blank -%}
                    <blockquote class="bb-sp-review__quote">
                      <span class="bb-sp-review__mark" aria-hidden="true">&ldquo;</span>
                      <div class="bb-sp-review__text rte">{{ r.quote }}</div>
                    </blockquote>
                  {%- endif -%}

                  <div class="bb-sp-review__divider" aria-hidden="true"></div>

                  <footer class="bb-sp-review__author">
                    {%- if r.author_avatar != blank -%}
                      <img
                        class="bb-sp-review__avatar"
                        src="{{ r.author_avatar | image_url: width: 120 }}"
                        alt="{{ r.author_name | default: 'Reviewer' }}"
                        loading="lazy"
                        width="48"
                        height="48"
                      >
                    {%- endif -%}

                    <div class="bb-sp-review__meta">
                      {%- if r.author_name != blank -%}
                        <p class="bb-sp-review__name">{{ r.author_name }}</p>
                      {%- endif -%}
                      {%- if r.author_location != blank -%}
                        <p class="bb-sp-review__loc">{{ r.author_location }}</p>
                      {%- endif -%}
                      {%- if r.verified and r.verified_label != blank -%}
                        {%- capture verified_inner -%}<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="14" height="14" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-1.2 14.3l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4z"/></svg>{{ r.verified_label }}{%- endcapture -%}
                        {%- if has_src_link -%}
                          <a class="bb-sp-review__verified bb-sp-review__verified--link" href="{{ r.source_link }}" target="_blank" rel="noopener noreferrer">{{ verified_inner }}</a>
                        {%- else -%}
                          <p class="bb-sp-review__verified">{{ verified_inner }}</p>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  </footer>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- if has_stat and s.show_stats -%}
      <div class="bb-sp-stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            {%- assign st = block.settings -%}
            <div class="bb-sp-stat" {{ block.shopify_attributes }}>
              <span class="bb-sp-stat__icon" aria-hidden="true">
                {%- if st.custom_icon != blank -%}
                  <img src="{{ st.custom_icon | image_url: width: 96 }}" alt="" width="28" height="28" loading="lazy">
                {%- else -%}
                  {%- case st.icon -%}
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M12 20s-7-4.4-7-9.3A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7 3.7C19 15.6 12 20 12 20z"/></svg>
                    {%- when 'palm' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c-.5-4 .2-7 .8-9.4"/><path d="M12.8 11.6c-1.6-1.4-4-1.6-6 .2"/><path d="M12.8 11.6c1.8-1.2 4.2-1 5.8 1"/><path d="M12.8 11.6c-.8-2 0-4.4 2.4-5.6"/><path d="M12.8 11.6c-1-1.8-3.2-2.8-5.8-2.2"/></svg>
                    {%- when 'globe' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17M12 3.5c2.4 2.3 3.7 5.3 3.7 8.5S14.4 18.2 12 20.5c-2.4-2.3-3.7-5.3-3.7-8.5S9.6 5.8 12 3.5z"/></svg>
                    {%- when 'sparkle' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7z"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M12 3l2.7 5.5 6 .9-4.35 4.2 1 6L12 16.9 6.65 19.6l1-6L3.3 9.4l6-.9z"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
              <div class="bb-sp-stat__body">
                {%- if st.value != blank -%}<p class="bb-sp-stat__value">{{ st.value }}</p>{%- endif -%}
                {%- if st.label != blank -%}<p class="bb-sp-stat__label">{{ st.label }}</p>{%- endif -%}
                {%- if st.caption != blank -%}<p class="bb-sp-stat__caption">{{ st.caption }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if s.show_footer_tag and s.footer_tag != blank -%}
      <p class="bb-sp__footer">{{ s.footer_tag }}</p>
    {%- endif -%}

  </div>
</bb-social-proof>

{% stylesheet %}
.bb-sp {
  display: block;
  background: var(--bb-sp-bg);
  color: var(--bb-sp-text);
  font-family: var(--bb-sp-body-font);
  padding: var(--bb-sp-pt-m) 18px var(--bb-sp-pb-m);
  -webkit-font-smoothing: antialiased;
}
.bb-sp *,
.bb-sp *::before,
.bb-sp *::after {
  box-sizing: border-box;
}
.bb-sp .bb-sp__inner {
  max-width: var(--bb-sp-max);
  margin: 0 auto;
}
.bb-sp a:focus-visible,
.bb-sp bb-social-proof:focus-visible {
  outline: 2px solid var(--bb-sp-accent);
  outline-offset: 3px;
  border-radius: 3px;
}

/* ---------- Header ---------- */
.bb-sp .bb-sp__header {
  text-align: center;
}
.bb-sp.bb-sp--align-left .bb-sp__header {
  text-align: left;
}
.bb-sp .bb-sp__eyebrow {
  margin: 0 0 14px;
  color: var(--bb-sp-accent);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.bb-sp .bb-sp__heading {
  margin: 0;
  font-family: var(--bb-sp-heading-font);
  color: var(--bb-sp-heading);
  font-weight: 500;
  font-size: clamp(1.85rem, 6vw, var(--bb-sp-h-size));
  line-height: 1.08;
  letter-spacing: -0.01em;
}
.bb-sp .bb-sp__heading em { font-style: italic; }
.bb-sp .bb-sp__heading strong { font-weight: 700; }
.bb-sp .bb-sp__subtext {
  margin: 16px auto 0;
  max-width: 48ch;
  color: var(--bb-sp-muted);
  font-size: 1rem;
  line-height: 1.6;
}
.bb-sp.bb-sp--align-left .bb-sp__subtext { margin-inline: 0; }
.bb-sp .bb-sp__subtext p { margin: 0; }
.bb-sp .bb-sp__ig {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  margin-top: 22px;
  padding-bottom: 4px;
  color: var(--bb-sp-accent);
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  text-decoration: none;
  border-bottom: 2px solid var(--bb-sp-accent);
  transition: opacity 0.2s ease;
}
.bb-sp .bb-sp__ig:hover { opacity: 0.72; }
.bb-sp .bb-sp__ig-icon { width: 20px; height: 20px; }

/* ---------- Main grid ---------- */
.bb-sp .bb-sp__main {
  margin-top: 30px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}
.bb-sp .bb-sp__media { position: relative; }

/* ---------- UGC collage ---------- */
.bb-sp .bb-sp-ugc {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.bb-sp .bb-sp-ugc__item {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: calc(var(--bb-sp-radius) * 0.7);
  background: var(--bb-sp-border);
  aspect-ratio: 4 / 5;
  text-decoration: none;
}
/* Mobile/tablet collage: large, wide and tall span the full width;
   standard photos sit two-up. Desktop (>=990px) uses the full collage. */
.bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item--large,
.bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item--wide,
.bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item--tall {
  grid-column: span 2;
  aspect-ratio: 16 / 11;
}
.bb-sp .bb-sp-ugc__media {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.bb-sp .bb-sp-ugc__item:hover .bb-sp-ugc__media { transform: scale(1.04); }
.bb-sp .bb-sp-ugc__media--ph { display: grid; place-items: center; }
.bb-sp .bb-sp-ugc__media--ph svg { width: 100%; height: 100%; object-fit: cover; opacity: 0.4; }
.bb-sp .bb-sp-ugc__handle {
  position: absolute;
  left: 10px;
  bottom: 10px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  max-width: calc(100% - 20px);
  padding: 5px 11px;
  border-radius: 999px;
  background: rgba(20, 18, 16, 0.42);
  color: #fff;
  font-size: 0.74rem;
  font-weight: 500;
  line-height: 1;
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}
.bb-sp .bb-sp-ugc__handle svg { flex: 0 0 auto; }

/* ---------- Badge ---------- */
.bb-sp .bb-sp-badge {
  position: absolute;
  top: -10px;
  right: 6px;
  width: 78px;
  height: 78px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  border-radius: 50%;
  background: var(--bb-sp-bg);
  border: 1px dashed var(--bb-sp-accent);
  color: var(--bb-sp-accent);
  text-align: center;
  box-shadow: 0 6px 18px rgba(42, 37, 32, 0.08);
}
.bb-sp .bb-sp-badge__icon { width: 22px; height: 22px; }
.bb-sp .bb-sp-badge__text {
  display: flex;
  flex-direction: column;
  font-size: 0.5rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1.25;
}

/* ---------- Reviews ---------- */
.bb-sp .bb-sp__reviews {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.bb-sp .bb-sp-review {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 26px;
  background: var(--bb-sp-card);
  border: 1px solid var(--bb-sp-border);
  border-radius: var(--bb-sp-radius);
  box-shadow: 0 10px 30px rgba(42, 37, 32, 0.05);
}
.bb-sp .bb-sp-review__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.bb-sp .bb-sp-stars {
  position: relative;
  display: inline-block;
  font-size: 1.2rem;
  letter-spacing: 3px;
  line-height: 1;
}
.bb-sp .bb-sp-stars__row { display: block; }
.bb-sp .bb-sp-stars__row--empty { color: var(--bb-sp-star-empty); }
.bb-sp .bb-sp-stars__row--full {
  position: absolute;
  inset: 0;
  color: var(--bb-sp-accent);
  overflow: hidden;
  white-space: nowrap;
}
.bb-sp .bb-sp-review__source {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--bb-sp-muted);
  font-size: 0.8rem;
  font-weight: 500;
}
.bb-sp .bb-sp-review__source--link { text-decoration: none; }
.bb-sp .bb-sp-review__source--link:hover { text-decoration: underline; }
.bb-sp .bb-sp-review__source-link { display: inline-flex; }
.bb-sp .bb-sp-review__source svg { color: var(--bb-sp-accent); }
.bb-sp .bb-sp-review__source-img { max-height: 34px; width: auto; display: block; }
.bb-sp .bb-sp-review__quote { margin: 14px 0 0; position: relative; }
.bb-sp .bb-sp-review__mark {
  display: block;
  font-family: var(--bb-sp-heading-font);
  font-size: 3rem;
  line-height: 0.5;
  color: var(--bb-sp-accent);
}
.bb-sp .bb-sp-review__text {
  margin-top: 10px;
  font-family: var(--bb-sp-heading-font);
  font-style: italic;
  font-size: 1.06rem;
  line-height: 1.6;
  color: var(--bb-sp-text);
}
.bb-sp .bb-sp-review__text p { margin: 0 0 0.5em; }
.bb-sp .bb-sp-review__text p:last-child { margin-bottom: 0; }
.bb-sp .bb-sp-review__divider {
  height: 1px;
  background: var(--bb-sp-border);
  margin: 22px 0 16px;
}
.bb-sp .bb-sp-review__author {
  display: flex;
  align-items: center;
  gap: 13px;
  margin-top: auto;
}
.bb-sp .bb-sp-review__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
  flex: 0 0 auto;
}
.bb-sp .bb-sp-review__name {
  margin: 0;
  font-weight: 700;
  color: var(--bb-sp-heading);
}
.bb-sp .bb-sp-review__loc {
  margin: 2px 0 0;
  color: var(--bb-sp-muted);
  font-size: 0.85rem;
}
.bb-sp .bb-sp-review__verified {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin: 5px 0 0;
  color: var(--bb-sp-accent);
  font-size: 0.8rem;
  font-weight: 600;
}
.bb-sp a.bb-sp-review__verified { text-decoration: none; }
.bb-sp a.bb-sp-review__verified:hover { text-decoration: underline; }

/* ---------- Stats ---------- */
.bb-sp .bb-sp-stats {
  margin-top: 24px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  background: var(--bb-sp-card);
  border: 1px solid var(--bb-sp-border);
  border-radius: var(--bb-sp-radius);
  padding: 6px;
  box-shadow: 0 10px 30px rgba(42, 37, 32, 0.04);
}
.bb-sp .bb-sp-stat {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 18px 16px;
}
.bb-sp .bb-sp-stat__icon {
  flex: 0 0 auto;
  width: 50px;
  height: 50px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: var(--bb-sp-soft);
  color: var(--bb-sp-accent);
}
.bb-sp .bb-sp-stat__icon svg { width: 24px; height: 24px; }
.bb-sp .bb-sp-stat__icon img { width: 28px; height: 28px; object-fit: contain; }
.bb-sp .bb-sp-stat__value {
  margin: 0;
  color: var(--bb-sp-accent);
  font-family: var(--bb-sp-heading-font);
  font-size: 1.7rem;
  font-weight: 700;
  line-height: 1;
}
.bb-sp .bb-sp-stat__label {
  margin: 6px 0 2px;
  color: var(--bb-sp-heading);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.bb-sp .bb-sp-stat__caption {
  margin: 0;
  color: var(--bb-sp-muted);
  font-size: 0.8rem;
  line-height: 1.4;
}

/* ---------- Footer ---------- */
.bb-sp .bb-sp__footer {
  margin: 26px 0 0;
  text-align: center;
  color: var(--bb-sp-muted);
  font-size: 0.85rem;
}

/* ============ Tablet ============ */
@media (min-width: 750px) {
  .bb-sp .bb-sp-stats { grid-template-columns: repeat(4, 1fr); }
  .bb-sp .bb-sp-stat:not(:first-child) {
    border-left: 1px solid var(--bb-sp-border);
  }
}

/* ============ Desktop ============ */
@media (min-width: 990px) {
  .bb-sp {
    padding: var(--bb-sp-pt) 32px var(--bb-sp-pb);
  }
  .bb-sp .bb-sp__main {
    margin-top: 36px;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    gap: 28px;
    align-items: stretch;
  }

  /* Collage layout — composed for the approved 4-photo arrangement.
     Extra photos (5th+) flow below as standard tiles. */
  .bb-sp .bb-sp-ugc--collage {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
    grid-auto-rows: 1fr;
    aspect-ratio: 102 / 60;
    gap: 14px;
  }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item {
    aspect-ratio: auto;
    height: 100%;
  }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item:nth-child(1) { grid-column: 1 / span 2; grid-row: 1 / span 2; }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item:nth-child(2) { grid-column: 3; grid-row: 1; }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item:nth-child(3) { grid-column: 3; grid-row: 2; }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item:nth-child(4) { grid-column: 4; grid-row: 1 / span 2; }
  .bb-sp .bb-sp-ugc--collage .bb-sp-ugc__item:nth-child(n+5) { grid-column: span 1; grid-row: span 1; }

  /* Even grid layout — robust for any number of photos */
  .bb-sp .bb-sp-ugc--grid { grid-template-columns: repeat(3, 1fr); }

  .bb-sp .bb-sp-badge {
    width: 92px;
    height: 92px;
    top: 8px;
    right: -10px;
  }
  .bb-sp .bb-sp-badge__text { font-size: 0.54rem; }

  .bb-sp .bb-sp-review { padding: 30px; }
  .bb-sp .bb-sp-review__text { font-size: 1.1rem; }
}

/* ============ Reduced motion ============ */
@media (prefers-reduced-motion: reduce) {
  .bb-sp *,
  .bb-sp *::before,
  .bb-sp *::after {
    transition: none !important;
    animation: none !important;
  }
  .bb-sp .bb-sp-ugc__item:hover .bb-sp-ugc__media { transform: none; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  if (customElements.get('bb-social-proof')) return;

  customElements.define(
    'bb-social-proof',
    class BBSocialProof extends HTMLElement {
      connectedCallback() {
        this.videos = Array.from(this.querySelectorAll('video'));
        if (!this.videos.length) return;

        // Enforce muted-by-default at the property level (some browsers
        // ignore the attribute alone) and disable picture-in-picture chrome.
        this.videos.forEach(function (v) {
          v.muted = true;
          v.defaultMuted = true;
          v.setAttribute('muted', '');
          v.playsInline = true;
          v.disablePictureInPicture = true;
        });

        // Respect reduced-motion: leave videos paused on the poster frame.
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
        if (reduce.matches || typeof IntersectionObserver === 'undefined') return;

        var self = this;
        this.io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              var video = entry.target;
              if (entry.isIntersecting) {
                var p = video.play();
                if (p && typeof p.catch === 'function') p.catch(function () {});
              } else {
                video.pause();
              }
            });
          },
          { threshold: 0.25 }
        );
        this.videos.forEach(function (v) {
          self.io.observe(v);
        });
      }

      disconnectedCallback() {
        if (this.io) {
          this.io.disconnect();
          this.io = null;
        }
      }
    }
  );
})();
{% endjavascript %}

