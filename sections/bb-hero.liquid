{% comment %}
  Bikini Booth owned hero — fork-first; edit markup freely.
{% endcomment %}
{{ 'bb-page-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign align_items = 'center'
  assign justify_content = 'center'
  assign text_align = 'center'
  if section.settings.content_horizontal == 'left'
    assign justify_content = 'flex-start'
    assign text_align = 'left'
  elsif section.settings.content_horizontal == 'right'
    assign justify_content = 'flex-end'
    assign text_align = 'right'
  endif
  if section.settings.content_vertical == 'top'
    assign align_items = 'flex-start'
  elsif section.settings.content_vertical == 'bottom'
    assign align_items = 'flex-end'
  endif
  assign overlay_op = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section id="bb-hero-{{ section.id }}" class="bb-hero" data-bb-hero {{ section.shopify_attributes }}
  style="--bb-hero-align: {{ align_items }}; --bb-hero-justify: {{ justify_content }}; --bb-hero-text-align: {{ text_align }}; --bb-hero-min-h: {{ section.settings.desktop_min_height }}px; --bb-hero-min-h-mobile: {{ section.settings.mobile_min_height }}px; --bb-hero-overlay: {{ overlay_op }}; --bb-hero-eyebrow-size: {{ section.settings.eyebrow_font_size }}px; --bb-hero-heading-size: {{ section.settings.heading_font_size }}px; --bb-hero-heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px; --bb-hero-sub-size: {{ section.settings.subheading_font_size }}px;{% if section.settings.eyebrow_color != blank %} --bb-hero-eyebrow-color: {{ section.settings.eyebrow_color }};{% endif %}{% if section.settings.heading_color != blank %} --bb-hero-heading-color: {{ section.settings.heading_color }};{% endif %}{% if section.settings.subheading_color != blank %} --bb-hero-sub-color: {{ section.settings.subheading_color }};{% endif %}{% if section.settings.button_bg != blank %} --bb-hero-btn-bg: {{ section.settings.button_bg }};{% endif %}{% if section.settings.button_text_color != blank %} --bb-hero-btn-text: {{ section.settings.button_text_color }};{% endif %}{% if section.settings.button_bg_hover != blank %} --bb-hero-btn-bg-hover: {{ section.settings.button_bg_hover }};{% endif %}{% if section.settings.button_text_hover != blank %} --bb-hero-btn-text-hover: {{ section.settings.button_text_hover }};{% endif %}">
  {% if section.settings.image != blank or section.settings.image_mobile != blank %}
    <div class="bb-hero__media" aria-hidden="true">
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          >
        {%- endif -%}
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 2400 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
            fetchpriority="high"
            sizes="100vw"
            srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1800 }} 1800w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
          >
        {%- else -%}
          <img
            src="{{ section.settings.image_mobile | image_url: width: 1200 }}"
            alt="{{ section.settings.image_mobile.alt | escape }}"
            width="{{ section.settings.image_mobile.width }}"
            height="{{ section.settings.image_mobile.height }}"
            loading="eager"
            fetchpriority="high"
            sizes="100vw"
          >
        {%- endif -%}
      </picture>
    </div>
  {% elsif section.settings.fallback_asset != blank %}
    <div class="bb-hero__media" aria-hidden="true">
      <img src="{{ section.settings.fallback_asset | asset_url }}" alt="" width="1920" height="1080" loading="eager" fetchpriority="high">
    </div>
  {% endif %}
  <div class="bb-hero__overlay"></div>
  <div class="bb-hero__inner page-fullwidth">
    <div class="bb-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="bb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="bb-hero__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="bb-hero__sub rte">{{ section.settings.subheading }}</div>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a class="bb-hero__cta" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BB Hero",
  "tag": "section",
  "class": "bb-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image — desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image — mobile",
      "info": "Optional. Shown below 750px width; falls back to desktop image if empty."
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "Theme asset filename (fallback if no image)",
      "info": "Theme asset filename (e.g. bb-hero-main.jpg) — used only when Hero image is empty.",
      "default": "bb-hero-main.jpg"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (small line above headline)",
      "info": "Optional. Uppercase micro-label, e.g. NEW SEASON"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "content_horizontal",
      "label": "Align content (horizontal)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_vertical",
      "label": "Align content (vertical)",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay darkness",
      "default": 0
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow font size",
      "default": 10
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading font size (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 20,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading font size (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Subheading font size",
      "default": 15
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "desktop_min_height",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Minimum height (desktop)",
      "default": 900
    },
    {
      "type": "range",
      "id": "mobile_min_height",
      "min": 300,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Minimum height (mobile)",
      "default": 800
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text"
    },
    {
      "type": "color",
      "id": "button_bg_hover",
      "label": "Button background (hover)"
    },
    {
      "type": "color",
      "id": "button_text_hover",
      "label": "Button text (hover)"
    }
  ],
  "presets": [
    {
      "name": "BB Hero"
    }
  ]
}
{% endschema %}
