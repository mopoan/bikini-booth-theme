{%- comment -%}
  Bikini Booth — Order Summary card (Stage 3).
  Restyles the cart footer into the cream summary card from the mockup while
  preserving every checkout contract cart.js / Shopify depend on:
    #main-cart-footer[data-id], .js-contents, cart-discount, subtotal
    (cart.total_price | money_with_currency), #checkout (form="cart", name="checkout"),
    content_for_additional_checkout_buttons, terms checkbox, app blocks, #cart-errors.
  The cart note is intentionally NOT rendered here — it lives in the
  bb-cart-note-accordion (left column) to avoid a duplicate #Cart-note.
{%- endcomment -%}

<div id="main-cart-footer"
     class="bb-cart{% if cart == empty %} is-empty{% endif %}"
     data-id="{{ section.id }}"
     data-section-name="main-cart-footer">

  <aside class="bb-summary">
    <span class="bb-summary__star" aria-hidden="true">{% render 'bb-icon', icon: 'starfish', size: 104 %}</span>

    <h2 class="bb-summary__title">Order Summary</h2>
    <span class="bb-summary__wave" aria-hidden="true">{% render 'bb-icon', icon: 'wave', size: 46 %}</span>

    <div class="bb-summary__content cart__footer__content js-contents">
      {%- if settings.show_add_discount_code -%}
        <div class="bb-summary__discount discount-container">
          <h6 class="bb-summary__discount-label">{{ "general.cart.heading_discount" | t }}</h6>
          {%- render "cart-discount", section_id: section.id -%}
        </div>
      {%- endif -%}

      <div class="bb-summary__row totals">
        <span class="bb-summary__row-label totals__subtotal">{{ 'sections.cart.subtotal' | t | default: 'Subtotal' }}</span>
        <span class="bb-summary__row-val totals__subtotal-value">{{ cart.total_price | money_with_currency }}</span>
      </div>

      {%- if settings.show_installments -%}
        <span class="bb-summary__installments cart__installments display-block">{% form 'cart', cart %}{{ form | payment_terms }}{% endform %}</span>
      {%- endif -%}

      {%- if cart.cart_level_discount_applications.size > 0 -%}
        <ul class="bb-summary__discounts discounts unstyle-ul" role="list" aria-label="{{ 'customer.order.discount' | t }}">
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="discounts__discount">
              {{- 'icon-discount' | append: settings.system_icon_thickness | inline_asset_content -}}
              <span>{{ discount.title }} (-{{ discount.total_allocated_amount | money }})</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- capture _taxnote -%}
        {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
          {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
        {%- elsif cart.taxes_included -%}
          {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
        {%- elsif shop.shipping_policy.body != blank -%}
          {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
        {%- else -%}
          {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
        {%- endif -%}
      {%- endcapture -%}
      {%- if _taxnote != blank -%}
        <p class="bb-summary__tax">{{ _taxnote }}</p>
      {%- endif -%}
    </div>

    {%- if settings.terms_and_condition_checkbox -%}
      <terms_and_condition-checkbox class="bb-summary__terms display-block">
        <label for="product-terms_and_condition_checkbox-{{ section.id }}" class="checkbox-input body2">
          <input id="product-terms_and_condition_checkbox-{{ section.id }}" type="checkbox">
          <div class="checkbox-input__checkmark">
            <div class="checkbox-input__flip">
              <div class="checkbox-input__front"></div>
              <div class="checkbox-input__back">
                {{- 'icon-checkmark' | append: settings.system_icon_thickness | inline_asset_content -}}
              </div>
            </div>
          </div>
          <span>{{ 'general.accept_terms_checkbox_html' | t }}</span>
        </label>
      </terms_and_condition-checkbox>
    {%- endif -%}

    {%- if settings.show_checkout_button -%}
      <button type="submit" id="checkout" name="checkout" form="cart" class="bb-summary__checkout">
        {% render 'bb-icon', icon: 'lock', size: 16 %}
        <span>{{ 'sections.cart.checkout' | t | default: 'Secure Checkout' }}</span>
      </button>
    {%- endif -%}

    {%- if additional_checkout_buttons and settings.show_accelerated_checkout_buttons -%}
      <div class="bb-summary__express"><span>Express checkout</span></div>
      <div class="bb-summary__dynamic cart__dynamic-checkout-buttons additional-checkout-buttons additional-checkout-buttons--vertical">{{ content_for_additional_checkout_buttons }}</div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}{% render block %}
      {%- endcase -%}
    {%- endfor -%}

    <div id="cart-errors"></div>

    <div class="bb-summary__trust">
      <div class="bb-summary__trust-item">{% render 'bb-icon', icon: 'shield', size: 22 %}<span>Secure<br>checkout</span></div>
      <div class="bb-summary__trust-item">{% render 'bb-icon', icon: 'returns', size: 22 %}<span>Easy<br>returns</span></div>
      <div class="bb-summary__trust-item">{% render 'bb-icon', icon: 'store', size: 22 %}<span>Store pickup<br>available</span></div>
    </div>
  </aside>
</div>

{% schema %}
{
  "name": "Subtotal",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Heading" },
    {
      "type": "select",
      "id": "heading_aligment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" }
      ],
      "default": "text-center",
      "label": "Heading alignment"
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "top_spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "normal", "label": "Normal" }
      ],
      "default": "normal",
      "label": "Top spacing"
    },
    {
      "type": "select",
      "id": "width",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "page-width", "label": "Boxed" },
        { "value": "page-wide", "label": "Wide" }
      ],
      "default": "default",
      "label": "Width",
      "info": "The Wide option works for screens with 1440px width and more."
    },
    { "type": "header", "content": "Dividing line" },
    { "type": "checkbox", "id": "show_lines", "default": false, "label": "Show" }
  ]
}
{% endschema %}
