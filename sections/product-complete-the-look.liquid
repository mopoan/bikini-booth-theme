{%- comment -%}
  Section: product-complete-the-look.liquid
  Purpose: "Complete the look" bundle — pulls products automatically.

  Item 1: Current product (from product object, pre-checked)
  Item 2: Matching piece Top↔Bottom (from auto-connect via JS)
  Item 3: Set pair product (from metafield custom.set_pair_product)

  No manual block assignment needed — all automatic per product.
{%- endcomment -%}

{%- assign pair_product = product.metafields.custom.set_pair_product.value -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- capture bb_has_paired_piece -%}{%- render 'bb-paired-piece', product: product, ctl_flag_only: true -%}{%- endcapture -%}
{%- assign bb_has_paired_piece = bb_has_paired_piece | strip -%}

{%- assign ctl_img_w  = section.settings.image_width | default: 60 -%}
{%- assign ctl_img_h  = ctl_img_w | times: 16 | divided_by: 9 -%}
{%- assign ctl_img_w2 = ctl_img_w | times: 2 -%}
{%- assign ctl_img_h2 = ctl_img_h | times: 2 -%}

<div class="bb-ctl" id="bb-ctl-{{ section.id }}"{% if pair_product == blank and bb_has_paired_piece != 'true' %} hidden{% endif %}>

  <div class="bb-ctl__head">
    <p class="bb-ctl__title">{{ section.settings.heading | default: 'Complete the look' }}</p>
    <p class="bb-ctl__sub">{{ section.settings.subheading | default: 'Style the full set' }}</p>
  </div>

  {%- comment -%} ── Desktop checklist ── {%- endcomment -%}
  <div class="bb-ctl__list" aria-label="Complete the look — select items">

    {%- comment -%} Item 1: Current product {%- endcomment -%}
    <div
      class="bb-ctl__item is-current is-checked"
      data-product-id="{{ product.id }}"
      data-variant-id="{{ current_variant.id }}"
      data-price="{{ current_variant.price }}"
      data-price-unit="presentment"
      data-slot="current"
    >
      <div class="bb-ctl__check" aria-hidden="true">
        <div class="bb-ctl__chk-on">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
      </div>
      <div class="bb-ctl__img">
        {%- if product.featured_image != blank -%}
          <img
            src="{{ product.featured_image | image_url: width: ctl_img_w2, height: ctl_img_h2, crop: 'center' }}"
            alt="{{ product.title | escape }}"
            width="{{ ctl_img_w }}" height="{{ ctl_img_h }}" loading="lazy"
          >
        {%- endif -%}
      </div>
      <div class="bb-ctl__info">
        <span class="bb-ctl__name">{{ product.title | split: ' in ' | first }}</span>
        <p class="bb-ctl__piece bb-ctl__piece--current">{{ section.settings.this_item_label | default: 'This item' }}</p>
        <p class="bb-ctl__price">{{ current_variant.price | money | strip_html }}</p>
      </div>
      <div class="bb-ctl__right">
        <div class="bb-ctl__size-wrap">
          {%- if product.variants.size > 1 -%}
            <select class="bb-ctl__size-select" aria-label="Size" data-item-id="{{ product.id }}">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  data-price="{{ variant.price }}"
                  data-price-unit="presentment"
                  data-price-formatted="{{ variant.price | money | strip_html | escape }}"
                  {%- if variant == current_variant %} selected{%- endif -%}
                  {%- unless variant.available %} disabled{%- endunless -%}
                >{{ variant.title }}{%- unless variant.available %} — Sold out{%- endunless -%}</option>
              {%- endfor -%}
            </select>
            <svg class="bb-ctl__size-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8a8077" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          {%- else -%}
            <span class="bb-ctl__size-only">One-Size</span>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- comment -%} Divider {%- endcomment -%}
    <div class="bb-ctl__divider" aria-hidden="true">
      <div class="bb-ctl__divider-line"></div>
      <span class="bb-ctl__divider-text">{{ section.settings.divider_text | default: 'Add to complete the set' }}</span>
      <div class="bb-ctl__divider-line"></div>
    </div>

    {%- comment -%} Item 2: Matching piece — rendered inside snippet (scoped Liquid prices) {%- endcomment -%}
    {%- render 'bb-paired-piece',
      product: product,
      render_ctl_piece: true,
      section: section,
      ctl_img_w: ctl_img_w,
      ctl_img_h: ctl_img_h,
      ctl_img_w2: ctl_img_w2,
      ctl_img_h2: ctl_img_h2
    -%}

    {%- comment -%} Item 3: Set pair from metafield {%- endcomment -%}
    {%- if pair_product != blank -%}
      {%- assign pair_variant = pair_product.selected_or_first_available_variant -%}
      <div
        class="bb-ctl__item"
        data-product-id="{{ pair_product.id }}"
        data-variant-id="{{ pair_variant.id }}"
        data-price="{{ pair_variant.price }}"
        data-price-unit="presentment"
        data-slot="pair"
      >
        <div class="bb-ctl__check" aria-hidden="true">
          <div class="bb-ctl__chk-off"></div>
        </div>
        <div class="bb-ctl__img">
          {%- if pair_product.featured_image != blank -%}
            <img
              src="{{ pair_product.featured_image | image_url: width: ctl_img_w2, height: ctl_img_h2, crop: 'center' }}"
              alt="{{ pair_product.title | escape }}"
              width="{{ ctl_img_w }}" height="{{ ctl_img_h }}" loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="bb-ctl__info">
          <a class="bb-ctl__name" href="{{ pair_product.url }}">{{ pair_product.title | split: ' in ' | first }}</a>
          <p class="bb-ctl__piece">{{ pair_product.type | default: section.settings.pair_label | default: 'Resortwear' }}</p>
          <p class="bb-ctl__price" data-base-price="{{ pair_variant.price }}">
            {{ pair_variant.price | money | strip_html }}
          </p>
        </div>
        <div class="bb-ctl__right">
          <div class="bb-ctl__size-wrap">
            {%- if pair_product.variants.size > 1 -%}
              <select class="bb-ctl__size-select" aria-label="Size for {{ pair_product.title | escape }}" data-item-id="{{ pair_product.id }}">
                {%- for variant in pair_product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    data-price="{{ variant.price }}"
                    data-price-unit="presentment"
                    data-price-formatted="{{ variant.price | money | strip_html | escape }}"
                    {%- unless variant.available %} disabled{%- endunless -%}
                  >{{ variant.title }}{%- unless variant.available %} — Sold out{%- endunless -%}</option>
                {%- endfor -%}
              </select>
              <svg class="bb-ctl__size-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8a8077" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            {%- else -%}
              <span class="bb-ctl__size-only">One-Size</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── Footer ── {%- endcomment -%}
  <div class="bb-ctl__footer">
    <div class="bb-ctl__total-wrap">
      <span class="bb-ctl__total-label">Total</span>
      <strong class="bb-ctl__total-value" id="bb-ctl-total-{{ section.id }}">—</strong>
    </div>
    <button
      type="button"
      class="bb-ctl__add-btn"
      id="bb-ctl-add-{{ section.id }}"
      aria-label="Add selected items to cart"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <span class="bb-ctl__add-label">Add to cart</span>
    </button>
  </div>

</div>


<style>
  #bb-ctl-{{ section.id }} {
    --bb-accent: {{ section.settings.accent_color | default: '#49c6be' }};
    background: #ffffff;
    display: flex;
    flex-direction: column;
  }
  #bb-ctl-{{ section.id }}[hidden] { display: none !important; }

  #bb-ctl-{{ section.id }} .bb-ctl__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 16px 20px 12px;
    border-top: 0.5px solid #e8e4dd;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__title {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2a2520;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__sub { font-size: 0.6875rem; color: #8a8077; }

  #bb-ctl-{{ section.id }} .bb-ctl__list { display: flex; flex-direction: column; }

  #bb-ctl-{{ section.id }} .bb-ctl__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: #faf8f4;
    border-bottom: 0.5px solid #f0ece6;
    cursor: pointer;
    transition: background 0.15s;
    user-select: none;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__item.is-current { cursor: default; }
  #bb-ctl-{{ section.id }} .bb-ctl__item:not(.is-current):hover { background: #f5f1ec; }
  #bb-ctl-{{ section.id }} .bb-ctl__item.is-checked:not(.is-current) { background: #f5f1ec; }
  #bb-ctl-{{ section.id }} .bb-ctl__item.is-checked { box-shadow: inset 0 0 0 1px var(--bb-accent); border-radius: 6px; }
  #bb-ctl-{{ section.id }} .bb-ctl__item + .bb-ctl__item { margin-top: 4px; }

  #bb-ctl-{{ section.id }} .bb-ctl__check { flex-shrink: 0; }
  #bb-ctl-{{ section.id }} .bb-ctl__chk-on {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--bb-accent); border: 1.5px solid var(--bb-accent);
    display: inline-flex; align-items: center; justify-content: center;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__chk-off {
    width: 18px; height: 18px; border-radius: 50%;
    border: 1.5px solid #d0cbc4; background: #ffffff;
  }

  #bb-ctl-{{ section.id }} .bb-ctl__img {
    width: {{ ctl_img_w }}px; height: {{ ctl_img_h }}px; border-radius: 6px;
    overflow: hidden; flex-shrink: 0; background: #f0ece6;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  #bb-ctl-{{ section.id }} .bb-ctl__info { flex: 1; min-width: 0; }
  #bb-ctl-{{ section.id }} .bb-ctl__name {
    display: inline-block; max-width: 100%; vertical-align: top; text-decoration: none;
    font-size: 0.8125rem; font-weight: 500; color: #2a2520;
    margin-bottom: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  #bb-ctl-{{ section.id }} a.bb-ctl__name:hover { text-decoration: underline; }
  #bb-ctl-{{ section.id }} .bb-ctl__piece { font-size: 0.75rem; color: #8a8077; margin-bottom: 3px; }
  #bb-ctl-{{ section.id }} .bb-ctl__price { font-size: 0.75rem; color: #2a2520; }

  #bb-ctl-{{ section.id }} .bb-ctl__right {
    display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__size-wrap { position: relative; display: inline-flex; align-items: center; }
  #bb-ctl-{{ section.id }} .bb-ctl__size-select {
    appearance: none; -webkit-appearance: none;
    background: {{ section.settings.size_select_bg_color | default: '#ffffff' }};
    border: 0.5px solid {{ section.settings.size_select_border_color | default: '#e0dbd3' }};
    border-radius: {{ section.settings.size_select_radius | default: 5 }}px;
    min-width: {{ section.settings.size_select_min_width | default: 64 }}px;
    height: {{ section.settings.size_select_height | default: 30 }}px;
    padding: 0 24px 0 9px; font-size: {{ section.settings.size_select_font_size | default: 12 }}px;
    color: {{ section.settings.size_select_text_color | default: '#2a2520' }};
    font-family: inherit; cursor: pointer;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__size-chevron { position: absolute; right: 7px; pointer-events: none; }
  #bb-ctl-{{ section.id }} .bb-ctl__size-only {
    font-size: {{ section.settings.onesize_font_size | default: 12 }}px;
    font-weight: {{ section.settings.onesize_weight | default: 500 }};
    color: {{ section.settings.onesize_color | default: '#8a8077' }};
  }

  #bb-ctl-{{ section.id }} .bb-ctl__divider {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 20px; background: #ffffff;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__divider-line { flex: 1; height: 0.5px; background: #e8e4dd; }
  #bb-ctl-{{ section.id }} .bb-ctl__divider-text {
    font-size: 0.5625rem; font-weight: 500; letter-spacing: 0.06em;
    text-transform: uppercase; color: #a09890; white-space: nowrap;
  }

  #bb-ctl-{{ section.id }} .bb-ctl__footer {
    display: flex; align-items: center; justify-content: space-between;
    gap: 10px; background: #f0faf9; padding: 12px 20px;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__total-wrap { display: flex; flex-direction: column; gap: 1px; }
  #bb-ctl-{{ section.id }} .bb-ctl__total-label { font-size: 0.625rem; color: #2a7a74; letter-spacing: 0.04em; }
  #bb-ctl-{{ section.id }} .bb-ctl__total-value { font-size: 0.9375rem; font-weight: 500; color: #2a2520; }

  #bb-ctl-{{ section.id }} .bb-ctl__add-btn {
    -webkit-appearance: none; appearance: none;
    -webkit-tap-highlight-color: transparent;
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    background: var(--bb-accent); color: #ffffff; border: none; border-radius: 999px;
    padding: 10px 16px; font-size: 0.6875rem; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer; font-family: inherit; white-space: nowrap; transition: opacity 0.15s;
  }
  #bb-ctl-{{ section.id }} .bb-ctl__add-btn:hover { opacity: 0.9; }
  #bb-ctl-{{ section.id }} .bb-ctl__add-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  #bb-ctl-{{ section.id }} .bb-ctl__add-btn svg { stroke: #ffffff; flex-shrink: 0; }

  @media (max-width: 767px) {
    #bb-ctl-{{ section.id }} .bb-ctl__head { padding: 14px 14px 10px; }
    #bb-ctl-{{ section.id }} .bb-ctl__footer { padding: 10px 14px; }
    #bb-ctl-{{ section.id }} .bb-ctl__item { padding: 10px 14px; }
    #bb-ctl-{{ section.id }} .bb-ctl__divider { padding: 6px 14px; }
    #bb-ctl-{{ section.id }} .bb-ctl__add-btn { min-width: 150px; }
  }
</style>


<script>
(function () {
  'use strict';

  var sid    = '{{ section.id }}';
  var ctl    = document.getElementById('bb-ctl-' + sid);
  if (!ctl) return;

  var totalEl  = document.getElementById('bb-ctl-total-' + sid);
  var addBtn   = document.getElementById('bb-ctl-add-' + sid);
  var addLabel = addBtn ? addBtn.querySelector('.bb-ctl__add-label') : null;
  var pieceRow = document.getElementById('bb-ctl-piece-' + sid);
  var pieceRowIsLiquid = pieceRow && pieceRow.dataset.liquidPiece === 'true';

  var imgW  = {{ ctl_img_w }};
  var imgH  = {{ ctl_img_h }};
  var imgW2 = {{ ctl_img_w2 }};
  var imgH2 = {{ ctl_img_h2 }};

  /* ── Populate matching piece row from auto-connect (JS fallback only) ── */
  function handleProductData(data) {
    if (pieceRowIsLiquid) return;
    if (!data || !data.hasPieceToggle) return;

    var oppPiece = data.piece === 'Top' ? 'Bottom' : 'Top';
    var link     = data.pieceLinks[oppPiece];
    if (!link) return;

    /* A matching piece exists → make sure the section is shown even if it
       started hidden (no set-pair metafield). */
    ctl.hidden = false;

    var handle = link.url.replace('/products/', '');

    fetch('/products/' + handle + '.js')
      .then(function (r) { return r.json(); })
      .then(function (p) {
        var nameEl  = document.getElementById('bb-ctl-piece-name-' + sid);
        var labelEl = document.getElementById('bb-ctl-piece-label-' + sid);
        var priceEl = document.getElementById('bb-ctl-piece-price-' + sid);
        var imgEl   = document.getElementById('bb-ctl-piece-img-' + sid);
        var sizesEl = document.getElementById('bb-ctl-piece-sizes-' + sid);

        if (nameEl) {
          nameEl.textContent = p.title.split(' in ')[0];
          nameEl.href = link.url;
        }
        if (labelEl) labelEl.textContent = (p.type && p.type.trim()) ? p.type : oppPiece;
        if (priceEl) {
          priceEl.textContent = formatShopMoneyFromCents(p.variants[0].price);
        }

        /*
          /products/{handle}.js returns featured_image and images as URL STRINGS
          (not objects), so the old p.images[0].src was undefined — hence no image.
        */
        var imgSrc = p.featured_image || (p.images && p.images[0]) || null;

        if (imgEl && imgSrc) {
          imgSrc = imgSrc.split('?')[0] + '?width=' + imgW2 + '&height=' + imgH2 + '&crop=center';
          var img    = document.createElement('img');
          img.src    = imgSrc;
          img.alt    = p.title;
          img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
          imgEl.style.cssText = 'width:' + imgW + 'px;height:' + imgH + 'px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#f0ece6;';
          imgEl.innerHTML = '';
          imgEl.appendChild(img);
        }

        /* Size select */
        if (sizesEl && p.variants.length > 0) {
          sizesEl.innerHTML = '';
          if (p.variants.length > 1) {
            var sel = document.createElement('select');
            sel.className = 'bb-ctl__size-select';
            sel.setAttribute('aria-label', 'Size for ' + p.title);
            sel.dataset.itemId = p.id;

            p.variants.forEach(function (v) {
              var opt = document.createElement('option');
              opt.value                  = v.id;
              opt.dataset.price          = v.price;
              opt.dataset.priceUnit      = 'shop';
              opt.dataset.priceFormatted = formatShopMoneyFromCents(v.price);
              opt.textContent            = v.title + (v.available ? '' : ' — Sold out');
              if (!v.available) opt.disabled = true;
              sel.appendChild(opt);
            });

            var chevron = document.createElement('span');
            chevron.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8a8077" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bb-ctl__size-chevron"><polyline points="6 9 12 15 18 9"/></svg>';

            sizesEl.appendChild(sel);
            sizesEl.appendChild(chevron.firstChild);

            sel.addEventListener('change', function () {
              var opt = sel.options[sel.selectedIndex];
              pieceRow.dataset.variantId = opt.value;
              pieceRow.dataset.price     = opt.dataset.price;
              pieceRow.dataset.priceUnit = opt.dataset.priceUnit || 'shop';
              var priceEl = pieceRow.querySelector('.bb-ctl__price');
              if (priceEl) priceEl.textContent = opt.dataset.priceFormatted || '';
              updateTotal();
            });
          } else {
            var onlyPiece = document.createElement('span');
            onlyPiece.className = 'bb-ctl__size-only';
            onlyPiece.textContent = 'One-Size';
            sizesEl.appendChild(onlyPiece);
          }

          pieceRow.dataset.variantId = p.variants[0].id;
          pieceRow.dataset.price     = p.variants[0].price;
          pieceRow.dataset.priceUnit = 'shop';
          pieceRow.dataset.productId = p.id;
        }

        pieceRow.style.display = '';
        updateTotal();

        /* If a size was already chosen on the main product, apply it to this row */
        if (lastSelectedSize) syncSize(lastSelectedSize);
      })
      .catch(function (err) {
        console.warn('[BB CTL] Could not load piece product:', err);
      });
  }

  /* Handle both early and late firing of auto-connect */
  if (window.BB && window.BB.productData) {
    handleProductData(window.BB.productData);
  }
  document.addEventListener('bb:productDataReady', function (e) {
    handleProductData(e.detail);
  });

  /* ── Money helpers ── */
  function formatPresentmentCents(cents) {
    if (window.BB && typeof window.BB.formatPresentmentCents === 'function') {
      return window.BB.formatPresentmentCents(cents);
    }
    if (window.BB && typeof window.BB.formatMoney === 'function') {
      var fmt = (window.theme && window.theme.moneyFormat) || (window.BB && window.BB.moneyFormat) || '{{amount}}';
      return window.BB.formatMoney(cents, fmt);
    }
    return String(parseFloat(cents) / 100);
  }

  function formatShopMoneyFromCents(shopCents) {
    if (window.BB && typeof window.BB.formatPresentmentMoney === 'function') {
      return window.BB.formatPresentmentMoney(shopCents);
    }
    return formatPresentmentCents(shopCents);
  }

  function bbCurrencyRate() {
    var active = window.Shopify && window.Shopify.currency && window.Shopify.currency.active;
    var shop   = window.BB && window.BB.shopCurrency;
    if (!active || !shop || active === shop) return 1;
    return window.Shopify.currency.rate || 1;
  }

  function itemPresentmentCents(item, sel) {
    var opt = sel ? sel.options[sel.selectedIndex] : null;
    var raw = opt
      ? parseInt(opt.dataset.price || '0', 10)
      : parseInt(item.dataset.price || '0', 10);
    var unit = (opt && opt.dataset.priceUnit) || item.dataset.priceUnit || 'presentment';
    if (unit === 'shop') {
      return Math.round(raw * bbCurrencyRate());
    }
    return raw;
  }

  /* ── Size sync: match every item's size <select> to the chosen product size ── */
  var lastSelectedSize = null;

  function optionSizeLabel(opt) {
    /* Strip the " — Sold out" suffix and normalise for comparison */
    return opt.textContent.split(' — ')[0].trim().toLowerCase();
  }

  function syncSize(size) {
    if (!size) return;
    var target = String(size).trim().toLowerCase();

    ctl.querySelectorAll('.bb-ctl__item').forEach(function (item) {
      var sel = item.querySelector('.bb-ctl__size-select');
      if (!sel) return;

      var matched = null;
      for (var i = 0; i < sel.options.length; i++) {
        if (optionSizeLabel(sel.options[i]) === target) { matched = sel.options[i]; break; }
      }

      /* No matching size, or it's sold out → leave this item on its current size */
      if (!matched || matched.disabled) return;

      sel.value              = matched.value;
      item.dataset.variantId = matched.value;
      if (matched.dataset.price) {
        item.dataset.price     = matched.dataset.price;
        item.dataset.priceUnit = matched.dataset.priceUnit || item.dataset.priceUnit || 'presentment';
      }

      var priceEl = item.querySelector('.bb-ctl__price');
      if (priceEl) {
        var formatted = matched.dataset.priceFormatted;
        if (!formatted && matched.dataset.price) {
          formatted = formatPresentmentCents(parseInt(matched.dataset.price, 10));
        }
        if (formatted) priceEl.textContent = formatted;
      }
    });

    updateTotal();
  }

  /* Listen for size changes broadcast by product-info.liquid */
  document.addEventListener('bb:sizeSelected', function (e) {
    lastSelectedSize = e.detail && e.detail.size;
    syncSize(lastSelectedSize);
  });

  /* ── Collect checked items ── */
  function getCheckedItems() {
    var checked = [];
    ctl.querySelectorAll('.bb-ctl__item.is-checked').forEach(function (item) {
      var sel       = item.querySelector('.bb-ctl__size-select');
      var variantId = sel ? sel.value : item.dataset.variantId;
      var price     = itemPresentmentCents(item, sel);
      if (variantId) checked.push({ variantId: variantId, price: price });
    });
    return checked;
  }

  /* ── Update total ── */
  function updateTotal() {
    var items = getCheckedItems();
    var total = 0;
    items.forEach(function (i) { total += i.price; });
    if (totalEl) totalEl.textContent = total > 0 ? formatPresentmentCents(total) : '—';
  }

  /* ── Row click toggles check ── */
  ctl.querySelectorAll('.bb-ctl__item:not(.is-current)').forEach(function (item) {
    item.addEventListener('click', function (e) {
      if (e.target.closest('.bb-ctl__size-wrap')) return;
      if (e.target.closest('.bb-ctl__name')) return;
      var isChecked = item.classList.toggle('is-checked');
      var chkEl     = item.querySelector('.bb-ctl__check');
      if (chkEl) {
        chkEl.innerHTML = isChecked
          ? '<div class="bb-ctl__chk-on"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>'
          : '<div class="bb-ctl__chk-off"></div>';
      }
      updateTotal();
    });

    var sel = item.querySelector('.bb-ctl__size-select');
    if (sel) {
      sel.addEventListener('change', function () {
        var opt = sel.options[sel.selectedIndex];
        item.dataset.variantId = opt.value;
        item.dataset.price     = opt.dataset.price || '0';
        item.dataset.priceUnit = opt.dataset.priceUnit || item.dataset.priceUnit || 'presentment';
        var priceEl = item.querySelector('.bb-ctl__price');
        if (priceEl) {
          var formatted = opt.dataset.priceFormatted;
          if (!formatted && opt.dataset.price) {
            formatted = formatPresentmentCents(parseInt(opt.dataset.price, 10));
          }
          if (formatted) priceEl.textContent = formatted;
        }
        updateTotal();
      });
    }
  });

  /* ── Add to cart ── */
  if (addBtn) {
    addBtn.addEventListener('click', function () {
      var checkedItems = getCheckedItems();
      if (checkedItems.length === 0) return;

      addBtn.disabled = true;
      if (addLabel) addLabel.textContent = 'Adding…';

      var cartDrawer = document.querySelector('cart-drawer');
      var addBody    = {
        items: checkedItems.map(function (i) {
          return { id: parseInt(i.variantId, 10), quantity: 1 };
        })
      };

      if (cartDrawer && typeof cartDrawer.getSectionsToRender === 'function') {
        addBody.sections     = cartDrawer.getSectionsToRender().map(function (s) { return s.id; }).join(',');
        addBody.sections_url = window.location.pathname;
      }

      fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify(addBody)
      })
      .then(function (r) { return r.json(); })
      .then(function (response) {
        if (response.status) {
          throw new Error(response.description || 'Could not add to cart');
        }

        if (addLabel) addLabel.textContent = 'Added!';

        if (cartDrawer && typeof cartDrawer.renderContents === 'function' && response.sections) {
          /* Swap in freshly-rendered drawer HTML and open it (renders correctly on mobile) */
          cartDrawer.renderContents(response);
          /* Clear stale empty-state class when adding to a previously empty cart */
          cartDrawer.classList.remove('is-empty');
          var drawerInner = cartDrawer.querySelector('.drawer__inner');
          if (drawerInner) drawerInner.classList.remove('is-empty');
        } else {
          document.dispatchEvent(new CustomEvent('cart:updated'));
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          var cartTriggers = ['[data-drawer-open="cart-drawer"]','[data-cart-drawer-trigger]','[data-open-drawer="cart"]','.js-cart-drawer-open','#cart-icon-bubble','.cart-icon-bubble','[aria-controls="cart-drawer"]'];
          for (var i = 0; i < cartTriggers.length; i++) {
            var el = document.querySelector(cartTriggers[i]);
            if (el) { el.click(); break; }
          }
        }

        setTimeout(function () {
          if (addLabel) addLabel.textContent = 'Add to cart';
          addBtn.disabled = false;
        }, 1800);
      })
      .catch(function (err) {
        console.warn('[BB CTL] Cart error:', err);
        if (addLabel) addLabel.textContent = 'Try again';
        addBtn.disabled = false;
      });
    });
  }

  /* Initial sync: match other items to the current product's pre-selected size */
  (function () {
    var currentItem = ctl.querySelector('.bb-ctl__item.is-current');
    var currentSel  = currentItem ? currentItem.querySelector('.bb-ctl__size-select') : null;
    if (currentSel && currentSel.selectedIndex >= 0) {
      lastSelectedSize = optionSizeLabel(currentSel.options[currentSel.selectedIndex]);
      syncSize(lastSelectedSize);
    }
  })();

  updateTotal();
})();
</script>


