{% comment %}
  Infinite horizontal marquee, either numbered URLs under Admin > Content > Files,
  or manual slide blocks with the image picker.
{% endcomment %}

{%- liquid
  assign use_files = section.settings.use_shopify_files_urls
  assign files_base = section.settings.files_base_url | strip
  assign q = section.settings.files_url_query | strip
  assign ext = section.settings.files_extension | strip | default: 'png'
  assign i_start = section.settings.file_index_start | default: 1 | plus: 0
  assign i_end = section.settings.file_index_end | default: 19 | plus: 0
  assign file_indices_raw = section.settings.file_indices | strip
  assign use_index_list = false
  if file_indices_raw != blank
    assign use_index_list = true
  endif

  assign slide_count = 0
  if use_files and files_base != blank
    if use_index_list
      assign idx_parts = file_indices_raw | split: ','
      for piece in idx_parts
        assign n = piece | strip | plus: 0
        if n > 0
          assign slide_count = slide_count | plus: 1
        endif
      endfor
    elsif i_end >= i_start
      assign slide_count = i_end | minus: i_start | plus: 1
    endif
  else
    for block in section.blocks
      if block.type == 'slide' and block.settings.image != blank
        assign slide_count = slide_count | plus: 1
      endif
    endfor
  endif
-%}

<section
  class="bb-subframe bb-subframe-marquee"
  id="bb-marquee-{{ section.id }}"
  style="
    --bb-marquee-line: {{ section.settings.line_color | default: '#0a2e2e' }};
    --bb-marquee-bg: {{ section.settings.background_color | default: '#f0f7f7' }};
    --bb-marquee-strip-bg: {{ section.settings.strip_background | default: '#ffffff' }};
    --bb-marquee-duration: {{ section.settings.duration | default: 24 }}s;
    --bb-marquee-slide-w: {{ section.settings.slide_width | default: 260 }}px;
    --bb-marquee-slide-h: {{ section.settings.slide_height | default: 440 }}px;
    --bb-marquee-btn-bg: {{ section.settings.button_background | default: '#0a2e2e' }};
    --bb-marquee-btn-fg: {{ section.settings.button_label_color | default: '#ffffff' }};
  "
  {{ section.shopify_attributes }}
>
  <div class="bb-subframe-marquee__inner">
    <div class="bb-subframe-section-head bb-subframe-marquee__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bb-subframe-eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-subframe-title bb-subframe-title--marquee">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="bb-subframe-marquee__frame">
      <div class="bb-subframe-marquee__rule" aria-hidden="true"></div>

      <div class="bb-subframe-marquee__viewport">
        {%- if slide_count > 0 -%}
          <div class="bb-subframe-marquee__track">
            {%- if use_files and files_base != blank and use_index_list and slide_count > 0 -%}
              <div class="bb-subframe-marquee__group">
                {%- assign idx_parts = file_indices_raw | split: ',' -%}
                {%- for piece in idx_parts -%}
                  {%- assign i = piece | strip | plus: 0 -%}
                  {%- if i > 0 -%}
                    {%- assign file_src = files_base | append: i | append: '.' | append: ext -%}
                    {%- if q != blank -%}
                      {%- assign file_src = file_src | append: '?' | append: q -%}
                    {%- endif -%}
                    <div class="bb-subframe-marquee__slide">
                      <img
                        src="{{ file_src }}"
                        sizes="{{ section.settings.slide_width }}px"
                        alt="{{ section.settings.heading | default: shop.name | escape }} - {{ i }}"
                        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                        decoding="async"
                      >
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <div class="bb-subframe-marquee__group" aria-hidden="true">
                {%- assign idx_parts = file_indices_raw | split: ',' -%}
                {%- for piece in idx_parts -%}
                  {%- assign i = piece | strip | plus: 0 -%}
                  {%- if i > 0 -%}
                    {%- assign file_src = files_base | append: i | append: '.' | append: ext -%}
                    {%- if q != blank -%}
                      {%- assign file_src = file_src | append: '?' | append: q -%}
                    {%- endif -%}
                    <div class="bb-subframe-marquee__slide">
                      <img
                        src="{{ file_src }}"
                        sizes="{{ section.settings.slide_width }}px"
                        alt=""
                        loading="lazy"
                        decoding="async"
                      >
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- elsif use_files and files_base != blank and i_end >= i_start -%}
              <div class="bb-subframe-marquee__group">
                {%- for i in (i_start..i_end) -%}
                  {%- assign file_src = files_base | append: i | append: '.' | append: ext -%}
                  {%- if q != blank -%}
                    {%- assign file_src = file_src | append: '?' | append: q -%}
                  {%- endif -%}
                  <div class="bb-subframe-marquee__slide">
                    <img
                      src="{{ file_src }}"
                      sizes="{{ section.settings.slide_width }}px"
                      alt="{{ section.settings.heading | default: shop.name | escape }} - {{ i }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      decoding="async"
                    >
                  </div>
                {%- endfor -%}
              </div>
              <div class="bb-subframe-marquee__group" aria-hidden="true">
                {%- for i in (i_start..i_end) -%}
                  {%- assign file_src = files_base | append: i | append: '.' | append: ext -%}
                  {%- if q != blank -%}
                    {%- assign file_src = file_src | append: '?' | append: q -%}
                  {%- endif -%}
                  <div class="bb-subframe-marquee__slide">
                    <img
                      src="{{ file_src }}"
                      sizes="{{ section.settings.slide_width }}px"
                      alt=""
                      loading="lazy"
                      decoding="async"
                    >
                  </div>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="bb-subframe-marquee__group">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' and block.settings.image != blank -%}
                    <div class="bb-subframe-marquee__slide" {{ block.shopify_attributes }}>
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w"
                        sizes="{{ section.settings.slide_width }}px"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        alt="{{ block.settings.image.alt | default: section.settings.heading | escape }}"
                        loading="lazy"
                        decoding="async"
                      >
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <div class="bb-subframe-marquee__group" aria-hidden="true">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' and block.settings.image != blank -%}
                    <div class="bb-subframe-marquee__slide">
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w"
                        sizes="{{ section.settings.slide_width }}px"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        alt=""
                        loading="lazy"
                        decoding="async"
                      >
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="bb-subframe-marquee__empty">
            <p>Turn on “Use Shopify Files URLs” with a valid base path and index range, or add slide blocks with images.</p>
          </div>
        {%- endif -%}
      </div>

      <div class="bb-subframe-marquee__rule bb-subframe-marquee__rule--strip-bottom" aria-hidden="true"></div>

      <div class="bb-subframe-marquee__cta">
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a class="bb-subframe-marquee__btn bb-subframe-cta-cohesive" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>
        {%- elsif section.settings.button_label != blank -%}
          <span class="bb-subframe-marquee__btn bb-subframe-cta-cohesive bb-subframe-marquee__btn--disabled">{{ section.settings.button_label | escape }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BB - Marquee strip",
  "tag": "section",
  "class": "bb-subframe-marquee-section",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Complete your swim look"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Bikini Booth uniform"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f0f7f7"
    },
    {
      "type": "color",
      "id": "strip_background",
      "label": "Image strip background",
      "default": "#ffffff",
      "info": "Usually white so PNG cutouts blend edge-to-edge."
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Hairline color",
      "default": "#0a2e2e",
      "info": "Theme ink/teal - replaces default black divider lines."
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Shop button background",
      "default": "#0a2e2e"
    },
    {
      "type": "color",
      "id": "button_label_color",
      "label": "Shop button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "checkbox",
      "id": "use_shopify_files_urls",
      "label": "Use Shopify Files numbered URLs",
      "default": true,
      "info": "Builds …/1.png through …/19.png from the base URL. Turn off to use slide blocks with the image picker instead."
    },
    {
      "type": "text",
      "id": "files_base_url",
      "label": "Files base URL",
      "default": "https://cdn.shopify.com/s/files/1/0692/4022/5894/files/",
      "info": "Open any file in Admin → Content → Files, copy the link, and paste everything before the file name (must end with /)."
    },
    {
      "type": "number",
      "id": "file_index_start",
      "label": "First file number",
      "default": 1
    },
    {
      "type": "number",
      "id": "file_index_end",
      "label": "Last file number",
      "default": 19
    },
    {
      "type": "text",
      "id": "files_extension",
      "label": "File extension",
      "default": "png"
    },
    {
      "type": "text",
      "id": "files_url_query",
      "label": "URL query (optional)",
      "default": "v=1776092291",
      "info": "Without ? - matches the query on your Files URLs (cache-busting). Clear if your links have no query string."
    },
    {
      "type": "text",
      "id": "file_indices",
      "label": "File order (comma list)",
      "default": "1,2,3,4,5,6,7,8",
      "info": "Uses only these file numbers, in order. Overrides First/Last when filled."
    },
    {
      "type": "range",
      "id": "duration",
      "min": 12,
      "max": 90,
      "step": 1,
      "unit": "s",
      "label": "Full loop duration",
      "default": 24,
      "info": "Lower = faster scroll (similar to fast editorial marquees)."
    },
    {
      "type": "range",
      "id": "slide_width",
      "min": 160,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Slide width",
      "default": 260
    },
    {
      "type": "range",
      "id": "slide_height",
      "min": 280,
      "max": 640,
      "step": 8,
      "unit": "px",
      "label": "Max image height",
      "default": 440
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BB - Marquee strip",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
