{%- comment -%}
  ============================================================
  Section: Starfish Divider
  File:    sections/bb-starfish-divider.liquid
  Brand:   Bikini Booth
  ------------------------------------------------------------
  Standalone, reusable decorative divider.
  - Pure inline SVG (slender starfish + delicate tapered/fading lines).
  - No images, no libraries.
  - Full-width by default; fades softly at both ends.
  - All CSS scoped to the section's unique id (safe for multiple instances).
  - Gradient ids suffixed per-instance to avoid collisions.
  - OS 2.0 compatible: addable anywhere via the theme editor (presets).
  ============================================================
{%- endcomment -%}

{%- liquid
  assign color  = section.settings.divider_color
  assign top    = section.settings.top_spacing
  assign bottom = section.settings.bottom_spacing
  assign star   = section.settings.starfish_size
  assign uid    = section.id

  if section.settings.full_width
    assign innermax = '100%'
  else
    assign innermax = section.settings.max_width | append: 'px'
  endif
-%}

<style>
  .bb-sfd-{{ uid }} {
    --bb-sfd-color: {{ color }};
    --bb-sfd-pt: {{ top }}px;
    --bb-sfd-pb: {{ bottom }}px;
    --bb-sfd-maxw: {{ innermax }};
    --bb-sfd-star: {{ star }}px;
    box-sizing: border-box;
    width: 100%;
    padding-top: var(--bb-sfd-pt);
    padding-bottom: var(--bb-sfd-pb);
  }
  .bb-sfd-{{ uid }} .bb-sfd__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(6px, 1.2vw, 11px);
    width: 100%;
    max-width: var(--bb-sfd-maxw);
    margin-inline: auto;
    padding-inline: clamp(8px, 2vw, 28px);
    color: var(--bb-sfd-color);
    box-sizing: border-box;
  }
  .bb-sfd-{{ uid }} .bb-sfd__line {
    flex: 1 1 0;
    min-width: 0;
    height: 8px;
    display: block;
  }
  .bb-sfd-{{ uid }} .bb-sfd__line svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bb-sfd-{{ uid }} .bb-sfd__line--right { transform: scaleX(-1); }
  .bb-sfd-{{ uid }} .bb-sfd__dot {
    flex: 0 0 auto;
    width: clamp(3px, 0.45vw, 4px);
    height: clamp(3px, 0.45vw, 4px);
    border-radius: 50%;
    background: currentColor;
  }
  .bb-sfd-{{ uid }} .bb-sfd__star {
    flex: 0 0 auto;
    width: var(--bb-sfd-star);
    height: var(--bb-sfd-star);
    display: block;
  }
  .bb-sfd-{{ uid }} .bb-sfd__star svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  @media screen and (max-width: 749px) {
    .bb-sfd-{{ uid }} {
      padding-top: calc(var(--bb-sfd-pt) * 0.62);
      padding-bottom: calc(var(--bb-sfd-pb) * 0.62);
    }
    .bb-sfd-{{ uid }} .bb-sfd__star {
      width: calc(var(--bb-sfd-star) * 0.88);
      height: calc(var(--bb-sfd-star) * 0.88);
    }
  }
</style>

<div class="bb-sfd-{{ uid }}" role="presentation">
  <div class="bb-sfd__inner">

    {%- comment -%} Left line: delicate hairline, slightly thicker near the centre, fading at the far end {%- endcomment -%}
    <span class="bb-sfd__line bb-sfd__line--left" aria-hidden="true">
      <svg viewBox="0 0 300 8" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bb-sfd-gl-{{ uid }}" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0"    stop-color="currentColor" stop-opacity="0"/>
            <stop offset="0.05" stop-color="currentColor" stop-opacity="0.5"/>
            <stop offset="0.2"  stop-color="currentColor" stop-opacity="1"/>
            <stop offset="1"    stop-color="currentColor" stop-opacity="1"/>
          </linearGradient>
        </defs>
        <path d="M 0 3.85 C 130 3.78, 210 3.05, 300 3.0 L 300 5.0 C 210 4.95, 130 4.22, 0 4.15 Z"
              fill="url(#bb-sfd-gl-{{ uid }})"/>
      </svg>
    </span>

    <span class="bb-sfd__dot" aria-hidden="true"></span>

    {%- comment -%} Centred slender outlined starfish {%- endcomment -%}
    <span class="bb-sfd__star" aria-hidden="true">
      <svg viewBox="0 0 100 92" xmlns="http://www.w3.org/2000/svg" fill="none">
        <path d="M 50 3
                 L 58.23 38.67 L 94.7 35.48 L 63.31 54.33 L 77.64 88.02
                 L 50 64 L 22.36 88.02 L 36.69 54.33 L 5.3 35.48 L 41.77 38.67 Z"
              stroke="currentColor" stroke-width="2.4"
              stroke-linejoin="round" stroke-linecap="round"/>
        <g fill="currentColor" opacity="0.45">
          <circle cx="50" cy="50" r="1"/>
          <circle cx="50" cy="44" r="0.85"/>
          <circle cx="53.5" cy="52" r="0.8"/>
          <circle cx="46.5" cy="52" r="0.8"/>
          <circle cx="50" cy="24" r="0.8"/>
          <circle cx="66" cy="46" r="0.8"/>
          <circle cx="34" cy="46" r="0.8"/>
        </g>
      </svg>
    </span>

    <span class="bb-sfd__dot" aria-hidden="true"></span>

    {%- comment -%} Right line: mirror of the left for perfect symmetry {%- endcomment -%}
    <span class="bb-sfd__line bb-sfd__line--right" aria-hidden="true">
      <svg viewBox="0 0 300 8" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bb-sfd-gr-{{ uid }}" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0"    stop-color="currentColor" stop-opacity="0"/>
            <stop offset="0.05" stop-color="currentColor" stop-opacity="0.5"/>
            <stop offset="0.2"  stop-color="currentColor" stop-opacity="1"/>
            <stop offset="1"    stop-color="currentColor" stop-opacity="1"/>
          </linearGradient>
        </defs>
        <path d="M 0 3.85 C 130 3.78, 210 3.05, 300 3.0 L 300 5.0 C 210 4.95, 130 4.22, 0 4.15 Z"
              fill="url(#bb-sfd-gr-{{ uid }})"/>
      </svg>
    </span>

  </div>
</div>

{% schema %}
{
  "name": "Starfish Divider",
  "tag": "section",
  "class": "bb-starfish-divider-section",
  "settings": [
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#49c6be"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "info": "Span the full width of the section. Turn off to cap the width below.",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Divider max width",
      "info": "Only used when Full width is off.",
      "min": 480,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "starfish_size",
      "label": "Starfish size",
      "min": 18,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Starfish Divider"
    }
  ]
}
{% endschema %}
