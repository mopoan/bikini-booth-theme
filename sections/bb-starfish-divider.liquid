{%- comment -%}
  ============================================================
  Section: Starfish Divider  (sections/bb-starfish-divider.liquid)
  Brand:   Bikini Booth
  ------------------------------------------------------------
  HYBRID build:
    - Lines are drawn in code (inline SVG) and flex to fill the width,
      so they go full-width WITHOUT a 100vw breakout (won't break grids).
    - Starfish is a true vector trace of the approved art, sized
      independently of the lines.
    - Dots flank the star. Everything recolors via currentColor wired to
      the "Divider color" setting.
  Controls: color, line thickness, starfish size, max width, edge-to-edge,
  top/bottom spacing.  CSS scoped to section id; ids suffixed per instance.
  OS 2.0 (presets). Safe to add multiple times per page.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign color = section.settings.divider_color
  assign top    = section.settings.top_spacing
  assign bottom = section.settings.bottom_spacing
  assign uid    = section.id
-%}

<style>
  .bb-sfd-{{ uid }} {
    --c: {{ color }};
    --pt: {{ top }}px;
    --pb: {{ bottom }}px;
    --star: {{ section.settings.star_size }}px;
    --lt: {{ section.settings.line_thickness }}px;
    box-sizing: border-box;
    width: 100%;
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }
{%- if section.settings.full_bleed %}
  /* Edge-to-edge: break out of a centered, width-constrained parent.
     Use only when this section is standalone (NOT inside the product grid). */
  .bb-sfd-{{ uid }} {
    grid-column: 1 / -1;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
{%- endif %}
  .bb-sfd-{{ uid }} .bb-sfd__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: calc(var(--star) * 0.28);
    width: 100%;
    max-width: {% if section.settings.full_bleed %}100%{% else %}{{ section.settings.max_width }}px{% endif %};
    margin-inline: auto;
    padding-inline: clamp(12px, 3vw, 40px);
    color: var(--c);
    box-sizing: border-box;
  }
  .bb-sfd-{{ uid }} .bb-sfd__line {
    flex: 1 1 0;
    min-width: 0;
    height: var(--lt);
    display: block;
  }
  .bb-sfd-{{ uid }} .bb-sfd__line svg { display: block; width: 100%; height: 100%; }
  .bb-sfd-{{ uid }} .bb-sfd__line--right { transform: scaleX(-1); }
  .bb-sfd-{{ uid }} .bb-sfd__dot {
    flex: 0 0 auto;
    width: calc(var(--lt) * 1.3);
    height: calc(var(--lt) * 1.3);
    border-radius: 50%;
    background: currentColor;
  }
  .bb-sfd-{{ uid }} .bb-sfd__star {
    flex: 0 0 auto;
    width: var(--star);
    height: calc(var(--star) * 0.8953);
    display: block;
  }
  .bb-sfd-{{ uid }} .bb-sfd__star svg { display: block; width: 100%; height: 100%; overflow: visible; }

  @media screen and (max-width: 749px) {
    .bb-sfd-{{ uid }} { padding-top: calc(var(--pt) * 0.62); padding-bottom: calc(var(--pb) * 0.62); }
    .bb-sfd-{{ uid }} .bb-sfd__inner { padding-inline: clamp(10px, 4vw, 24px); }
  }
</style>

<div class="bb-sfd-{{ uid }}" role="presentation">
  <div class="bb-sfd__inner">

    <span class="bb-sfd__line bb-sfd__line--left" aria-hidden="true">
