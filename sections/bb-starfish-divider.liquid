{%- comment -%}
  ============================================================
  Section: Starfish Divider  (sections/bb-starfish-divider.liquid)
  Brand:   Bikini Booth
  ------------------------------------------------------------
  TRUE VECTOR divider (inline SVG paths, traced from the approved
  artwork). Recolors via the theme-editor "Divider color" setting
  (fill = currentColor). Soft fade restored at both ends.
  - No images, no libraries, no external assets. Infinitely crisp.
  - CSS scoped to the section id; gradient/mask ids suffixed per
    instance. Safe to add multiple times per page. OS 2.0 (presets).
  ============================================================
{%- endcomment -%}

{%- liquid
  assign color  = section.settings.divider_color
  assign top    = section.settings.top_spacing
  assign bottom = section.settings.bottom_spacing
  assign uid    = section.id
-%}

<style>
  .bb-sfd-{{ uid }} {
    --c: {{ color }};
    --pt: {{ top }}px;
    --pb: {{ bottom }}px;
    box-sizing: border-box;
    width: 100%;
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }
{%- if section.settings.full_width %}
  /* Full bleed: escape any centered, width-constrained parent and span the viewport */
  .bb-sfd-{{ uid }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
{%- endif %}
  .bb-sfd-{{ uid }} .bb-sfd__art {
    display: block;
    width: 100%;
    max-width: {% if section.settings.full_width %}100%{% else %}{{ section.settings.max_width }}px{% endif %};
    height: auto;
    margin-inline: auto;
    color: var(--c);
  }
  @media screen and (max-width: 749px) {
    .bb-sfd-{{ uid }} {
      padding-top: calc(var(--pt) * 0.62);
      padding-bottom: calc(var(--pb) * 0.62);
    }
  }
</style>

