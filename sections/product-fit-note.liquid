{%- comment -%}
  Section: product-fit-note.liquid
  Purpose: Fit note callout below the trust bar on product pages.
           Teal tint background matching the announcement bar.
           Optional model image on the right.
  Standalone: No dependencies on other sections or snippets.
{%- endcomment -%}

{%- if section.settings.fit_note != blank -%}

{%- assign fit_img_w  = section.settings.image_width | default: 72 -%}
{%- assign fit_img_h  = fit_img_w | times: 16 | divided_by: 9 -%}
{%- assign fit_img_w2 = fit_img_w | times: 2 -%}
{%- assign fit_img_h2 = fit_img_h | times: 2 -%}

<div class="bb-fit" id="bb-fit-{{ section.id }}">

  <div class="bb-fit__text">
    <div class="bb-fit__label">
      {%- case section.settings.fit_icon -%}
        {%- when 'none' -%}
        {%- when 'shipping' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {%- when 'location' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {%- when 'returns' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>
        {%- when 'lock' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {%- when 'leaf' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 22c1.25-1.25 2.5-2.5 3.75-5C7 14.5 7.5 12 8 10c1-4 4-7 9-8-1 5-2 8-4 10s-5 3-8 4c-1.5.5-2.5 1-3 2z"/><path d="M2 22L12 12"/></svg>
        {%- when 'shield' -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {%- else -%}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      {%- endcase -%}
      {{ section.settings.fit_title | default: 'Fit note' }}
    </div>
    <div class="bb-fit__body">{{ section.settings.fit_note }}</div>
  </div>

  {%- if product.featured_image != blank -%}
    <div class="bb-fit__img">
      <img
        src="{{ product.featured_image | image_url: width: fit_img_w2, height: fit_img_h2, crop: 'center' }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        width="{{ fit_img_w }}"
        height="{{ fit_img_h }}"
        loading="lazy"
      >
    </div>
  {%- endif -%}

</div>

<style>
  #bb-fit-{{ section.id }} {
    background: #f0faf9;
    padding: 14px 22px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    border-top: 0.5px solid #d8f0ee;
    border-bottom: 0.5px solid #d8f0ee;
  }

  #bb-fit-{{ section.id }} .bb-fit__text { flex: 1; }

  #bb-fit-{{ section.id }} .bb-fit__label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: {{ section.settings.title_font_size | default: 10 }}px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #2a7a74;
    margin-bottom: 5px;
  }

  #bb-fit-{{ section.id }} .bb-fit__body {
    font-size: {{ section.settings.body_font_size | default: 11 }}px;
    color: #3a6a65;
    line-height: 1.65;
  }
  #bb-fit-{{ section.id }} .bb-fit__body p { margin: 0; }

  #bb-fit-{{ section.id }} .bb-fit__img {
    flex-shrink: 0;
  }
  #bb-fit-{{ section.id }} .bb-fit__img img {
    width: {{ fit_img_w }}px;
    height: {{ fit_img_h }}px;
    object-fit: cover;
    border-radius: 5px;
    display: block;
  }

  @media (max-width: 767px) {
    #bb-fit-{{ section.id }} { padding: 12px 14px; }
  }
</style>

{%- endif -%}


{% schema %}
{
  "name": "Product fit note",
  "tag": "div",
  "class": "bb-product-fit-section",
  "settings": [
    {
      "type": "richtext",
      "id": "fit_note",
      "label": "Fit note text",
      "info": "Leave blank to hide this section entirely. The product's main image is used automatically as the model photo.",
      "default": "<p>Our model is 5'9.5\", wears size S top and size S bottom. For reference, she has a 34B bust, 24\" waist and 34.5\" hips.</p>"
    },
    {
      "type": "header",
      "content": "Title & icon"
    },
    {
      "type": "text",
      "id": "fit_title",
      "label": "Title",
      "default": "Fit note"
    },
    {
      "type": "select",
      "id": "fit_icon",
      "label": "Icon",
      "options": [
        { "value": "star",     "label": "Star" },
        { "value": "shield",   "label": "Shield" },
        { "value": "shipping", "label": "Shipping truck" },
        { "value": "location", "label": "Location pin" },
        { "value": "returns",  "label": "Returns arrow" },
        { "value": "lock",     "label": "Secure lock" },
        { "value": "leaf",     "label": "Leaf" },
        { "value": "none",     "label": "No icon" }
      ],
      "default": "star"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Fit note font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "header",
      "content": "Model image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width (height keeps 9:16)",
      "min": 40,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    { "name": "Product fit note" }
  ]
}
{% endschema %}
