{%- comment -%}
  Section: product-fit-note.liquid
  Purpose: Fit note callout below the trust bar on product pages.
           Teal tint background matching the announcement bar.
           Optional model image on the right.
  Standalone: No dependencies on other sections or snippets.
{%- endcomment -%}

{%- if section.settings.fit_note != blank -%}

<div class="bb-fit" id="bb-fit-{{ section.id }}">

  <div class="bb-fit__text">
    <div class="bb-fit__label">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      Fit note
    </div>
    <div class="bb-fit__body">{{ section.settings.fit_note }}</div>
  </div>

  {%- if product.featured_image != blank -%}
    <div class="bb-fit__img">
      <img
        src="{{ product.featured_image | image_url: width: 160, height: 200, crop: 'center' }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        width="60"
        height="75"
        loading="lazy"
      >
    </div>
  {%- endif -%}

</div>

<style>
  #bb-fit-{{ section.id }} {
    background: #f0faf9;
    padding: 14px 22px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    border-top: 0.5px solid #d8f0ee;
    border-bottom: 0.5px solid #d8f0ee;
  }

  #bb-fit-{{ section.id }} .bb-fit__text { flex: 1; }

  #bb-fit-{{ section.id }} .bb-fit__label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #2a7a74;
    margin-bottom: 5px;
  }

  #bb-fit-{{ section.id }} .bb-fit__body {
    font-size: 0.6875rem;
    color: #3a6a65;
    line-height: 1.65;
  }
  #bb-fit-{{ section.id }} .bb-fit__body p { margin: 0; }

  #bb-fit-{{ section.id }} .bb-fit__img {
    flex-shrink: 0;
  }
  #bb-fit-{{ section.id }} .bb-fit__img img {
    width: 60px;
    height: 75px;
    object-fit: cover;
    border-radius: 5px;
    display: block;
  }

  @media (max-width: 767px) {
    #bb-fit-{{ section.id }} { padding: 12px 14px; }
  }
</style>

{%- endif -%}


{% schema %}
{
  "name": "Product fit note",
  "tag": "div",
  "class": "bb-product-fit-section",
  "settings": [
    {
      "type": "richtext",
      "id": "fit_note",
      "label": "Fit note text",
      "info": "Leave blank to hide this section entirely. The product's main image is used automatically as the model photo.",
      "default": "<p>Our model is 5'9.5\", wears size S top and size S bottom. For reference, she has a 34B bust, 24\" waist and 34.5\" hips.</p>"
    }
  ],
  "presets": [
    { "name": "Product fit note" }
  ]
}
{% endschema %}
