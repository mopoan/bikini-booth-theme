{{ 'component-inputs.css' | asset_url | stylesheet_tag }}
{{ 'bb-palm-shadow.css' | asset_url | stylesheet_tag }}
{{ 'bb-contact-page.css' | asset_url | stylesheet_tag }}
{{ 'bb-page-images.css' | asset_url | stylesheet_tag }}

<div class="bb-contact-page" id="bb-contact-page-{{ section.id }}" style="--bb-contact-hero-min: {{ section.settings.hero_min_height | default: 22 }}rem; --bb-contact-hero-image-min-mobile: {{ section.settings.hero_image_height_mobile | default: 220 }}px; --bb-contact-form-offset-y: {{ section.settings.form_offset_y | default: 0 }}px;">
  <div class="bb-contact-hero">
    <div class="bb-contact-hero__image">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 900 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 990px) 50vw, 100vw"
          alt="{{ section.settings.hero_image.alt | default: 'Bikini Booth store' | escape }}"
          width="{{ section.settings.hero_image.width | default: 900 }}"
          height="{{ section.settings.hero_image.height | default: 1125 }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>
    <div class="bb-contact-hero__form-wrap">
      {%- render 'bb-contact-hero-leaves', section: section -%}
      <div class="bb-contact-form-panel">
        {%- if section.settings.form_heading != blank -%}
          <h1 class="bb-contact-form-panel__title">{{ section.settings.form_heading | escape }}</h1>
        {%- endif -%}
        {%- render 'bb-star-divider' -%}
        {%- if section.settings.form_intro != blank -%}
          <p class="bb-contact-form-panel__intro">{{ section.settings.form_intro | escape }}</p>
        {%- endif -%}

        {%- form 'contact', class: 'bb-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <p class="bb-contact-form__status" tabindex="-1">{{ 'templates.contact.form.post_success' | t }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="bb-contact-form__errors">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div class="field field-with-icon">
            <input
              class="field__input"
              autocomplete="name"
              type="text"
              id="ContactForm-name-{{ section.id }}"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'templates.contact.form.name' | t }}"
              required
            >
            <label class="field__label" for="ContactForm-name-{{ section.id }}">{{ 'templates.contact.form.name' | t }}</label>
            <div class="field__icon">{{- 'icon-account' | append: settings.system_icon_thickness | inline_asset_content -}}</div>
          </div>

          <div class="field field-with-icon">
            <input
              class="field__input"
              autocomplete="email"
              type="email"
              id="ContactForm-email-{{ section.id }}"
              name="contact[email]"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              placeholder="{{ 'templates.contact.form.email' | t }}"
              required
            >
            <label class="field__label" for="ContactForm-email-{{ section.id }}">{{ 'templates.contact.form.email' | t }}</label>
            <div class="field__icon">{{- 'icon-mail' | append: settings.system_icon_thickness | inline_asset_content -}}</div>
          </div>

          <div class="field field-with-icon field--comment field--text-area">
            <textarea
              class="field__input text-area"
              id="ContactForm-body-{{ section.id }}"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.comment' | t }}"
              rows="4"
              required
            >{{- form.body -}}</textarea>
            <label class="field__label" for="ContactForm-body-{{ section.id }}">{{ 'templates.contact.form.comment' | t }}</label>
            <div class="field__icon field__icon--comment">{{- 'icon-chat' | append: settings.system_icon_thickness | inline_asset_content -}}</div>
          </div>

          <div class="bb-contact-form__submit-wrap">
            <button type="submit" class="bb-contact-form__submit">{{ section.settings.submit_label | default: 'SEND' | escape }}</button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>

  <div class="bb-contact-section-rule-wrap">
    {%- render 'bb-contact-section-rule' -%}
  </div>

  <section class="bb-contact-stores" id="find-us">
    <div class="bb-contact-stores__inner">
      {%- if section.settings.stores_eyebrow != blank -%}
        <span class="bb-contact-stores__eyebrow">{{ section.settings.stores_eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.stores_heading != blank -%}
        <h2 class="bb-contact-stores__title">{{ section.settings.stores_heading | escape }}</h2>
      {%- endif -%}
      {%- render 'bb-star-divider' -%}

      <div class="bb-contact-stores__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'store' -%}
            <article class="bb-contact-store" {{ block.shopify_attributes }}>
              <div class="bb-contact-store__img">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="{{ block.settings.image | image_url: width: 480 }} 480w, {{ block.settings.image | image_url: width: 640 }} 640w, {{ block.settings.image | image_url: width: 800 }} 800w"
                    sizes="(min-width: 990px) calc((min(1280px, 100vw - 3rem) - 2.5rem) / 3), 38vw"
                    alt="{{ block.settings.city | escape }}"
                    loading="lazy"
                    width="800"
                    height="533"
                  >
                {%- elsif block.settings.image_url != blank -%}
                  <img src="{{ block.settings.image_url }}" alt="{{ block.settings.city | escape }}" loading="lazy" width="600" height="400">
                {%- endif -%}
              </div>
              <div class="bb-contact-store__body">
                <div class="bb-contact-store__main">
                {%- if block.settings.city != blank -%}
                  <h3 class="bb-contact-store__city">{{ block.settings.city | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.address != blank -%}
                  <p class="bb-contact-store__meta bb-contact-store__meta--address">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
                    <span>{{ block.settings.address | escape }}</span>
                  </p>
                {%- endif -%}
              </div>
              <div class="bb-contact-store__footer">
                {%- if block.settings.hours != blank -%}
                  <p class="bb-contact-store__meta bb-contact-store__meta--hours">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <span>{{ block.settings.hours | escape }}</span>
                  </p>
                {%- endif -%}
                {%- if block.settings.directions_url != blank -%}
                  <a class="bb-contact-store__dir" href="{{ block.settings.directions_url }}" rel="noopener" target="_blank">Get Directions →</a>
                {%- endif -%}
              </div>
              {%- render 'bb-contact-store-leaf' -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "BB Contact Page",
  "tag": "section",
  "class": "bb-contact-page-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Hero layout"
    },
    {
      "type": "range",
      "id": "hero_min_height",
      "min": 18,
      "max": 44,
      "step": 1,
      "unit": "rem",
      "label": "Hero height (desktop)",
      "default": 22
    },
    {
      "type": "range",
      "id": "hero_image_height_mobile",
      "min": 160,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Hero image height (mobile)",
      "default": 220
    },
    {
      "type": "range",
      "id": "form_offset_y",
      "min": -80,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Form vertical position (nudge up/down)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Palm leaf 1 (large frond)"
    },
    {
      "type": "range",
      "id": "leaf_1_offset_x",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Leaf 1 - X (distance from right edge)",
      "default": 20
    },
    {
      "type": "range",
      "id": "leaf_1_offset_y",
      "min": 0,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Leaf 1 - Y (distance from top)",
      "default": 4
    },
    {
      "type": "range",
      "id": "leaf_1_size",
      "min": 80,
      "max": 480,
      "step": 4,
      "unit": "px",
      "label": "Leaf 1 - size",
      "default": 200
    },
    {
      "type": "range",
      "id": "leaf_1_rotate",
      "min": -180,
      "max": 180,
      "step": 4,
      "unit": "deg",
      "label": "Leaf 1 - rotation",
      "default": 0
    },
    {
      "type": "range",
      "id": "leaf_1_opacity",
      "min": 5,
      "max": 35,
      "step": 1,
      "unit": "%",
      "label": "Leaf 1 - opacity",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "leaf_1_flip",
      "label": "Leaf 1 - flip horizontally",
      "default": false
    },
    {
      "type": "header",
      "content": "Palm leaf 2 (small frond)"
    },
    {
      "type": "range",
      "id": "leaf_2_offset_x",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Leaf 2 - X (distance from right edge)",
      "default": 52
    },
    {
      "type": "range",
      "id": "leaf_2_offset_y",
      "min": 0,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Leaf 2 - Y (distance from top)",
      "default": 64
    },
    {
      "type": "range",
      "id": "leaf_2_size",
      "min": 60,
      "max": 400,
      "step": 4,
      "unit": "px",
      "label": "Leaf 2 - size",
      "default": 148
    },
    {
      "type": "range",
      "id": "leaf_2_rotate",
      "min": -180,
      "max": 180,
      "step": 4,
      "unit": "deg",
      "label": "Leaf 2 - rotation",
      "default": -8
    },
    {
      "type": "range",
      "id": "leaf_2_opacity",
      "min": 5,
      "max": 35,
      "step": 1,
      "unit": "%",
      "label": "Leaf 2 - opacity",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "leaf_2_flip",
      "label": "Leaf 2 - flip horizontally",
      "default": false
    },
    {
      "type": "header",
      "content": "Form content"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "form_intro",
      "label": "Form intro",
      "default": "We're here to help! Whether you have a question about our swimwear, resortwear, sizing, store locations, or an order, our team will get back to you as soon as possible."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "SEND"
    },
    {
      "type": "text",
      "id": "stores_eyebrow",
      "label": "Stores eyebrow",
      "default": "FIND US"
    },
    {
      "type": "text",
      "id": "stores_heading",
      "label": "Stores heading",
      "default": "Phuket · Koh Samui · Koh Phangan"
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL fallback" },
        { "type": "text", "id": "city", "label": "City", "default": "Phuket" },
        { "type": "textarea", "id": "address", "label": "Address" },
        { "type": "text", "id": "hours", "label": "Hours", "default": "Daily · 10am – 10pm" },
        { "type": "url", "id": "directions_url", "label": "Directions URL" }
      ]
    }
  ],
  "presets": [{ "name": "BB Contact Page" }]
}
{% endschema %}
