{%- comment -%}
  Section: main-product.liquid
  Purpose: Full product page layout for Bikini Booth.

  Layout:
    Desktop — two-column grid:
      Left:  product gallery (sticky) + social proof below
      Right: purchase form + complete the look + accordions

    Mobile — single column:
      Gallery → purchase form → social proof → complete the look → accordions

  Snippets rendered:
    bb-product-auto-connect   — JS engine, fires bb:productDataReady
    bb-product-form           — piece toggle, swatches, sizes, ATC, trust, fit note
    bb-product-social-proof   — UGC grid + review
    bb-product-complete-the-look — checklist desktop / card scroll mobile
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="bb-pdp" id="bb-pdp-{{ section.id }}">

  {%- comment -%} ── Top grid: gallery + form ── {%- endcomment -%}
  <div class="bb-pdp__top">

    {%- comment -%} Gallery {%- endcomment -%}
    <div class="bb-pdp__gallery" id="bb-gallery-{{ section.id }}">
      <div class="bb-pdp__gallery-main" id="bb-gallery-main">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images -%}
            <div
              class="bb-pdp__slide{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
              aria-hidden="{%- if forloop.first -%}false{%- else -%}true{%- endif -%}"
            >
              <img
                src="{{ image | image_url: width: 900 }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="{%- if forloop.first -%}eager{%- else -%}lazy{%- endif -%}"
                class="bb-pdp__slide-img"
              >
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="bb-pdp__slide is-active bb-pdp__slide--empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c0b4a8" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}

        <button class="bb-pdp__zoom-btn" id="bb-zoom-{{ section.id }}" aria-label="Zoom image">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>

        {%- comment -%} Mobile dots {%- endcomment -%}
        {%- if product.images.size > 1 -%}
          <div class="bb-pdp__dots" aria-hidden="true">
            {%- for image in product.images -%}
              <div class="bb-pdp__dot{%- if forloop.first %} is-active{%- endif -%}" data-index="{{ forloop.index0 }}"></div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Thumbnail strip {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <div class="bb-pdp__thumbs" role="tablist" aria-label="Product images">
          {%- for image in product.images -%}
            <button
              type="button"
              class="bb-pdp__thumb{%- if forloop.first %} is-active{%- endif -%}"
              role="tab"
              aria-selected="{%- if forloop.first -%}true{%- else -%}false{%- endif -%}"
              aria-label="View image {{ forloop.index }}"
              data-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 120, height: 150, crop: 'center' }}"
                alt="{{ image.alt | escape | default: product.title }}"
                width="60"
                height="75"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Purchase form {%- endcomment -%}
    <div class="bb-pdp__form-col">
      {% render 'bb-product-auto-connect' %}
      {% render 'bb-product-form' %}
    </div>

  </div>

  {%- comment -%} ── Bottom grid: social proof + right column ── {%- endcomment -%}
  <div class="bb-pdp__bottom">

    <div class="bb-pdp__social-col">
      {% render 'bb-product-social-proof' %}
    </div>

    <div class="bb-pdp__right-col">
      {% render 'bb-product-complete-the-look' %}

      {%- comment -%} Accordions {%- endcomment -%}
      <div class="bb-pdp__accordions">

        {%- if product.description != blank -%}
          <div class="bb-acc" data-acc>
            <button type="button" class="bb-acc__btn" aria-expanded="true" aria-controls="bb-acc-details-{{ section.id }}">
              <span>Details</span>
              <svg class="bb-acc__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <div class="bb-acc__body" id="bb-acc-details-{{ section.id }}">
              <div class="bb-acc__content">{{ product.description }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.care_instructions != blank -%}
          <div class="bb-acc" data-acc>
            <button type="button" class="bb-acc__btn" aria-expanded="false" aria-controls="bb-acc-care-{{ section.id }}">
              <span>Care & composition</span>
              <svg class="bb-acc__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="bb-acc__body bb-acc__body--closed" id="bb-acc-care-{{ section.id }}">
              <div class="bb-acc__content">{{ section.settings.care_instructions }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.shipping_info != blank -%}
          <div class="bb-acc" data-acc>
            <button type="button" class="bb-acc__btn" aria-expanded="false" aria-controls="bb-acc-shipping-{{ section.id }}">
              <span>Shipping & returns</span>
              <svg class="bb-acc__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="bb-acc__body bb-acc__body--closed" id="bb-acc-shipping-{{ section.id }}">
              <div class="bb-acc__content">{{ section.settings.shipping_info }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <div class="bb-acc" data-acc {{ block.shopify_attributes }}>
              <button type="button" class="bb-acc__btn" aria-expanded="false" aria-controls="bb-acc-block-{{ block.id }}">
                <span>{{ block.settings.acc_title }}</span>
                <svg class="bb-acc__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="bb-acc__body bb-acc__body--closed" id="bb-acc-block-{{ block.id }}">
                <div class="bb-acc__content">{{ block.settings.acc_content }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>

  </div>

</div>

{%- comment -%} Size chart modal {%- endcomment -%}
{% render 'size-chart-modal' %}


<style>
  #bb-pdp-{{ section.id }} {
    background: #faf8f4;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Top grid ── */
  #bb-pdp-{{ section.id }} .bb-pdp__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
    border-bottom: 0.5px solid #e8e4dd;
  }

  /* Gallery */
  #bb-pdp-{{ section.id }} .bb-pdp__gallery {
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__gallery-main {
    position: relative;
    flex: 1;
    background: #f0ece6;
    overflow: hidden;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__slide.is-active { opacity: 1; pointer-events: auto; }
  #bb-pdp-{{ section.id }} .bb-pdp__slide--empty { background: #f0ece6; }

  #bb-pdp-{{ section.id }} .bb-pdp__slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__zoom-btn {
    position: absolute;
    top: 12px; right: 12px;
    width: 30px; height: 30px;
    background: rgba(255,255,255,0.92);
    border: 0.5px solid #e0dbd3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #2a2520;
    transition: background 0.15s;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__zoom-btn:hover { background: #ffffff; }

  #bb-pdp-{{ section.id }} .bb-pdp__dots {
    position: absolute;
    bottom: 10px; left: 0; right: 0;
    display: none;
    justify-content: center;
    gap: 5px;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.55);
    transition: background 0.2s, width 0.2s;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__dot.is-active {
    background: #ffffff;
    width: 14px;
    border-radius: 3px;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__thumbs {
    display: flex;
    gap: 5px;
    padding: 8px 12px;
    background: #f0ece6;
    border-top: 0.5px solid #e0d8cf;
    overflow-x: auto;
    scrollbar-width: none;
    flex-shrink: 0;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__thumbs::-webkit-scrollbar { display: none; }

  #bb-pdp-{{ section.id }} .bb-pdp__thumb {
    width: 48px; height: 58px;
    border-radius: 4px;
    overflow: hidden;
    border: 1.5px solid transparent;
    background: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s;
  }
  #bb-pdp-{{ section.id }} .bb-pdp__thumb.is-active { border-color: #49c6be; }
  #bb-pdp-{{ section.id }} .bb-pdp__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Form column */
  #bb-pdp-{{ section.id }} .bb-pdp__form-col {
    border-left: 0.5px solid #e8e4dd;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    max-height: 100vh;
  }

  /* ── Bottom grid ── */
  #bb-pdp-{{ section.id }} .bb-pdp__bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__social-col {
    border-right: 0.5px solid #e8e4dd;
  }

  #bb-pdp-{{ section.id }} .bb-pdp__right-col {
    background: #ffffff;
    display: flex;
    flex-direction: column;
  }

  /* Accordions */
  #bb-pdp-{{ section.id }} .bb-pdp__accordions {
    padding: 0 20px 28px;
    border-top: 0.5px solid #e8e4dd;
  }

  #bb-pdp-{{ section.id }} .bb-acc { border-bottom: 0.5px solid #f0ece6; }

  #bb-pdp-{{ section.id }} .bb-acc__btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2a2520;
    text-align: left;
  }

  #bb-pdp-{{ section.id }} .bb-acc__icon { color: #8a8077; flex-shrink: 0; transition: transform 0.2s ease; }
  #bb-pdp-{{ section.id }} .bb-acc__btn[aria-expanded="true"] .bb-acc__icon { transform: rotate(180deg); }

  #bb-pdp-{{ section.id }} .bb-acc__body { overflow: hidden; transition: max-height 0.25s ease; max-height: 600px; }
  #bb-pdp-{{ section.id }} .bb-acc__body--closed { max-height: 0; }

  #bb-pdp-{{ section.id }} .bb-acc__content {
    padding-bottom: 14px;
    font-size: 0.6875rem;
    color: #6a6560;
    line-height: 1.7;
  }
  #bb-pdp-{{ section.id }} .bb-acc__content p { margin: 0 0 8px; }
  #bb-pdp-{{ section.id }} .bb-acc__content p:last-child { margin-bottom: 0; }
  #bb-pdp-{{ section.id }} .bb-acc__content ul { padding-left: 16px; margin: 0; }
  #bb-pdp-{{ section.id }} .bb-acc__content li { margin-bottom: 4px; }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    #bb-pdp-{{ section.id }} .bb-pdp__top { grid-template-columns: 1fr; min-height: auto; }
    #bb-pdp-{{ section.id }} .bb-pdp__gallery { position: relative; max-height: none; top: auto; }
    #bb-pdp-{{ section.id }} .bb-pdp__gallery-main { min-height: 320px; }
    #bb-pdp-{{ section.id }} .bb-pdp__dots { display: flex; }
    #bb-pdp-{{ section.id }} .bb-pdp__form-col { border-left: none; border-top: 0.5px solid #e8e4dd; max-height: none; overflow-y: visible; }
    #bb-pdp-{{ section.id }} .bb-pdp__bottom { grid-template-columns: 1fr; }
    #bb-pdp-{{ section.id }} .bb-pdp__social-col { border-right: none; }
    #bb-pdp-{{ section.id }} .bb-pdp__right-col { border-top: 0.5px solid #e8e4dd; }
    #bb-pdp-{{ section.id }} .bb-pdp__thumbs { display: none; }
    #bb-pdp-{{ section.id }} .bb-pdp__accordions { padding: 0 14px 24px; }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    #bb-pdp-{{ section.id }} .bb-pdp__gallery-main { min-height: 420px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #bb-pdp-{{ section.id }} .bb-pdp__slide { transition: none; }
    #bb-pdp-{{ section.id }} .bb-acc__body { transition: none; }
  }
</style>


<script>
(function () {
  'use strict';

  var pdp = document.getElementById('bb-pdp-{{ section.id }}');
  if (!pdp) return;

  /* ── Gallery ── */
  var slides    = pdp.querySelectorAll('.bb-pdp__slide');
  var thumbBtns = pdp.querySelectorAll('.bb-pdp__thumb');
  var dots      = pdp.querySelectorAll('.bb-pdp__dot');
  var mainEl    = pdp.querySelector('.bb-pdp__gallery-main');
  var activeIdx = 0;

  function goToSlide(idx) {
    slides.forEach(function (s, i) {
      s.classList.toggle('is-active', i === idx);
      s.setAttribute('aria-hidden', i !== idx ? 'true' : 'false');
    });
    thumbBtns.forEach(function (t, i) {
      t.classList.toggle('is-active', i === idx);
      t.setAttribute('aria-selected', i === idx ? 'true' : 'false');
    });
    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
    activeIdx = idx;
  }

  thumbBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      goToSlide(parseInt(btn.dataset.index, 10));
    });
  });

  /* Mobile swipe */
  if (mainEl) {
    var touchStartX = 0;
    mainEl.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    mainEl.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) < 40) return;
      if (dx < 0 && activeIdx < slides.length - 1) goToSlide(activeIdx + 1);
      if (dx > 0 && activeIdx > 0) goToSlide(activeIdx - 1);
    }, { passive: true });
  }

  /* Zoom — open full-screen image */
  var zoomBtn = document.getElementById('bb-zoom-{{ section.id }}');
  if (zoomBtn) {
    zoomBtn.addEventListener('click', function () {
      var activeSlide = pdp.querySelector('.bb-pdp__slide.is-active img');
      if (!activeSlide) return;
      var overlay = document.createElement('div');
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:zoom-out;';
      var img = document.createElement('img');
      img.src = activeSlide.src.replace(/width=\d+/, 'width=1600');
      img.style.cssText = 'max-width:90vw;max-height:90vh;object-fit:contain;';
      img.alt = activeSlide.alt;
      overlay.appendChild(img);
      document.body.appendChild(overlay);
      overlay.addEventListener('click', function () { overlay.remove(); });
      document.addEventListener('keydown', function esc(e) {
        if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', esc); }
      });
    });
  }

  /* ── Accordions ── */
  pdp.querySelectorAll('[data-acc]').forEach(function (acc) {
    var btn  = acc.querySelector('.bb-acc__btn');
    var body = acc.querySelector('.bb-acc__body');
    var icon = acc.querySelector('.bb-acc__icon');
    if (!btn || !body) return;

    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', !expanded ? 'true' : 'false');
      body.classList.toggle('bb-acc__body--closed', expanded);
    });
  });

})();
</script>


{% schema %}
{
  "name": "Product page",
  "tag": "section",
  "class": "bb-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Product form"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Price note",
      "default": "Top and bottom sold separately."
    },
    {
      "type": "url",
      "id": "ask_question_url",
      "label": "Ask a question URL"
    },
    {
      "type": "header",
      "content": "Fit note"
    },
    {
      "type": "richtext",
      "id": "fit_note",
      "label": "Fit note text",
      "info": "Shown below the trust bar. Leave blank to hide."
    },
    {
      "type": "image_picker",
      "id": "fit_note_image",
      "label": "Fit note model image"
    },
    {
      "type": "header",
      "content": "Product details accordions"
    },
    {
      "type": "richtext",
      "id": "care_instructions",
      "label": "Care & composition",
      "default": "<p>Rinse thoroughly in cold water after each use and dry flat or hang in the shade. Hand wash only with a small amount of mild detergent. Do not machine wash, tumble dry, bleach, iron, or dry clean.</p>"
    },
    {
      "type": "richtext",
      "id": "shipping_info",
      "label": "Shipping & returns",
      "default": "<p>Free shipping on orders over $250. Flat rate $7 for domestic Thailand orders. International orders ship via DHL or UPS express from Thailand. Returns are not accepted on sale items.</p>"
    },
    {
      "type": "header",
      "content": "Social proof — UGC pool"
    },
    {
      "type": "text",
      "id": "sp_section_title",
      "label": "Section title",
      "default": "As worn by our community"
    },
    {
      "type": "text",
      "id": "sp_section_subtitle",
      "label": "Subtitle",
      "info": "Leave blank to auto-generate from Instagram handle."
    },
    {
      "type": "range",
      "id": "sp_ugc_pool_size",
      "label": "Active pool size",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 10,
      "info": "Number of ugc-001 through ugc-020 files that are active."
    },
    {
      "type": "textarea",
      "id": "sp_ugc_handles",
      "label": "Instagram handles",
      "info": "Comma-separated, one per slot. e.g. @maya_k, @surf.sara, @lila.bkk. Position matches file number.",
      "default": "@bikinibooth, @bikinibooth, @bikinibooth"
    },
    {
      "type": "text",
      "id": "sp_instagram_handle",
      "label": "Brand Instagram handle",
      "default": "@bikinibooth"
    },
    {
      "type": "header",
      "content": "Social proof — Featured review"
    },
    {
      "type": "range",
      "id": "sp_review_rating",
      "label": "Star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "richtext",
      "id": "sp_review_text",
      "label": "Review quote",
      "default": "<p>\"The most flattering bikini I've ever owned. Wore it every day in Koh Samui — the fit is perfect and the fabric holds up beautifully.\"</p>"
    },
    {
      "type": "text",
      "id": "sp_review_author",
      "label": "Reviewer name",
      "default": "Sofia P. — Bangkok"
    },
    {
      "type": "text",
      "id": "sp_review_initials",
      "label": "Reviewer initials (avatar)",
      "default": "SP"
    },
    {
      "type": "checkbox",
      "id": "sp_review_verified",
      "label": "Show verified buyer badge",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "look_item",
      "name": "Complete the look item",
      "settings": [
        {
          "type": "product",
          "id": "ctl_product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "ctl_label",
          "label": "Piece label",
          "info": "e.g. Top, Bottom, Resortwear, Jewellery",
          "default": "Bottom"
        },
        {
          "type": "checkbox",
          "id": "ctl_is_current",
          "label": "This is the current product",
          "default": false,
          "info": "Check for the item that matches the product on this page."
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Custom accordion",
      "settings": [
        {
          "type": "text",
          "id": "acc_title",
          "label": "Title",
          "default": "More information"
        },
        {
          "type": "richtext",
          "id": "acc_content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product page"
    }
  ]
}
{% endschema %}
