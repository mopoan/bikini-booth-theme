{% doc %}
  @prompt
    a slider that pools our Google reviews and match the design theme, please match the fonts of this block ot the website default font
    
    , please add a url filed so each rqadt will be clickable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-google-reviews-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-google-reviews-container-{{ ai_gen_id }} {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-google-reviews-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-google-reviews-title-{{ ai_gen_id }} {
    margin: 0 0 12px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-google-reviews-subtitle-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-google-reviews-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-google-reviews-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-google-reviews-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-google-reviews-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 12px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | times: 1.5 | divided_by: 100.0 }});
  }

  .ai-google-reviews-card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-google-reviews-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: {{ block.settings.avatar_text_color }};
    font-size: 18px;
    flex-shrink: 0;
  }

  .ai-google-reviews-author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-google-reviews-author-name-{{ ai_gen_id }} {
    margin: 0 0 4px;
    font-weight: 600;
    color: {{ block.settings.author_name_color }};
    font-size: 16px;
  }

  .ai-google-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-google-reviews-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-google-reviews-star-empty-{{ ai_gen_id }} {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-google-reviews-google-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .ai-google-reviews-text-{{ ai_gen_id }} {
    color: {{ block.settings.review_text_color }};
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-google-reviews-date-{{ ai_gen_id }} {
    color: {{ block.settings.date_color }};
    font-size: 14px;
    margin: 0;
  }

  .ai-google-reviews-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
  }

  .ai-google-reviews-nav-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    color: {{ block.settings.nav_button_color }};
  }

  .ai-google-reviews-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
  }

  .ai-google-reviews-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-google-reviews-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-google-reviews-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .ai-google-reviews-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-google-reviews-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-google-reviews-empty-state-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-google-reviews-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-google-reviews-card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-google-reviews-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-google-reviews-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<google-reviews-slider-{{ ai_gen_id }}
  class="ai-google-reviews-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-google-reviews-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-google-reviews-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-google-reviews-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-google-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% assign has_reviews = false %}
    {% for i in (1..6) %}
      {% assign review_name_key = 'review_' | append: i | append: '_name' %}
      {% assign review_text_key = 'review_' | append: i | append: '_text' %}
      {% if block.settings[review_name_key] != blank and block.settings[review_text_key] != blank %}
        {% assign has_reviews = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_reviews %}
      <div class="ai-google-reviews-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-google-reviews-track-{{ ai_gen_id }}" data-track>
          {% for i in (1..6) %}
            {% assign review_name_key = 'review_' | append: i | append: '_name' %}
            {% assign review_text_key = 'review_' | append: i | append: '_text' %}
            {% assign review_rating_key = 'review_' | append: i | append: '_rating' %}
            {% assign review_date_key = 'review_' | append: i | append: '_date' %}
            {% assign review_url_key = 'review_' | append: i | append: '_url' %}

            {% assign review_name = block.settings[review_name_key] %}
            {% assign review_text = block.settings[review_text_key] %}
            {% assign review_rating = block.settings[review_rating_key] %}
            {% assign review_date = block.settings[review_date_key] %}
            {% assign review_url = block.settings[review_url_key] %}

            {% if review_name != blank and review_text != blank %}
              {% if review_url != blank %}
                <a href="{{ review_url }}" class="ai-google-reviews-card-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
              {% else %}
                <div class="ai-google-reviews-card-{{ ai_gen_id }}">
              {% endif %}
                <div class="ai-google-reviews-card-header-{{ ai_gen_id }}">
                  <div class="ai-google-reviews-avatar-{{ ai_gen_id }}">
                    {{ review_name | slice: 0 | upcase }}
                  </div>
                  <div class="ai-google-reviews-author-info-{{ ai_gen_id }}">
                    <h3 class="ai-google-reviews-author-name-{{ ai_gen_id }}">{{ review_name }}</h3>
                    <div class="ai-google-reviews-stars-{{ ai_gen_id }}">
                      {% for star in (1..5) %}
                        {% if star <= review_rating %}
                          <svg class="ai-google-reviews-star-{{ ai_gen_id }}" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        {% else %}
                          <svg class="ai-google-reviews-star-{{ ai_gen_id }} ai-google-reviews-star-empty-{{ ai_gen_id }}" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                  <svg class="ai-google-reviews-google-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                </div>
                <p class="ai-google-reviews-text-{{ ai_gen_id }}">{{ review_text }}</p>
                {% if review_date != blank %}
                  <p class="ai-google-reviews-date-{{ ai_gen_id }}">{{ review_date }}</p>
                {% endif %}
              {% if review_url != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ai-google-reviews-controls-{{ ai_gen_id }}">
        <button
          class="ai-google-reviews-nav-button-{{ ai_gen_id }}"
          data-prev
          aria-label="Previous reviews"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 16L6 10L12 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="ai-google-reviews-dots-{{ ai_gen_id }}" data-dots></div>
        <button
          class="ai-google-reviews-nav-button-{{ ai_gen_id }}"
          data-next
          aria-label="Next reviews"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 4L14 10L8 16" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% else %}
      <div class="ai-google-reviews-empty-state-{{ ai_gen_id }}">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <p>Add your Google reviews to get started</p>
      </div>
    {% endif %}
  </div>
</google-reviews-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class GoogleReviewsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        
        if (!this.track) return;

        this.cards = Array.from(this.track.children);
        this.totalCards = this.cards.length;
        
        if (this.totalCards === 0) return;

        this.updateCardsPerView();
        this.createDots();
        this.setupEventListeners();
        this.updateSlider();
        
        if ({{ block.settings.autoplay | json }}) {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.createDots();
          this.updateSlider();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = 1;
        } else if (width <= 989) {
          this.cardsPerView = 2;
        } else {
          this.cardsPerView = 3;
        }
        this.totalSlides = Math.max(1, this.totalCards - this.cardsPerView + 1);
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-google-reviews-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
        
        this.dots = Array.from(this.dotsContainer.children);
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if ({{ block.settings.autoplay | json }}) {
            this.startAutoplay();
          }
        });
      }

      prev() {
        this.currentIndex = Math.max(0, this.currentIndex - 1);
        this.updateSlider();
      }

      next() {
        this.currentIndex = Math.min(this.totalSlides - 1, this.currentIndex + 1);
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.totalSlides - 1;
        }

        if (this.dots) {
          this.dots.forEach((dot, index) => {
            if (index === this.currentIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          if (this.currentIndex >= this.totalSlides - 1) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateSlider();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('google-reviews-slider-{{ ai_gen_id }}', GoogleReviewsSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
