{% doc %}
  @prompt
    Create an image slider section to replace the BB - Hero section with the following features: an option to set the number of slides, separate image upload options for mobile and desktop versions of each slide, navigation arrows and dot indicators, smooth sliding transitions, and each slide should support a heading, subheading, button text and link. The slider should be fully responsive and show the appropriate image based on device type (mobile or desktop).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slider_height_desktop }}px;
  }

  .ai-hero-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
    height: 100%;
  }

  .ai-hero-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-slider__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
  }

  .ai-hero-slider__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    font-weight: 600;
  }

  .ai-hero-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  .ai-hero-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-hero-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: {{ block.settings.nav_opacity | divided_by: 100.0 }};
  }

  .ai-hero-slider__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_bg_hover_color }};
    color: {{ block.settings.nav_icon_hover_color }};
    opacity: 1;
  }

  .ai-hero-slider__nav--prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-hero-slider__nav--next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-hero-slider__nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-hero-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-hero-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
  }

  .ai-hero-slider__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
  }

  .ai-hero-slider__dot-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-hero-slider__image--mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slider__wrapper-{{ ai_gen_id }} {
      height: max({{ block.settings.slider_height_mobile }}px, 52vh);
      min-height: {{ block.settings.slider_height_mobile }}px;
    }

    .ai-hero-slider__image-{{ ai_gen_id }} {
      object-fit: cover;
      object-position: center top;
    }

    .ai-hero-slider__image--desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-slider__image--mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-slider__content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-hero-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-slider__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-slider__nav-{{ ai_gen_id }} {
      width: {{ block.settings.nav_size | times: 0.8 }}px;
      height: {{ block.settings.nav_size | times: 0.8 }}px;
    }

    .ai-hero-slider__nav--prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-hero-slider__nav--next-{{ ai_gen_id }} {
      right: 10px;
    }

    .ai-hero-slider__dots-{{ ai_gen_id }} {
      bottom: 20px;
    }
  }
{% endstyle %}

<hero-slider-{{ ai_gen_id }} class="ai-hero-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-slider__wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-slider__track-{{ ai_gen_id }}" data-track>
      {% for i in (1..block.settings.number_of_slides) %}
        {% liquid
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign subheading_key = 'slide_' | append: i | append: '_subheading'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'
          assign image_desktop_key = 'slide_' | append: i | append: '_image_desktop'
          assign image_mobile_key = 'slide_' | append: i | append: '_image_mobile'

          assign heading = block.settings[heading_key]
          assign subheading = block.settings[subheading_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign image_desktop = block.settings[image_desktop_key]
          assign image_mobile = block.settings[image_mobile_key]
        %}

        <div class="ai-hero-slider__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          {% if block.settings.show_overlay %}
            <div class="ai-hero-slider__overlay-{{ ai_gen_id }}"></div>
          {% endif %}

          {% if image_desktop %}
            <img
              src="{{ image_desktop | image_url: width: 2000 }}"
              alt="{{ image_desktop.alt | escape }}"
              loading="lazy"
              width="{{ image_desktop.width }}"
              height="{{ image_desktop.height }}"
              class="ai-hero-slider__image-{{ ai_gen_id }} ai-hero-slider__image--desktop-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-hero-slider__image-placeholder-{{ ai_gen_id }} ai-hero-slider__image--desktop-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if image_mobile %}
            <img
              src="{{ image_mobile | image_url: width: 1000 }}"
              alt="{{ image_mobile.alt | escape }}"
              loading="lazy"
              width="{{ image_mobile.width }}"
              height="{{ image_mobile.height }}"
              class="ai-hero-slider__image-{{ ai_gen_id }} ai-hero-slider__image--mobile-{{ ai_gen_id }}"
            >
          {% elsif image_desktop %}
            <img
              src="{{ image_desktop | image_url: width: 1000 }}"
              alt="{{ image_desktop.alt | escape }}"
              loading="lazy"
              width="{{ image_desktop.width }}"
              height="{{ image_desktop.height }}"
              class="ai-hero-slider__image-{{ ai_gen_id }} ai-hero-slider__image--mobile-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-hero-slider__image-placeholder-{{ ai_gen_id }} ai-hero-slider__image--mobile-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-hero-slider__content-{{ ai_gen_id }}">
            {% if heading != blank %}
              <h2 class="ai-hero-slider__heading-{{ ai_gen_id }}">{{ heading }}</h2>
            {% endif %}

            {% if subheading != blank %}
              <p class="ai-hero-slider__subheading-{{ ai_gen_id }}">{{ subheading }}</p>
            {% endif %}

            {% if button_text != blank %}
              <a href="{{ button_link }}" class="ai-hero-slider__button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if block.settings.show_arrows and block.settings.number_of_slides > 1 %}
      <button class="ai-hero-slider__nav-{{ ai_gen_id }} ai-hero-slider__nav--prev-{{ ai_gen_id }}" data-prev aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-hero-slider__nav-{{ ai_gen_id }} ai-hero-slider__nav--next-{{ ai_gen_id }}" data-next aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots and block.settings.number_of_slides > 1 %}
      <div class="ai-hero-slider__dots-{{ ai_gen_id }}" data-dots>
        {% for i in (1..block.settings.number_of_slides) %}
          <button 
            class="ai-hero-slider__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" 
            data-dot="{{ i }}"
            aria-label="Go to slide {{ i }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</hero-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = {{ block.settings.number_of_slides }};
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplaySpeed = {{ block.settings.autoplay_speed | times: 1000 }};
        this.autoplayTimer = null;
      }

      connectedCallback() {
        if (this.totalSlides <= 1) return;

        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dots = this.querySelectorAll('[data-dot]');

        this.setupEventListeners();
        
        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        this.updateSlider();
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        if (this.autoplay) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      startAutoplay() {
        this.autoplayTimer = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-slider-{{ ai_gen_id }}', HeroSlider{{ ai_gen_id }});
  })();
</script>

