{%- comment -%}
  ============================================================
  Bikini Booth — Icon Library  (snippets/bb-icon.liquid)
  ============================================================
  ONE entry point for every icon in the theme. Two formats,
  chosen automatically by name so call sites never care:

    • SVG line icons  → inline, recolour with CSS `color`
        wave · delivery · chevron · plus · minus · trash
        lock · shield · returns · store
    • PNG illustrations → detailed brand art (assets/bb-icon-*.png)
        note · flower · palm · island · leaves · shell · starfish

  USAGE
    {% render 'bb-icon', icon: 'chevron', size: 20 %}
    {% render 'bb-icon', icon: 'shell',   size: 56 %}
    {% render 'bb-icon', icon: 'trash',   size: 18, class: 'cart-remove__icon' %}
    {% render 'bb-icon', icon: 'island',  size: 120, alt: 'Tropical island' %}

  PARAMETERS
    icon  (required)  name from the lists above
    size  (optional)  rendered width in px (height auto). Default 48.
                      UI icons typically 18–24; illustrations 48–140.
    class (optional)  extra class(es)
    alt   (optional)  accessible label. Blank = decorative → hidden
                      from screen readers.

  Recolour an SVG icon by setting `color` on it or a parent:
    .cart-remove__icon{ color: var(--muted); }

  Base rule (add once to your stylesheet):
    .bb-icon{display:inline-block;vertical-align:middle;pointer-events:none;}

  NOTE: supersedes the old `bb-cart-decorative-icons` snippet.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign bb_icon  = icon  | default: '' | strip | downcase
  assign bb_size  = size  | default: 48
  assign bb_cls   = class | default: ''
  assign bb_label = alt   | default: ''
  assign bb_png   = 'note,flower,palm,island,leaves,shell,starfish' | split: ','
-%}

{%- capture bb_a -%}{% if bb_label == blank %}aria-hidden="true" focusable="false"{% else %}role="img" aria-label="{{ bb_label | escape }}" focusable="false"{% endif %}{%- endcapture -%}
{%- capture bb_attr -%}class="bb-icon bb-icon--{{ bb_icon }}{% if bb_cls != blank %} {{ bb_cls }}{% endif %}" style="width:{{ bb_size }}px;height:auto;" {{ bb_a }}{%- endcapture -%}

{%- if bb_png contains bb_icon -%}
  {%- assign bb_file = 'bb-icon-' | append: bb_icon | append: '.png' -%}
  <img class="bb-icon bb-icon--{{ bb_icon }}{% if bb_cls != blank %} {{ bb_cls }}{% endif %}"
       src="{{ bb_file | asset_url }}" alt="{{ bb_label | escape }}"
       {% if bb_label == blank %}aria-hidden="true"{% endif %}
       loading="lazy" decoding="async" style="width:{{ bb_size }}px;height:auto;">

{%- else -%}
  {%- case bb_icon -%}

    {%- when 'wave' -%}
      <svg {{ bb_attr }} viewBox="0 0 64 12" fill="none">
        <path d="M2 7c4-6 8-6 12 0s8 6 12 0 8-6 12 0 8 6 12 0 8-6 12 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>

    {%- when 'delivery' -%}
      <svg {{ bb_attr }} viewBox="0 0 32 24" fill="none">
        <path d="M2 4h14v12H2zM16 8h7l5 5v3h-12z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="9" cy="19" r="2.4" stroke="currentColor" stroke-width="2"/>
        <circle cx="23" cy="19" r="2.4" stroke="currentColor" stroke-width="2"/>
        <path d="M2 16h4M27 16h3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>

    {%- when 'chevron' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

    {%- when 'plus' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>

    {%- when 'minus' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>

    {%- when 'trash' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M4 7h16M9 7V4h6v3M6 7l1 13h10l1-13M10 11v6M14 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

    {%- when 'lock' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/>
        <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>

    {%- when 'shield' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

    {%- when 'returns' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M4 12a8 8 0 1 1 2.3 5.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M4 7v5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

    {%- when 'store' -%}
      <svg {{ bb_attr }} viewBox="0 0 24 24" fill="none">
        <path d="M4 9l1.4-5h13.2L20 9M4 9h16M4 9v0a3 3 0 0 0 6 0 3 3 0 0 0 6 0 3 3 0 0 0 4 0M5 11v9h14v-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 20v-5h4v5" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      </svg>

  {%- endcase -%}
{%- endif -%}
