{%- comment -%}
  Section: product-media.liquid
  Purpose: Product image gallery — 9:16 portrait stage, vertical thumbnail strip
           on desktop left, dot navigation on mobile.
  Injects: bb-product-layout snippet for two-column page grid.
{%- endcomment -%}

{% render 'bb-product-layout' %}

{%- assign thumb_position = section.settings.thumb_position -%}
{%- assign image_fit      = section.settings.image_fit -%}
{%- assign bg_color       = section.settings.bg_color -%}
{%- assign border_radius  = section.settings.border_radius -%}
{%- assign enable_zoom    = section.settings.enable_zoom -%}
{%- assign enable_dots    = section.settings.enable_dots -%}
{%- assign sticky         = section.settings.sticky_gallery -%}

{%- comment -%} Video settings {%- endcomment -%}
{%- assign vid_autoplay   = section.settings.video_autoplay -%}
{%- assign vid_loop       = section.settings.video_loop -%}
{%- assign vid_muted      = section.settings.video_muted -%}
{%- assign vid_controls   = section.settings.video_controls -%}
{%- assign vid_show_play  = section.settings.video_custom_playpause -%}
{%- assign vid_show_mute  = section.settings.video_custom_mute -%}
{%- assign vid_thumb_play = section.settings.video_thumb_play_icon -%}

<div
  class="bb-media bb-media--thumbs-{{ thumb_position }}"
  id="bb-media-{{ section.id }}"
  data-zoom="{{ enable_zoom }}"
>

  {%- comment -%} ── Thumbnail strip (desktop left / desktop bottom / hidden) ── {%- endcomment -%}
  {%- if product.media.size > 1 and thumb_position != 'hidden' -%}
    <div
      class="bb-media__thumbs"
      id="bb-media-thumbs-{{ section.id }}"
      role="tablist"
      aria-label="Product media thumbnails"
    >
      {%- assign t_img_i = 0 -%}
      {%- for media in product.media -%}
        {%- assign t_is_video = false -%}
        {%- if media.media_type == 'video' -%}{%- assign t_is_video = true -%}{%- endif -%}
        <button
          type="button"
          class="bb-media__thumb{%- if forloop.first %} is-active{%- endif -%}{%- if t_is_video %} bb-media__thumb--video{%- endif -%}"
          role="tab"
          aria-selected="{%- if forloop.first -%}true{%- else -%}false{%- endif -%}"
          aria-label="{{ media.alt | escape | default: product.title }} — {% if t_is_video %}video{% else %}image{% endif %} {{ forloop.index }}"
          data-index="{{ forloop.index0 }}"
          data-media-index="{{ forloop.index0 }}"
          {%- unless t_is_video %} data-image-index="{{ t_img_i }}"{%- endunless %}
          data-media-type="{{ media.media_type }}"
        >
          <img
            src="{{ media.preview_image | image_url: width: 160, height: 200, crop: 'center' }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="{{ section.settings.thumb_width }}"
            height="{{ section.settings.thumb_height }}"
            loading="lazy"
          >
          {%- if t_is_video and vid_thumb_play -%}
            <span class="bb-media__thumb-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20"/></svg>
            </span>
          {%- endif -%}
        </button>
        {%- unless t_is_video -%}{%- assign t_img_i = t_img_i | plus: 1 -%}{%- endunless -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Main image stage ── {%- endcomment -%}
  <div class="bb-media__stage-wrap">
    <div
      class="bb-media__stage"
      id="bb-media-stage-{{ section.id }}"
      aria-label="Product images"
    >

      {%- if product.media.size > 0 -%}
        {%- assign img_i = 0 -%}
        {%- for media in product.media -%}
          {%- if media.media_type == 'video' -%}
            <div
              class="bb-media__slide bb-media__slide--video{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
              data-media-index="{{ forloop.index0 }}"
              data-media-type="video"
              role="group"
              aria-label="{{ media.alt | escape | default: product.title }} — video {{ forloop.index }} of {{ product.media.size }}"
              aria-hidden="{%- unless forloop.first -%}true{%- else -%}false{%- endunless -%}"
            >
              <video
                class="bb-media__video"
                playsinline
                preload="metadata"
                poster="{{ media.preview_image | image_url: width: 1000 }}"
                {%- if vid_muted %} muted{%- endif -%}
                {%- if vid_loop %} loop{%- endif -%}
                {%- if vid_controls %} controls controlsList="{% if section.settings.video_hide_download %}nodownload {% endif %}{% if section.settings.video_hide_fullscreen %}nofullscreen {% endif %}{% if section.settings.video_hide_remote %}noremoteplayback{% endif %}"{%- endif -%}
                {%- if section.settings.video_hide_remote %} disableremoteplayback{%- endif -%}
              >
                {%- for source in media.sources -%}
                  {%- if source.mime_type contains 'video' -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endif -%}
                {%- endfor -%}
              </video>
              {%- if vid_show_play or vid_show_mute -%}
                <div class="bb-media__vcontrols"{%- if vid_controls %} hidden{%- endif -%}>
                  {%- if vid_show_play -%}
                    <button type="button" class="bb-media__vbtn bb-media__vbtn--play" aria-label="Play video">
                      <svg class="bb-icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20"/></svg>
                      <svg class="bb-icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
                    </button>
                  {%- endif -%}
                  {%- if vid_show_mute -%}
                    <button type="button" class="bb-media__vbtn bb-media__vbtn--mute" aria-label="{% if vid_muted %}Unmute video{% else %}Mute video{% endif %}">
                      <svg class="bb-icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"{%- unless vid_muted %} style="display:none"{%- endunless -%}><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                      <svg class="bb-icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"{%- if vid_muted %} style="display:none"{%- endif -%}><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- else -%}
            <div
              class="bb-media__slide{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
              data-media-index="{{ forloop.index0 }}"
              data-image-index="{{ img_i }}"
              data-media-type="image"
              role="img"
              aria-label="{{ media.alt | escape | default: product.title }} — image {{ forloop.index }} of {{ product.media.size }}"
              aria-hidden="{%- unless forloop.first -%}true{%- else -%}false{%- endunless -%}"
            >
              <img
                src="{{ media.preview_image | image_url: width: 1000 }}"
                srcset="
                  {{ media.preview_image | image_url: width: 480 }}  480w,
                  {{ media.preview_image | image_url: width: 750 }}  750w,
                  {{ media.preview_image | image_url: width: 1000 }} 1000w
                "
                sizes="(max-width: 767px) 100vw, 40vw"
                alt="{{ media.alt | escape | default: product.title }}"
                width="{{ media.preview_image.width }}"
                height="{{ media.preview_image.height }}"
                loading="{%- if forloop.first -%}eager{%- else -%}lazy{%- endif -%}"
                class="bb-media__img"
              >
            </div>
            {%- assign img_i = img_i | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="bb-media__slide is-active bb-media__no-image" data-media-type="none">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c0b4a8" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p>No media</p>
        </div>
      {%- endif -%}

      {%- comment -%} Zoom button (images only; JS hides it on video slides) {%- endcomment -%}
      {%- if enable_zoom and product.media.size > 0 -%}
        <button
          type="button"
          class="bb-media__zoom-btn"
          id="bb-media-zoom-{{ section.id }}"
          aria-label="Zoom image"
          aria-pressed="false"
        >
          <svg class="bb-zoom-in" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          <svg class="bb-zoom-out" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
      {%- endif -%}

      {%- comment -%} Mobile dots {%- endcomment -%}
      {%- if enable_dots and product.media.size > 1 -%}
        <div class="bb-media__dots" aria-hidden="true" id="bb-media-dots-{{ section.id }}">
          {%- for media in product.media -%}
            <div
              class="bb-media__dot{%- if forloop.first %} is-active{%- endif -%}"
              data-index="{{ forloop.index0 }}"
            ></div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} ── Prev / next arrows ── {%- endcomment -%}
    {%- if product.media.size > 1 -%}
      <button type="button" class="bb-media__arrow bb-media__arrow--prev" id="bb-media-prev-{{ section.id }}" aria-label="Previous image">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button type="button" class="bb-media__arrow bb-media__arrow--next" id="bb-media-next-{{ section.id }}" aria-label="Next image">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}
  </div>

</div>


<style>
  /* ── Section wrapper ── */
  #bb-media-{{ section.id }} {
    display: flex !important;
    flex-direction: row !important;
    gap: {{ section.settings.thumb_gap }}px;
    background: {{ bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    align-items: flex-start;
  }

  /* ── Stage wrap fills remaining space ── */
  #bb-media-{{ section.id }} .bb-media__stage-wrap {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  /* ── Prev / next arrows ── */
  #bb-media-{{ section.id }} .bb-media__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #49c6be;
    background: rgba(255, 255, 255, 0.85);
    color: #49c6be;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    z-index: 5;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }
  #bb-media-{{ section.id }} .bb-media__arrow svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  #bb-media-{{ section.id }} .bb-media__arrow:hover {
    background: #49c6be;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(73, 198, 190, 0.35);
  }
  #bb-media-{{ section.id }} .bb-media__arrow--prev { left: 12px; }
  #bb-media-{{ section.id }} .bb-media__arrow--next { right: 12px; }

  /* ── Stage: enforces 9:16 aspect ratio ── */
  #bb-media-{{ section.id }} .bb-media__stage {
    position: relative;
    width: 100%;
    {%- case section.settings.aspect_ratio -%}
      {%- when '9:16' -%}
        aspect-ratio: 9 / 16;
      {%- when '3:4' -%}
        aspect-ratio: 3 / 4;
      {%- when '1:1' -%}
        aspect-ratio: 1 / 1;
      {%- when 'natural' -%}
        aspect-ratio: auto;
        min-height: 400px;
    {%- endcase -%}
    background: {{ bg_color }};
    border-radius: {{ border_radius }}px;
    overflow: hidden;
    cursor: crosshair;
  }

  /* ── Slides (crossfade on desktop, horizontal slide on mobile) ── */
  #bb-media-{{ section.id }} .bb-media__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateX(0);
    transition: transform 0.35s ease, opacity 0.35s ease;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }
  /* Outgoing slide stays opaque while it slides out (mobile) */
  #bb-media-{{ section.id }} .bb-media__slide.is-leaving {
    opacity: 1;
    z-index: 1;
  }

  /* ── Images ── */
  #bb-media-{{ section.id }} .bb-media__img {
    width: 100%;
    height: 100%;
    object-fit: {{ image_fit }};
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
    transform-origin: center center;
  }

  /* ── Video ── */
  #bb-media-{{ section.id }} .bb-media__slide--video {
    background: {{ section.settings.video_bg_color }};
  }
  #bb-media-{{ section.id }} .bb-media__video {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.video_object_fit }};
    object-position: center center;
    display: block;
    background: {{ section.settings.video_bg_color }};
  }
  /* Video slides never use the zoom crosshair */
  #bb-media-{{ section.id }} .bb-media__stage.is-video { cursor: default; }

  /* Custom video controls */
  #bb-media-{{ section.id }} .bb-media__vcontrols {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    gap: 8px;
    z-index: 4;
  }
  #bb-media-{{ section.id }} .bb-media__vcontrols[hidden] { display: none; }
  #bb-media-{{ section.id }} .bb-media__vbtn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #49c6be;
    background: rgba(255, 255, 255, 0.85);
    color: #49c6be;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s ease, color 0.15s ease;
  }
  #bb-media-{{ section.id }} .bb-media__vbtn:hover { background: #49c6be; color: #ffffff; }
  #bb-media-{{ section.id }} .bb-media__vbtn svg { width: 16px; height: 16px; display: block; }

  /* Play icon overlay on video thumbnails */
  #bb-media-{{ section.id }} .bb-media__thumb-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 50%;
    color: #ffffff;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__thumb-play svg { width: 10px; height: 10px; }

  /* Visible focus states */
  #bb-media-{{ section.id }} .bb-media__thumb:focus-visible,
  #bb-media-{{ section.id }} .bb-media__arrow:focus-visible,
  #bb-media-{{ section.id }} .bb-media__vbtn:focus-visible,
  #bb-media-{{ section.id }} .bb-media__zoom-btn:focus-visible {
    outline: 2px solid #49c6be;
    outline-offset: 2px;
  }

  /* ── Hover zoom (desktop) ── */
  @media (hover: hover) {
    #bb-media-{{ section.id }} .bb-media__stage:hover .bb-media__slide.is-active .bb-media__img {
      transform: scale(1.04);
    }
  }

  /* ── Click zoom ── */
  /* Reveal the FULL image when zoomed: switch from the cropped stage fit to
     'contain' so nothing is cut off, then scale + pan to inspect it. */
  #bb-media-{{ section.id }} .bb-media__stage.is-zoomed .bb-media__slide.is-active .bb-media__img {
    transform: scale(1.7);
    object-fit: contain;
    object-position: center center;
    cursor: zoom-out;
  }

  /* ── No image placeholder ── */
  #bb-media-{{ section.id }} .bb-media__no-image {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    opacity: 1;
    pointer-events: none;
  }
  #bb-media-{{ section.id }} .bb-media__no-image p {
    font-size: 0.75rem;
    color: #c0b4a8;
  }

  /* ── Zoom button ── */
  #bb-media-{{ section.id }} .bb-media__zoom-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    background: rgba(255,255,255,0.9);
    border: 0.5px solid #e0dbd3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.15s;
  }
  #bb-media-{{ section.id }} .bb-media__zoom-btn:hover { background: #ffffff; }

  /* ── Mobile dots ── */
  #bb-media-{{ section.id }} .bb-media__dots {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    display: none;
    justify-content: center;
    gap: 5px;
    z-index: 2;
  }
  #bb-media-{{ section.id }} .bb-media__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    transition: background 0.2s, width 0.2s;
    cursor: pointer;
  }
  #bb-media-{{ section.id }} .bb-media__dot.is-active {
    background: #ffffff;
    width: 14px;
    border-radius: 3px;
  }

  /* ── Thumbnail strip — left (desktop default) ── */
  #bb-media-{{ section.id }} .bb-media__thumbs {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.thumb_gap }}px;
    flex-shrink: 0;
    width: {{ section.settings.thumb_width }}px;
    max-height: 80vh;
    overflow-y: auto;
    scrollbar-width: none;
    padding: 2px;
  }
  #bb-media-{{ section.id }} .bb-media__thumbs::-webkit-scrollbar { display: none; }

  /* ── Thumbnail button ── */
  #bb-media-{{ section.id }} .bb-media__thumb {
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ border_radius | divided_by: 2 }}px;
    overflow: hidden;
    border: 1.5px solid transparent;
    background: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s;
    display: block;
    position: relative;
  }
  #bb-media-{{ section.id }} .bb-media__thumb.is-active {
    border-color: #49c6be;
  }
  #bb-media-{{ section.id }} .bb-media__thumb:not(.is-active):hover {
    border-color: #c5e8e6;
  }
  #bb-media-{{ section.id }} .bb-media__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Desktop: left strip matches the main image height and spreads down it ── */
  @media (min-width: 900px) {
    #bb-media-{{ section.id }}.bb-media--thumbs-left .bb-media__thumbs {
      align-self: stretch;
      max-height: none;
    }
  }

  /* ── Bottom thumbnail variant ── */
  #bb-media-{{ section.id }}.bb-media--thumbs-bottom {
    flex-direction: column !important;
  }
  #bb-media-{{ section.id }}.bb-media--thumbs-bottom .bb-media__thumbs {
    flex-direction: row;
    width: 100%;
    max-height: none;
    overflow-x: auto;
    overflow-y: visible;
    height: {{ section.settings.thumb_height }}px;
  }
  #bb-media-{{ section.id }}.bb-media--thumbs-bottom .bb-media__thumb {
    width: auto;
    aspect-ratio: 9 / 16;
    height: 100%;
    flex-shrink: 0;
  }

  /* ── Sticky on desktop ── */
  {%- if sticky -%}
  @media (min-width: 900px) {
    .bb-product-media-section {
      position: sticky;
      top: 0;
      align-self: start;
    }
  }
  {%- endif -%}

  /* ── Mobile ── */
  @media (max-width: 899px) {
    #bb-media-{{ section.id }} {
      flex-direction: column !important;
    }

    {%- unless section.settings.show_thumbs_mobile -%}
    #bb-media-{{ section.id }} .bb-media__thumbs {
      display: none;
    }
    {%- endunless -%}

    #bb-media-{{ section.id }} .bb-media__dots {
      display: flex;
    }

    #bb-media-{{ section.id }} .bb-media__arrow {
      display: {% if section.settings.show_arrows_mobile %}flex{% else %}none{% endif %};
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #bb-media-{{ section.id }} .bb-media__slide,
    #bb-media-{{ section.id }} .bb-media__img {
      transition: none;
    }
  }
</style>


<script>
(function () {
  'use strict';

  var wrap    = document.getElementById('bb-media-{{ section.id }}');
  var stage   = document.getElementById('bb-media-stage-{{ section.id }}');
  var thumbsEl = document.getElementById('bb-media-thumbs-{{ section.id }}');
  var dotsEl  = document.getElementById('bb-media-dots-{{ section.id }}');
  var zoomBtn = document.getElementById('bb-media-zoom-{{ section.id }}');
  if (!wrap || !stage) return;

  var slides  = stage.querySelectorAll('.bb-media__slide');
  var thumbs  = thumbsEl ? thumbsEl.querySelectorAll('.bb-media__thumb') : [];
  var dots    = dotsEl   ? dotsEl.querySelectorAll('.bb-media__dot')     : [];
  var activeIdx = 0;
  var isZoomed  = false;

  /* ── Video config (from theme settings) ── */
  var cfg = {
    autoplay:       {% if section.settings.video_autoplay %}true{% else %}false{% endif %},
    loop:           {% if section.settings.video_loop %}true{% else %}false{% endif %},
    muted:          {% if section.settings.video_muted %}true{% else %}false{% endif %},
    nativeControls: {% if section.settings.video_controls %}true{% else %}false{% endif %},
    pauseInactive:  {% if section.settings.video_pause_inactive %}true{% else %}false{% endif %},
    resetInactive:  {% if section.settings.video_reset_inactive %}true{% else %}false{% endif %}
  };
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var zoomEnabled  = '{{ enable_zoom }}' === 'true';

  /* ── Map image-order index -> slide (media) index, so a legacy bb:requestSlide
     that uses image indices still lands on the right slide once videos exist ── */
  var imageIndexMap = {};
  Array.prototype.forEach.call(slides, function (s, i) {
    var ii = s.getAttribute('data-image-index');
    if (ii !== null) imageIndexMap[parseInt(ii, 10)] = i;
  });
  function imageIndexToSlide(ii) { return (ii in imageIndexMap) ? imageIndexMap[ii] : null; }

  /* ── Media-type helpers ── */
  function slideType(i) { return slides[i] ? slides[i].getAttribute('data-media-type') : null; }
  function activeIsImage() { return slideType(activeIdx) === 'image'; }
  function getVideo(i) { return slides[i] ? slides[i].querySelector('.bb-media__video') : null; }

  /* ── Reflect active media type on the stage (zoom only for images) ── */
  function setStageMode() {
    var isVid = slideType(activeIdx) === 'video';
    stage.classList.toggle('is-video', isVid);
    if (zoomBtn) zoomBtn.style.display = isVid ? 'none' : '';
    if (isVid && isZoomed) setZoom(false);
  }

  /* ── Sync a video's custom control buttons to its current state ── */
  function updateVideoButtons(v) {
    var slide = v.closest('.bb-media__slide');
    if (!slide) return;
    var pb = slide.querySelector('.bb-media__vbtn--play');
    if (pb) {
      var playing = !v.paused;
      pb.setAttribute('aria-label', playing ? 'Pause video' : 'Play video');
      var ip = pb.querySelector('.bb-icon-play'), ipa = pb.querySelector('.bb-icon-pause');
      if (ip)  ip.style.display  = playing ? 'none' : '';
      if (ipa) ipa.style.display = playing ? '' : 'none';
    }
    var mb = slide.querySelector('.bb-media__vbtn--mute');
    if (mb) {
      mb.setAttribute('aria-label', v.muted ? 'Unmute video' : 'Mute video');
      var im = mb.querySelector('.bb-icon-muted'), iu = mb.querySelector('.bb-icon-unmuted');
      if (im) im.style.display = v.muted ? '' : 'none';
      if (iu) iu.style.display = v.muted ? 'none' : '';
    }
  }

  function tryPlay(v) {
    if (cfg.muted) v.muted = true;   /* muted autoplay is the only reliably-allowed kind */
    var p = v.play();
    if (p && p.catch) p.catch(function () {});
  }

  /* ── On slide change: pause (and optionally reset) inactive videos, play the active one ── */
  function manageVideos(prevIdx, newIdx) {
    var pv = getVideo(prevIdx);
    if (pv && prevIdx !== newIdx) {
      pv.pause();
      if (cfg.resetInactive) { try { pv.currentTime = 0; } catch (e) {} }
    }
    if (cfg.pauseInactive) {
      for (var i = 0; i < slides.length; i++) {
        if (i === newIdx) continue;
        var v = getVideo(i);
        if (v && !v.paused) { v.pause(); if (cfg.resetInactive) { try { v.currentTime = 0; } catch (e) {} } }
      }
    }
    var cv = getVideo(newIdx);
    if (cv) {
      if (cfg.autoplay && !reduceMotion) tryPlay(cv);
      updateVideoButtons(cv);
    }
    setStageMode();
  }

  /* ── Slide-change broadcast (index = media/slide index; imageIndex for legacy consumers) ── */
  function dispatchSlideChange() {
    var s = slides[activeIdx];
    var imgAttr = s ? s.getAttribute('data-image-index') : null;
    document.dispatchEvent(new CustomEvent('bb:slideChange', { detail: {
      index: activeIdx,
      mediaIndex: activeIdx,
      imageIndex: imgAttr !== null ? parseInt(imgAttr, 10) : null,
      mediaType: s ? s.getAttribute('data-media-type') : null
    }}));
  }

  /* ── Resolve an external bb:requestSlide payload to a slide index.
     Accepts {mediaIndex}, {imageIndex}, or legacy {index} (historically image order) ── */
  function resolveRequestedIndex(detail) {
    if (!detail) return null;
    if (typeof detail.mediaIndex === 'number') return detail.mediaIndex;
    if (typeof detail.imageIndex === 'number') {
      var m = imageIndexToSlide(detail.imageIndex);
      return m !== null ? m : detail.imageIndex;
    }
    if (typeof detail.index === 'number') {
      var mapped = imageIndexToSlide(detail.index);   /* legacy: treat as image index */
      return mapped !== null ? mapped : detail.index; /* fall back to direct slide index */
    }
    return null;
  }

  /* ── Sync thumbnail + dot active state ── */
  function syncControls(oldIdx, newIdx) {
    if (thumbs[oldIdx]) { thumbs[oldIdx].classList.remove('is-active'); thumbs[oldIdx].setAttribute('aria-selected', 'false'); }
    if (dots[oldIdx])   dots[oldIdx].classList.remove('is-active');
    if (thumbs[newIdx]) {
      thumbs[newIdx].classList.add('is-active');
      thumbs[newIdx].setAttribute('aria-selected', 'true');
      /* Scroll thumbnail into view */
      thumbs[newIdx].scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
    }
    if (dots[newIdx]) dots[newIdx].classList.add('is-active');
  }

  var isAnimating = false;

  /* ── Navigate to slide ──
     Mobile (<=767px): horizontal slide transition + wrap-around (last -> first).
     Desktop: original crossfade, clamped at the ends. ── */
  function goTo(idx, dir) {
    var n = slides.length;
    if (n <= 1) return;
    var mobile = window.matchMedia('(max-width: 767px)').matches;
    idx = (idx % n + n) % n;                          /* wrap -> cycles on desktop + mobile */
    if (idx === activeIdx || isAnimating) return;
    if (dir === undefined) dir = idx > activeIdx ? 1 : -1;

    var oldIdx    = activeIdx;
    var prevSlide = slides[oldIdx];
    var nextSlide = slides[idx];

    if (!mobile) {
      /* Desktop: instant crossfade (unchanged behavior) */
      prevSlide.classList.remove('is-active');
      prevSlide.setAttribute('aria-hidden', 'true');
      activeIdx = idx;
      nextSlide.classList.add('is-active');
      nextSlide.setAttribute('aria-hidden', 'false');
      syncControls(oldIdx, activeIdx);
      manageVideos(oldIdx, activeIdx);
      if (isZoomed) setZoom(false);
      dispatchSlideChange();
      return;
    }

    /* Mobile: slide the new image in from one side, the old one out the other */
    isAnimating = true;
    nextSlide.style.transition = 'none';
    nextSlide.classList.add('is-active');
    nextSlide.setAttribute('aria-hidden', 'false');
    nextSlide.style.transform = 'translateX(' + (dir > 0 ? '100%' : '-100%') + ')';
    void nextSlide.offsetWidth;                        /* force reflow before animating */
    nextSlide.style.transition = '';
    nextSlide.style.transform = 'translateX(0)';

    prevSlide.classList.remove('is-active');
    prevSlide.classList.add('is-leaving');
    prevSlide.setAttribute('aria-hidden', 'true');
    prevSlide.style.transform = 'translateX(' + (dir > 0 ? '-100%' : '100%') + ')';

    activeIdx = idx;
    syncControls(oldIdx, activeIdx);
    manageVideos(oldIdx, activeIdx);

    if (isZoomed) setZoom(false);
    dispatchSlideChange();

    /* Reset the outgoing slide once it has slid out of view */
    setTimeout(function () {
      prevSlide.classList.remove('is-leaving');
      prevSlide.style.transition = 'none';
      prevSlide.style.transform = '';
      void prevSlide.offsetWidth;
      prevSlide.style.transition = '';
      isAnimating = false;
    }, 380);
  }

  function goNext() { goTo(activeIdx + 1, 1); }
  function goPrev() { goTo(activeIdx - 1, -1); }

  /* ── Thumbnail clicks ── */
  Array.from(thumbs).forEach(function (btn) {
    btn.addEventListener('click', function () {
      goTo(parseInt(btn.dataset.index, 10));
    });
  });

  /* ── Dot clicks ── */
  Array.from(dots).forEach(function (dot) {
    dot.addEventListener('click', function () {
      goTo(parseInt(dot.dataset.index, 10));
    });
  });

  /* ── Prev / next arrows ── */
  var prevBtn = document.getElementById('bb-media-prev-{{ section.id }}');
  var nextBtn = document.getElementById('bb-media-next-{{ section.id }}');
  if (prevBtn) prevBtn.addEventListener('click', function (e) { e.stopPropagation(); goPrev(); });
  if (nextBtn) nextBtn.addEventListener('click', function (e) { e.stopPropagation(); goNext(); });

  /* ── Touch swipe ── */
  var startX = 0;
  stage.addEventListener('touchstart', function (e) {
    startX = e.changedTouches[0].clientX;
  }, { passive: true });
  stage.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) < 40) return;
    if (dx < 0) goNext(); else goPrev();
  }, { passive: true });

  /* ── Keyboard navigation ── */
  stage.setAttribute('tabindex', '0');
  stage.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goNext(); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goPrev(); }
  });

  /* ── Zoom ── */
  function setZoom(on) {
    isZoomed = on;
    stage.classList.toggle('is-zoomed', on);
    if (zoomBtn) {
      zoomBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
      zoomBtn.setAttribute('aria-label', on ? 'Zoom out' : 'Zoom image');
      var zIn  = zoomBtn.querySelector('.bb-zoom-in');
      var zOut = zoomBtn.querySelector('.bb-zoom-out');
      if (zIn)  zIn.style.display  = on ? 'none' : '';
      if (zOut) zOut.style.display = on ? ''     : 'none';
    }
    if (!on) {
      var img = stage.querySelector('.bb-media__slide.is-active .bb-media__img');
      if (img) img.style.transformOrigin = 'center center';
    }
  }

  if (zoomBtn) {
    zoomBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      setZoom(!isZoomed);
    });
  }

  stage.addEventListener('click', function (e) {
    if (e.target.closest('.bb-media__zoom-btn')) return;
    if (e.target.closest('.bb-media__dot')) return;
    if (e.target.closest('.bb-media__vbtn')) return;
    if (e.target.closest('.bb-media__video')) return;
    if (!activeIsImage()) return;          /* no zoom on video slides */
    if (zoomEnabled) setZoom(!isZoomed);
  });

  stage.addEventListener('mousemove', function (e) {
    if (!isZoomed || !activeIsImage()) return;
    var img = stage.querySelector('.bb-media__slide.is-active .bb-media__img');
    if (!img) return;
    var rect = stage.getBoundingClientRect();
    img.style.transformOrigin =
      ((e.clientX - rect.left) / rect.width  * 100) + '% ' +
      ((e.clientY - rect.top)  / rect.height * 100) + '%';
  });

  /* ── Document-level listeners use named handlers so they can be removed on
     Shopify section reload — prevents duplicate-listener stacking in the editor ── */
  function onDocKeydown(e) {
    if (e.key === 'Escape' && isZoomed) setZoom(false);
  }
  function onRequestSlide(e) {
    var idx = resolveRequestedIndex(e.detail);
    if (idx !== null) goTo(idx);
  }
  document.addEventListener('keydown', onDocKeydown);
  document.addEventListener('bb:requestSlide', onRequestSlide);

  document.addEventListener('shopify:section:unload', function onUnload(e) {
    if (!e.detail || e.detail.sectionId !== '{{ section.id }}') return;
    document.removeEventListener('keydown', onDocKeydown);
    document.removeEventListener('bb:requestSlide', onRequestSlide);
    document.removeEventListener('shopify:section:unload', onUnload);  /* remove self -> no accumulation */
    Array.prototype.forEach.call(slides, function (s) {
      var v = s.querySelector('.bb-media__video');
      if (v) { try { v.pause(); } catch (err) {} }
    });
  });

  /* ── Wire video custom controls + keep their state in sync ── */
  Array.prototype.forEach.call(stage.querySelectorAll('.bb-media__slide--video'), function (slide) {
    var v = slide.querySelector('.bb-media__video');
    if (!v) return;
    var playBtn = slide.querySelector('.bb-media__vbtn--play');
    var muteBtn = slide.querySelector('.bb-media__vbtn--mute');
    if (playBtn) playBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      if (v.paused) tryPlay(v); else v.pause();
    });
    if (muteBtn) muteBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      v.muted = !v.muted;
      updateVideoButtons(v);
    });
    if (!cfg.nativeControls) {
      v.addEventListener('click', function (e) {
        e.stopPropagation();
        if (v.paused) tryPlay(v); else v.pause();
      });
    }
    v.addEventListener('play',  function () { updateVideoButtons(v); });
    v.addEventListener('pause', function () { updateVideoButtons(v); });
    v.addEventListener('volumechange', function () { updateVideoButtons(v); });
    updateVideoButtons(v);
  });

  /* ── Initial active media: set stage mode, autoplay first slide if it's a video ── */
  setStageMode();
  (function () {
    var v0 = getVideo(activeIdx);
    if (v0 && cfg.autoplay && !reduceMotion) tryPlay(v0);
  })();

})();
</script>


{% schema %}
{
  "name": "Product media",
  "tag": "div",
  "class": "bb-product-media-section",
  "settings": [
    {
      "type": "header",
      "content": "Image display"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Main image aspect ratio",
      "options": [
        { "value": "9:16",    "label": "Portrait 9:16 (recommended)" },
        { "value": "3:4",     "label": "Portrait 3:4" },
        { "value": "1:1",     "label": "Square 1:1" },
        { "value": "natural", "label": "Natural (no fixed ratio)" }
      ],
      "default": "9:16"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (fill frame, may crop)" }
      ],
      "default": "contain"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Image background color",
      "default": "#f0ece6"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image border radius (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 0
    },
    {
      "type": "header",
      "content": "Thumbnails"
    },
    {
      "type": "select",
      "id": "thumb_position",
      "label": "Thumbnail position (desktop)",
      "options": [
        { "value": "left",   "label": "Left of main image" },
        { "value": "bottom", "label": "Below main image" },
        { "value": "hidden", "label": "Hidden" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "thumb_width",
      "label": "Thumbnail width (px)",
      "min": 40,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "thumb_height",
      "label": "Thumbnail height — bottom layout only (px)",
      "min": 50,
      "max": 150,
      "step": 4,
      "default": 82
    },
    {
      "type": "range",
      "id": "thumb_gap",
      "label": "Thumbnail gap (px)",
      "min": 2,
      "max": 16,
      "step": 2,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_thumbs_mobile",
      "label": "Show thumbnails on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "checkbox",
      "id": "sticky_gallery",
      "label": "Sticky gallery on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable image zoom",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_dots",
      "label": "Enable mobile dot indicators",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows_mobile",
      "label": "Show prev/next arrows on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay active video",
      "info": "Autoplay only works while the video is muted, and is skipped for reduced-motion users.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute video by default",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Show native video controls",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_hide_fullscreen",
      "label": "Hide fullscreen button (best-effort)",
      "info": "Applied via controlsList on native controls; some browsers (Safari/iOS) ignore it.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_hide_download",
      "label": "Hide download button (best-effort)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_hide_remote",
      "label": "Hide remote playback (best-effort)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_custom_playpause",
      "label": "Show custom play/pause button",
      "info": "Recommended when native controls are off.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_custom_mute",
      "label": "Show custom mute/unmute button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_thumb_play_icon",
      "label": "Show play icon on video thumbnails",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_pause_inactive",
      "label": "Pause inactive videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_reset_inactive",
      "label": "Reset inactive videos to start",
      "default": false
    },
    {
      "type": "select",
      "id": "video_object_fit",
      "label": "Video fit",
      "options": [
        { "value": "cover",   "label": "Cover (fill frame, may crop)" },
        { "value": "contain", "label": "Contain (show full video)" }
      ],
      "default": "cover"
    },
    {
      "type": "color",
      "id": "video_bg_color",
      "label": "Video background color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product media",
      "settings": {
        "aspect_ratio": "9:16",
        "image_fit": "contain",
        "thumb_position": "left",
        "thumb_width": 64,
        "sticky_gallery": true,
        "enable_zoom": true,
        "enable_dots": true
      }
    }
  ]
}
