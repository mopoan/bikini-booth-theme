{%- liquid
  assign cta_url = routes.all_products_collection_url
  if section.settings.cta_link != blank
    assign cta_url = section.settings.cta_link
  endif
-%}

<div class="bb-wishlist-cta hide" data-bb-wishlist-cta>
  <div class="bb-wishlist-cta__copy">
    <span class="bb-wishlist-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 21c-.5-4 .2-7 .8-9.4"/>
        <path d="M12.8 11.6c-1.6-1.4-4-1.6-6 .2"/>
        <path d="M12.8 11.6c1.8-1.2 4.2-1 5.8 1"/>
        <path d="M12.8 11.6c-.8-2 0-4.4 2.4-5.6"/>
        <path d="M12.8 11.6c-1-1.8-3.2-2.8-5.8-2.2"/>
      </svg>
    </span>
    <span>{{ section.settings.cta_text | default: 'Ready to make it yours? Add your favorites to the bag or continue exploring.' | escape }}</span>
  </div>
  <a href="{{ cta_url }}" class="bb-wishlist-cta__btn">{{ section.settings.cta_button | default: 'CONTINUE SHOPPING' | escape }}</a>
  <div class="bb-wishlist-cta__decor" aria-hidden="true">
    <svg viewBox="0 0 120 120" fill="none">
      <path d="M95 115c-8-18-6-38 4-52" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M98 115c-14-12-22-28-20-44" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M101 115c-20-8-32-22-34-38" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M104 115c-24-4-38-16-42-32" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M107 115c-28 0-44-10-50-26" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M110 115c-30 4-48-4-56-20" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>
</div>
