{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout for Bikini Booth product pages.

  The sections are direct children of <main id="MainContent" class="content-for-layout">.
  We make that the grid container and assign each section to a column.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    /* ── Make main content area a two-column grid ── */
    body.template-product main.content-for-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Make shopify-section wrappers transparent to grid ── */
    body.template-product main.content-for-layout > .shopify-section {
      display: contents;
    }

    /* ── Left column: gallery — sticky full height ── */
    .bb-media {
      grid-column: 1;
      grid-row: 1 / 4;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Right column: purchase form ── */
    .bb-info   { grid-column: 2; grid-row: 1; }
    .bb-trust  { grid-column: 2; grid-row: 2; }
    .bb-fit    { grid-column: 2; grid-row: 3; }

    /* ── Bottom left: social proof ── */
    .bb-sp {
      grid-column: 1;
      grid-row: 4;
      border-top: 0.5px solid #e8e4dd;
    }

    /* ── Bottom right: complete the look + accordions ── */
    .bb-ctl      { grid-column: 2; grid-row: 4; border-top: 0.5px solid #e8e4dd; }
    .bb-acc-wrap { grid-column: 2; grid-row: 5; }

    /* ── Social proof needs same row height as CTL ── */
    .bb-sp { align-self: start; }

    /* Mobile: reset everything */
  }

  @media (max-width: 899px) {
    .bb-media {
      position: relative !important;
      height: auto !important;
      top: auto !important;
    }
  }
</style>
