{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  Strategy: CSS alone cannot reliably win the specificity battle against
  79 competing stylesheets. We set grid-area via inline styles in JS,
  which always takes precedence over any stylesheet rule.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {
    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     ."
        "recs   recs" !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }
  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section.bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>

<script>
(function () {
  'use strict';

  function applyGridAreas() {
    if (window.innerWidth < 900) return;

    var map = {
      'bb-product-media-section':  { area: 'media', position: 'sticky', top: '0', height: '100vh', overflow: 'hidden' },
      'bb-product-info-section':   { area: 'info' },
      'bb-product-trust-section':  { area: 'trust' },
      'bb-product-fit-section':    { area: 'fit' },
      'bb-product-ctl-section':    { area: 'ctl' },
      'bb-product-acc-section':    { area: 'acc' },
      'bb-product-sp-section':     { area: 'sp', alignSelf: 'start' }
    };

    Object.keys(map).forEach(function (cls) {
      var el = document.querySelector('.shopify-section.' + cls);
      if (!el) return;
      var props = map[cls];
      el.style.setProperty('grid-area', props.area, 'important');
      el.style.minWidth = '0';
      if (props.position)  el.style.position = props.position;
      if (props.top)       el.style.top = props.top;
      if (props.height)    el.style.height = props.height;
      if (props.overflow)  el.style.overflow = props.overflow;
      if (props.alignSelf) el.style.alignSelf = props.alignSelf;
    });

    /* Recommendations — target by content */
    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');
  }

  /* Run immediately and after DOM is fully ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyGridAreas);
  } else {
    applyGridAreas();
  }

  /* Also run after a short delay to catch any late overrides */
  setTimeout(applyGridAreas, 100);
  setTimeout(applyGridAreas, 500);

})();
</script>
