{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Stable two-column desktop layout for Bikini Booth product pages.

  Approach: Uses float/position instead of display:contents which breaks
  on DOM changes. Gallery is position:sticky left half, right column
  sections get margin-left: 50% to sit beside it.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    /* ── Page container ── */
    body.template-product main.content-for-layout {
      position: relative;
      max-width: 1440px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ── Left column: gallery — fixed to left half ── */
    body.template-product main.content-for-layout .bb-product-media-section {
      position: sticky;
      top: 0;
      float: left;
      width: 50%;
      height: auto;
      max-height: 100vh;
      overflow: hidden;
      z-index: 1;
    }

    body.template-product main.content-for-layout .bb-media {
      height: auto;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      max-height: 100vh;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      min-height: 0;
      aspect-ratio: 9 / 16;
      max-height: calc(100vh - 80px);
    }

    /* ── Right column: all other sections sit beside gallery ── */
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-acc-section {
      float: right;
      width: 50%;
      clear: none;
    }

    /* ── Social proof: bottom left, beside right column ── */
    body.template-product main.content-for-layout .bb-product-sp-section {
      float: left;
      width: 50%;
      clear: left;
    }

    /* ── Product recommendations + any other sections: full width below ── */
    body.template-product main.content-for-layout .bb-product-sp-section ~ .shopify-section {
      float: none;
      clear: both;
      width: 100%;
      margin-left: 0;
    }

    /* Target product recommendations by custom element and data attribute */
    body.template-product main.content-for-layout product-recommendations,
    body.template-product main.content-for-layout [data-section-name="product-recommendations"],
    body.template-product main.content-for-layout [id*="product_recommendations"],
    body.template-product main.content-for-layout [id*="product-recommendations"] {
      display: block;
      float: none;
      clear: both;
      width: 100%;
      margin-left: 0;
    }

    /* Also target the shopify-section wrapper containing it */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      float: none;
      clear: both;
      width: 100%;
      margin-left: 0;
    }

    /* ── Clearfix ── */
    body.template-product main.content-for-layout::after {
      content: '';
      display: table;
      clear: both;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout .bb-product-media-section {
      position: relative !important;
      float: none !important;
      width: 100% !important;
      height: auto !important;
    }
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-sp-section {
      margin-left: 0 !important;
      width: 100% !important;
      float: none !important;
    }
  }
</style>
