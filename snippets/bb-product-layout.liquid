{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  Social proof positioning: sp sits in grid row 6 col 1, but that row starts
  far below where the media section visually ends (because rows 1-5 are sized
  by the taller right column content). We use a negative margin-top on sp,
  calculated in JS, to pull it up flush below the media section's actual
  visual bottom edge.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {
    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     ."
        "recs   recs" !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }
  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section.bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>

<script>
(function () {
  'use strict';

  function applyGridAreas() {
    if (window.innerWidth < 900) return;

    var map = {
      'bb-product-media-section':  { area: 'media', position: 'sticky', top: '0', height: '100vh', overflow: 'hidden' },
      'bb-product-info-section':   { area: 'info' },
      'bb-product-trust-section':  { area: 'trust' },
      'bb-product-fit-section':    { area: 'fit' },
      'bb-product-ctl-section':    { area: 'ctl' },
      'bb-product-acc-section':    { area: 'acc' },
      'bb-product-sp-section':     { area: 'sp', alignSelf: 'start' }
    };

    Object.keys(map).forEach(function (cls) {
      var el = document.querySelector('.shopify-section.' + cls);
      if (!el) return;
      var props = map[cls];
      el.style.setProperty('grid-area', props.area, 'important');
      el.style.minWidth = '0';
      if (props.position)  el.style.position = props.position;
      if (props.top)       el.style.top = props.top;
      if (props.height)    el.style.height = props.height;
      if (props.overflow)  el.style.overflow = props.overflow;
      if (props.alignSelf) el.style.alignSelf = props.alignSelf;
    });

    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');

    /* Pull social proof up to sit directly below the media section */
    positionSocialProof();
  }

  function positionSocialProof() {
    if (window.innerWidth < 900) return;

    var mediaEl = document.querySelector('.shopify-section.bb-product-media-section');
    var spEl    = document.querySelector('.shopify-section.bb-product-sp-section');
    if (!mediaEl || !spEl) return;

    /* Reset first so measurements are clean */
    spEl.style.marginTop = '';

    var mediaBottom = mediaEl.getBoundingClientRect().bottom + window.scrollY;
    var spTop       = spEl.getBoundingClientRect().top    + window.scrollY;
    var gap         = spTop - mediaBottom;

    if (gap > 0) {
      spEl.style.setProperty('margin-top', '-' + gap + 'px', 'important');
    }
  }

  function init() {
    applyGridAreas();
    /* Re-run after images/content may have shifted layout */
    setTimeout(positionSocialProof, 300);
    setTimeout(positionSocialProof, 800);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Recalculate on resize */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(applyGridAreas, 150);
  });

})();
</script>
