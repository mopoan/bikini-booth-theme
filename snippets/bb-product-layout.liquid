{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout for Bikini Booth product pages.

  Shopify DOES apply schema "class" to the outer shopify-section wrapper:
    <div class="shopify-section bb-product-info-section">

  So we can target directly by class name.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      position: relative;
      max-width: 1440px;
      margin: 0 auto;
      overflow: hidden;
    }

    /* ── Left column: gallery ── */
    body.template-product main.content-for-layout .bb-product-media-section {
      position: sticky;
      top: 0;
      float: left;
      width: 50%;
      height: 100vh;
      overflow: hidden;
      z-index: 1;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

    /* ── Right column ── */
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-ctl-section {
      float: right;
      width: 50%;
      clear: none;
    }

    /* ── Bottom left: social proof ── */
    body.template-product main.content-for-layout .bb-product-sp-section {
      float: left;
      width: 50%;
      clear: left;
    }

    /* ── Accordion and CTL always float right, even after social proof ── */
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-ctl-section {
      float: right !important;
      width: 50% !important;
      clear: none !important;
    }

    /* ── Full width: recommendations only ── */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      float: none !important;
      clear: both !important;
      width: 100% !important;
    }

    /* ── Clearfix ── */
    body.template-product main.content-for-layout::after {
      content: '';
      display: table;
      clear: both;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout .bb-product-media-section,
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-sp-section {
      float: none !important;
      width: 100% !important;
      height: auto !important;
      position: relative !important;
      top: auto !important;
      overflow: visible !important;
    }
  }
</style>
