{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  IMPORTANT: Shopify wraps every section in a div.shopify-section.
  The grid children are those wrapper divs, not the inner section elements.
  We target the wrapper via its contained class using :has().
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     ."
        "recs   recs";
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Target the shopify-section wrapper divs via :has() */
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-media-section) { grid-area: media; position: sticky; top: 0; height: 100vh; overflow: hidden; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-info-section)  { grid-area: info;  min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-trust-section) { grid-area: trust; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-fit-section)   { grid-area: fit;   min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-ctl-section)   { grid-area: ctl;   min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-acc-section)   { grid-area: acc;   min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-sp-section)    { grid-area: sp;    min-width: 0; align-self: start; }
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations)   { grid-area: recs; }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-media-section) {
      position: relative !important;
      height: auto !important;
    }
  }
</style>
