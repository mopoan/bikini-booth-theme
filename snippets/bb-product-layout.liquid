{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  Social proof sits in DOM position 7 (after accordions).
  On desktop: moved into media section via JS for left-column placement.
  On mobile: stays in DOM position 7, no JS manipulation needed.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "media  ."
        "recs   recs" !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .shopify-section.bb-product-info-section  { grid-area: info  !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-trust-section { grid-area: trust !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-fit-section   { grid-area: fit   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-ctl-section   { grid-area: ctl   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-acc-section   { grid-area: acc   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) { grid-area: recs !important; }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
  }
</style>

<script>
(function () {
  'use strict';

  function applyLayout() {
    /* Media section — grid placement */
    var mediaEl = document.querySelector('.shopify-section.bb-product-media-section');
    if (mediaEl) {
      mediaEl.style.setProperty('grid-area', 'media', 'important');
      mediaEl.style.minWidth = '0';
      mediaEl.style.setProperty('overflow', 'visible', 'important');
    }

    /* Recs */
    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');

    /* Gallery flex-direction — use matchMedia which works correctly */
    var bbMedia = document.querySelector('.bb-media');
    if (bbMedia) {
      if (window.matchMedia('(min-width: 900px)').matches) {
        bbMedia.style.setProperty('flex-direction', 'row', 'important');
        bbMedia.style.setProperty('align-items', 'flex-start', 'important');
      } else {
        bbMedia.style.setProperty('flex-direction', 'column', 'important');
      }
    }

    /* Social proof — only move on desktop */
    if (window.matchMedia('(min-width: 900px)').matches) {
      moveSocialProofToMedia();
    }
  }

  function moveSocialProofToMedia() {
    var mediaEl = document.querySelector('.shopify-section.bb-product-media-section');
    var spEl    = document.querySelector('.shopify-section.bb-product-sp-section');
    if (!mediaEl || !spEl) return;
    if (spEl.parentElement === mediaEl) return;

    mediaEl.appendChild(spEl);
    spEl.style.removeProperty('grid-area');
    spEl.style.removeProperty('grid-row');
    spEl.style.removeProperty('align-self');
    spEl.style.removeProperty('margin-top');
    spEl.style.position = '';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyLayout);
  } else {
    applyLayout();
  }
  setTimeout(applyLayout, 100);

  /* Re-run on resize */
  var mq = window.matchMedia('(min-width: 900px)');
  mq.addEventListener('change', applyLayout);

})();
</script>
