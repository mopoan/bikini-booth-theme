{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout for Bikini Booth product pages.
  Uses CSS Grid on main.content-for-layout targeting section wrappers directly.
  Does NOT use display:contents since the theme overrides it with flex.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Gallery: left column, sticky ── */
    body.template-product main.content-for-layout .bb-product-media-section {
      grid-column: 1;
      grid-row: 1 / 6;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

    /* ── Right column ── */
    body.template-product main.content-for-layout .bb-product-info-section  { grid-column: 2; grid-row: 1; }
    body.template-product main.content-for-layout .bb-product-trust-section { grid-column: 2; grid-row: 2; }
    body.template-product main.content-for-layout .bb-product-fit-section   { grid-column: 2; grid-row: 3; }
    body.template-product main.content-for-layout .bb-product-ctl-section   { grid-column: 2; grid-row: 4; }
    body.template-product main.content-for-layout .bb-product-acc-section   { grid-column: 2; grid-row: 5; }

    /* ── Bottom left: social proof ── */
    body.template-product main.content-for-layout .bb-product-sp-section {
      grid-column: 1;
      grid-row: 6;
      align-self: start;
    }

    /* ── Full width: recommendations ── */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      grid-column: 1 / -1;
      grid-row: 7;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>
