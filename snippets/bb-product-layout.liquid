{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.
  Note: !important required on grid-area rules to override theme stylesheet.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     ."
        "recs   recs" !important;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    body.template-product main.content-for-layout .shopify-section.bb-product-media-section  { grid-area: media !important; position: sticky; top: 0; height: 100vh; overflow: hidden; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-info-section   { grid-area: info  !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-trust-section  { grid-area: trust !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-fit-section    { grid-area: fit   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-ctl-section    { grid-area: ctl   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-acc-section    { grid-area: acc   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-sp-section     { grid-area: sp    !important; min-width: 0; align-self: start; }
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) { grid-area: recs !important; }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section.bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>
