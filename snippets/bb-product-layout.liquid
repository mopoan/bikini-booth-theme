{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid.
  Grid is placed on main.content-for-layout with display:contents
  on shopify-section wrappers so inner divs become grid items.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Make section wrappers transparent to grid */
    body.template-product main.content-for-layout .bb-product-media-section,
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-sp-section {
      display: contents;
    }

    /* ── Gallery: left column, spans all right-column rows ── */
    body.template-product main.content-for-layout .bb-media {
      grid-column: 1;
      grid-row: 1 / 6;
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

    /* ── Right column items ── */
    body.template-product main.content-for-layout .bb-info      { grid-column: 2; grid-row: 1; }
    body.template-product main.content-for-layout .bb-trust     { grid-column: 2; grid-row: 2; }
    body.template-product main.content-for-layout .bb-fit       { grid-column: 2; grid-row: 3; }
    body.template-product main.content-for-layout .bb-ctl       { grid-column: 2; grid-row: 4; }
    body.template-product main.content-for-layout .bb-acc-wrap  { grid-column: 2; grid-row: 5; }

    /* ── Bottom row: social proof left, empty right ── */
    body.template-product main.content-for-layout .bb-sp {
      grid-column: 1;
      grid-row: 6;
      align-self: start;
    }

    /* ── Full width: recommendations ── */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      grid-column: 1 / -1;
      grid-row: 7;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .bb-product-media-section,
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-acc-section,
    body.template-product main.content-for-layout .bb-product-sp-section {
      display: block !important;
    }
    body.template-product main.content-for-layout .bb-media {
      position: relative !important;
      height: auto !important;
      grid-column: unset !important;
      grid-row: unset !important;
    }
  }
</style>
