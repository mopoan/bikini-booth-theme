{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  Social proof is moved into the media section via JS so it scrolls
  with the gallery rather than being an independent grid item.
  overflow: hidden is on .bb-media__main (gallery only), not the wrapper.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "media  ."
        "recs   recs" !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .bb-media {
      height: auto;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      min-height: 100vh;
      height: 0;
      overflow: hidden;
    }
  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .shopify-section.bb-product-media-section {
      position: relative !important;
      height: auto !important;
      overflow: visible !important;
    }
  }
</style>

<script>
(function () {
  'use strict';

  function applyGridAreas() {
    if (window.innerWidth < 900) return;

    var assignments = [
      { cls: 'bb-product-media-section', area: 'media', extra: { position: 'sticky', top: '0', alignSelf: 'start', overflow: 'visible' } },
      { cls: 'bb-product-info-section',  area: 'info' },
      { cls: 'bb-product-trust-section', area: 'trust' },
      { cls: 'bb-product-fit-section',   area: 'fit' },
      { cls: 'bb-product-ctl-section',   area: 'ctl' },
      { cls: 'bb-product-acc-section',   area: 'acc' }
    ];

    assignments.forEach(function (item) {
      var el = document.querySelector('.shopify-section.' + item.cls);
      if (!el) return;
      el.style.setProperty('grid-area', item.area, 'important');
      el.style.minWidth = '0';
      if (item.extra) {
        if (item.extra.position)  el.style.position  = item.extra.position;
        if (item.extra.top)       el.style.top        = item.extra.top;
        if (item.extra.alignSelf) el.style.alignSelf  = item.extra.alignSelf;
        if (item.extra.overflow)  el.style.setProperty('overflow', item.extra.overflow, 'important');
      }
    });

    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');

    moveSocialProof();
  }

  function moveSocialProof() {
    if (window.innerWidth < 900) return;

    var mediaEl = document.querySelector('.shopify-section.bb-product-media-section');
    var spEl    = document.querySelector('.shopify-section.bb-product-sp-section');
    if (!mediaEl || !spEl) return;
    if (spEl.parentElement === mediaEl) return;

    mediaEl.appendChild(spEl);

    spEl.style.removeProperty('grid-area');
    spEl.style.removeProperty('grid-row');
    spEl.style.removeProperty('align-self');
    spEl.style.position = '';
    spEl.style.marginTop = '';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyGridAreas);
  } else {
    applyGridAreas();
  }
  setTimeout(applyGridAreas, 100);

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(applyGridAreas, 150);
  });

})();
</script>
