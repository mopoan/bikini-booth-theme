{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout for Bikini Booth product pages.

  Shopify renders sections as:
    <div id="shopify-section-..." class="shopify-section">   ← outer, no custom class
      <div class="bb-product-xxx-section">                   ← inner, has our class

  We use :has() to target the outer wrapper based on its inner content class.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      position: relative;
      max-width: 1440px;
      margin: 0 auto;
      overflow: hidden;
    }

    /* ── Left column: gallery ── */
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-media-section) {
      position: sticky;
      top: 0;
      float: left;
      width: 50%;
      height: 100vh;
      overflow: hidden;
      z-index: 1;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

    /* ── Right column ── */
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-info-section),
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-trust-section),
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-fit-section),
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-acc-section),
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-ctl-section) {
      float: right;
      width: 50%;
      clear: none;
    }

    /* ── Bottom left: social proof ── */
    body.template-product main.content-for-layout .shopify-section:has(.bb-product-sp-section) {
      float: left;
      width: 50%;
      clear: left;
    }

    /* ── Full width: recommendations ── */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      float: none;
      clear: both;
      width: 100%;
    }

    /* ── Clearfix ── */
    body.template-product main.content-for-layout::after {
      content: '';
      display: table;
      clear: both;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout .shopify-section {
      float: none !important;
      width: 100% !important;
      height: auto !important;
      position: relative !important;
      top: auto !important;
      overflow: visible !important;
    }
  }
</style>
