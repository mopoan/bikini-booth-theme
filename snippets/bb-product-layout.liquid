{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid with named template areas.

  Grid (desktop):
    media  info
    media  trust
    media  fit
    media  ctl
    media  acc
    sp     sp     <- social proof, full width, below the accordions
    recs   recs   <- recommendations, full width

  Social proof is placed by grid-area (no DOM moving). For correct MOBILE
  order, the Social Proof section should sit between Accordions and
  Recommendations in the theme editor's section list — on mobile the grid
  collapses to block flow and follows DOM order.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      grid-template-areas:
        "media  info"
        "media  trust"
        "media  fit"
        "media  ctl"
        "media  acc"
        "sp     sp"
        "recs   recs" !important;
      /* Rows in the gallery's span (info→ctl) are min-content so they stay at
         their natural height and cannot be inflated when the gallery is taller
         than the right-hand stack. The acc row is auto, so any surplus gallery
         height collects there (below the accordion) instead of opening gaps
         between the sections above it. */
      grid-template-rows: min-content min-content min-content min-content auto auto auto !important;
      align-items: start !important;
      max-width: 1440px !important;
      margin: 0 auto !important;
    }

    body.template-product main.content-for-layout .shopify-section.bb-product-info-section  { grid-area: info  !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-trust-section { grid-area: trust !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-fit-section   { grid-area: fit   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-ctl-section   { grid-area: ctl   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-acc-section   { grid-area: acc   !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section.bb-product-sp-section    { grid-area: sp    !important; min-width: 0; }
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) { grid-area: recs !important; }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }

    /* Sentinel element — visible only on mobile via CSS */
    #bb-mobile-sentinel { display: block; }
  }

  /* Sentinel hidden on desktop */
  #bb-mobile-sentinel { display: none; }
</style>

{%- comment -%} Sentinel: CSS makes this visible on mobile, hidden on desktop {%- endcomment -%}
<div id="bb-mobile-sentinel" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;pointer-events:none;"></div>

<script>
(function () {
  'use strict';

  function isDesktop() {
    /* Check CSS sentinel — visible (display:block) on mobile, hidden (display:none) on desktop */
    var sentinel = document.getElementById('bb-mobile-sentinel');
    if (sentinel) {
      return getComputedStyle(sentinel).display === 'none';
    }
    /* Fallback */
    return window.matchMedia('(min-width: 900px)').matches;
  }

  function applyLayout() {
    var desktop = isDesktop();

    /* Media section — grid placement */
    var mediaEl = document.querySelector('.shopify-section.bb-product-media-section');
    if (mediaEl) {
      mediaEl.style.setProperty('grid-area', 'media', 'important');
      mediaEl.style.minWidth = '0';
      mediaEl.style.setProperty('overflow', 'visible', 'important');
    }

    /* Social proof — full-width grid row (placed by area, not moved) */
    var spEl = document.querySelector('.shopify-section.bb-product-sp-section');
    if (spEl) {
      spEl.style.setProperty('grid-area', 'sp', 'important');
      spEl.style.minWidth = '0';
    }

    /* Recommendations */
    var recs = document.querySelector('.shopify-section:has(product-recommendations)');
    if (recs) recs.style.setProperty('grid-area', 'recs', 'important');

    /* Gallery flex-direction */
    var bbMedia = document.querySelector('.bb-media');
    if (bbMedia) {
      if (desktop) {
        bbMedia.style.setProperty('flex-direction', 'row', 'important');
        bbMedia.style.setProperty('align-items', 'flex-start', 'important');
      } else {
        bbMedia.style.setProperty('flex-direction', 'column', 'important');
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyLayout);
  } else {
    applyLayout();
  }
  setTimeout(applyLayout, 100);

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(applyLayout, 150);
  });

})();
</script>
