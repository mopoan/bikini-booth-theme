{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout using CSS Grid.

  Layout:
  - Left column:  media (rows 1–2), social proof (row 2)
  - Right column: info, trust, fit, ctl, acc (rows 1–5)
  - Full width:   recs (row 3)

  Social proof sits below the gallery by sharing grid-column 1
  with an explicit grid-row that starts after media ends.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    body.template-product main.content-for-layout {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Media — left col, row 1, sticky */
    body.template-product main.content-for-layout .bb-product-media-section {
      grid-column: 1;
      grid-row: 1;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      min-width: 0;
    }

    /* Right column sections — stack in col 2 row 1 */
    body.template-product main.content-for-layout .bb-product-info-section,
    body.template-product main.content-for-layout .bb-product-trust-section,
    body.template-product main.content-for-layout .bb-product-fit-section,
    body.template-product main.content-for-layout .bb-product-ctl-section,
    body.template-product main.content-for-layout .bb-product-acc-section {
      grid-column: 2;
      grid-row: 1;
      min-width: 0;
    }

    /* Social proof — left col, row 2, directly below media */
    body.template-product main.content-for-layout .bb-product-sp-section {
      grid-column: 1;
      grid-row: 2;
      min-width: 0;
      align-self: start;
    }

    /* Recommendations — full width, row 3 */
    body.template-product main.content-for-layout .shopify-section:has(product-recommendations) {
      grid-column: 1 / -1;
      grid-row: 3;
    }

    body.template-product main.content-for-layout .bb-media {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body.template-product main.content-for-layout .bb-media__main {
      flex: 1;
      height: 0;
    }

  }

  @media (max-width: 899px) {
    body.template-product main.content-for-layout {
      display: block !important;
    }
    body.template-product main.content-for-layout .bb-product-media-section {
      position: relative !important;
      height: auto !important;
    }
  }
</style>
