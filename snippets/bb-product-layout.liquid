{%- comment -%}
  Snippet: bb-product-layout.liquid
  Purpose: Two-column desktop layout for Bikini Booth product pages.

  Approach: Uses CSS Grid on the #shopify-section-group-template wrapper
  which Shopify creates around all template sections. Each section's
  inner content div is assigned to a grid column.

  Column layout:
    Left  (col 1): gallery (sticky full height), then social proof below
    Right (col 2): info → trust bar → fit note → complete the look → accordions

  Usage: {% render 'bb-product-layout' %}
  Render this inside product-media.liquid so it loads first.
{%- endcomment -%}

<style>
  @media (min-width: 900px) {

    /* ── Make the Shopify section group a two-column grid ── */
    #shopify-section-group-template-section,
    [id^="shopify-section-group-template"] {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Make section wrappers transparent to grid */
    .shopify-section.bb-product-media-section,
    .shopify-section.bb-product-info-section,
    .shopify-section.bb-product-trust-section,
    .shopify-section.bb-product-fit-section,
    .shopify-section.bb-product-sp-section,
    .shopify-section.bb-product-ctl-section,
    .shopify-section.bb-product-acc-section {
      display: contents;
    }

    /* ── Left column: gallery sticky ── */
    .bb-media {
      grid-column: 1;
      grid-row: 1 / 5;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Right column: purchase form sections ── */
    .bb-info {
      grid-column: 2;
      grid-row: 1;
    }

    .bb-trust {
      grid-column: 2;
      grid-row: 2;
    }

    .bb-fit {
      grid-column: 2;
      grid-row: 3;
    }

    /* ── Bottom left: social proof ── */
    .bb-sp {
      grid-column: 1;
      grid-row: 5;
      border-top: 0.5px solid #e8e4dd;
    }

    /* ── Bottom right: complete the look + accordions ── */
    .bb-ctl {
      grid-column: 2;
      grid-row: 4;
      border-top: 0.5px solid #e8e4dd;
    }

    .bb-acc-wrap {
      grid-column: 2;
      grid-row: 5;
    }

  }
</style>
