{%- comment -%}
  Snippet: bb-product-auto-connect.liquid
  Purpose: Auto-connects related products by name convention.

  Naming convention (required):
    [Style] [Piece] in [Color]     e.g. "Kata Bikini Top in Orange"
    [Style] [Piece] in [Color]     e.g. "Kata Bikini Bottom in Orange"
    [Style] in [Color]             e.g. "Sarong in Sand" (no piece toggle)

  Swatch images (optional):
    Upload to Shopify Files as: swatch-[color-lowercase].png
    e.g. swatch-orange.png, swatch-turquoise.png, swatch-fuchsia.png
    If a swatch image exists it is used. Hex is the fallback.

  Performance:
    - Catalog is cached in sessionStorage so navigating between products
      (clicking swatches / piece toggle) does not re-fetch the whole catalog.
    - Swatches render immediately as hex; swatch images are probed in the
      background and upgraded only if they exist (no blocking on 404s).

  Output:
    Fires window.BB.productData and custom event 'bb:productDataReady'.
    May fire a second time to upgrade hex swatches to images.
    Consumed by product-info.liquid section.
{%- endcomment -%}

<script>
(function () {
  'use strict';

  window.BB = window.BB || {};
  window.BB.moneyFormat = {{ shop.money_format | json }};
  window.BB.shopCurrency = {{ shop.currency | json }};

  function bbCurrencyRate() {
    var active = window.Shopify && window.Shopify.currency && window.Shopify.currency.active;
    if (!active || !window.BB.shopCurrency || active === window.BB.shopCurrency) {
      return 1;
    }
    return window.Shopify.currency.rate || 1;
  }

  /* Shop-currency cents → active presentment currency */
  window.BB.formatPresentmentMoney = function (shopCurrencyCents) {
    var cents = Math.round(parseFloat(shopCurrencyCents) || 0);
    if (!cents) return '';
    cents = Math.round(cents * bbCurrencyRate());
    var fmt = (window.theme && window.theme.moneyFormat) || window.BB.moneyFormat || '{{amount}}';
    if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
      return window.Shopify.formatMoney(cents, fmt);
    }
    return (cents / 100).toFixed(2);
  };

  window.BB.formatPresentmentMoneyFromDecimal = function (decimalPrice) {
    var amount = parseFloat(decimalPrice);
    if (isNaN(amount)) return '';
    return window.BB.formatPresentmentMoney(Math.round(amount * 100));
  };

  function fetchProductCents(handle) {
    var root = (window.routes && window.routes.root_url) || '/';
    return fetch(root + 'products/' + handle + '.js')
      .then(function (r) { return r.json(); })
      .then(function (p) {
        return p.variants && p.variants[0] ? p.variants[0].price : null;
      })
      .catch(function () { return null; });
  }

  var PRODUCT_TITLE  = {{ product.title | json }};
  var PRODUCT_HANDLE = {{ product.handle | json }};
  var PRODUCT_URL    = {{ product.url | json }};

  var CACHE_KEY = 'bb_all_products';

  var colorMap = {
    'orange':    '#e8892a',
    'turquoise': '#49c6be',
    'fuchsia':   '#e855b0',
    'pink':      '#f4a0b8',
    'white':     '#ffffff',
    'black':     '#2a2520',
    'navy':      '#1e3a5f',
    'red':       '#e03030',
    'green':     '#4caf7d',
    'yellow':    '#f5c842',
    'blue':      '#4a90d9',
    'sand':      '#d4c4a0',
    'coral':     '#f07060',
    'lilac':     '#c8a8e0',
    'gold':      '#d4a832',
    'silver':    '#c0c0c0',
    'brown':     '#8b6340',
    'grey':      '#a0a0a0',
    'gray':      '#a0a0a0',
    'leopard':   '#c8902a',
    'zebra':     '#2a2520',
    'floral':    '#e87090'
  };

  var PIECES = ['Top', 'Bottom'];

  /* ── Parse title: "[Style] [Piece] in [Color]" ── */
  function parseTitle(title) {
    var color    = null;
    var baseName = title;
    var piece    = null;
    var style    = title;

    /* Split on " in " to get color */
    var inIdx = title.lastIndexOf(' in ');
    if (inIdx !== -1) {
      color    = title.slice(inIdx + 4).trim();
      baseName = title.slice(0, inIdx).trim();
    }

    /* Detect piece from base name — must be the LAST word exactly */
    for (var i = 0; i < PIECES.length; i++) {
      var p = PIECES[i];
      if (baseName === p || baseName.slice(-(p.length + 1)) === ' ' + p) {
        piece = p;
        style = baseName.slice(0, baseName.length - p.length - 1).trim();
        break;
      }
    }

    if (!piece) style = baseName;

    return { baseName: baseName, style: style, piece: piece, color: color };
  }

  function swatchImageUrl(colorName) {
    return '/files/swatch-' + colorName.toLowerCase().replace(/\s+/g, '-') + '.png';
  }

  function probeImage(url) {
    return new Promise(function (resolve) {
      var img    = new Image();
      img.onload  = function () { resolve(true); };
      img.onerror = function () { resolve(false); };
      img.src = url;
    });
  }

  /* ── Fetch full catalog, cached per browsing session ── */
  function fetchAllProducts(callback) {
    try {
      var cached = sessionStorage.getItem(CACHE_KEY);
      if (cached) { callback(JSON.parse(cached)); return; }
    } catch (e) {}

    var all = [];
    function getPage(page) {
      fetch('/products.json?limit=250&page=' + page)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var products = data.products || [];
          all = all.concat(products);
          if (products.length === 250) {
            getPage(page + 1);
          } else {
            try { sessionStorage.setItem(CACHE_KEY, JSON.stringify(all)); } catch (e) {}
            callback(all);
          }
        })
        .catch(function (err) {
          console.warn('[BB Auto-Connect] Fetch failed:', err);
          callback(all);
        });
    }
    getPage(1);
  }

  function buildData(allProducts) {
    var current       = parseTitle(PRODUCT_TITLE);
    var colorSwatches = [];
    var pieceLinks    = {};

    allProducts.forEach(function (p) {
      if (!p.title || !p.handle) return;
      var parsed = parseTitle(p.title);

      /* Same style + same piece + different color → color swatch */
      var isSamePiece = (
        parsed.style === current.style &&
        parsed.piece === current.piece
      );

      /* Same style + same color + opposite piece → piece link */
      var isOpposite = (
        current.piece !== null &&
        parsed.style  === current.style &&
        parsed.piece  !== null &&
        parsed.piece  !== current.piece &&
        parsed.color  !== null &&
        current.color !== null &&
        parsed.color.toLowerCase() === current.color.toLowerCase()
      );

      if (isSamePiece && parsed.color) {
        colorSwatches.push({
          color:    parsed.color,
          hex:      colorMap[parsed.color.toLowerCase()] || '#c8c0b8',
          imageUrl: swatchImageUrl(parsed.color),
          url:      '/products/' + p.handle,
          active:   p.handle === PRODUCT_HANDLE,
          available: p.available !== false,
          useImage: false
        });
      }

      if (isOpposite) {
        pieceLinks[parsed.piece] = {
          url:    '/products/' + p.handle,
          handle: p.handle,
          title:  p.title,
          price:  p.variants && p.variants[0] ? p.variants[0].price : null,
          priceCents: null
        };
      }
    });

    /* Sort swatches alphabetically */
    colorSwatches.sort(function (a, b) { return a.color.localeCompare(b.color); });

    /* Only show swatches when genuine alternatives exist (>1 product with this base) */
    if (colorSwatches.length < 2) colorSwatches = [];

    /*
      hasPieceToggle: true only when this product has a piece (Top/Bottom)
      AND a matching opposite piece was actually found in the store.
    */
    var hasPieceToggle = current.piece !== null && Object.keys(pieceLinks).length > 0;

    function emit() {
      window.BB              = window.BB || {};
      window.BB.productData  = {
        title:          PRODUCT_TITLE,
        handle:         PRODUCT_HANDLE,
        url:            PRODUCT_URL,
        style:          current.style,
        piece:          current.piece,
        color:          current.color,
        hasPieceToggle: hasPieceToggle,
        colorSwatches:  colorSwatches,
        pieceLinks:     pieceLinks
      };
      document.dispatchEvent(
        new CustomEvent('bb:productDataReady', { detail: window.BB.productData })
      );
    }

    /* Emit immediately — swatches + piece links (prices load async below) */
    emit();

    var pieceKeys = Object.keys(pieceLinks);
    if (pieceKeys.length) {
      Promise.all(pieceKeys.map(function (piece) {
        var link = pieceLinks[piece];
        return fetchProductCents(link.handle).then(function (cents) {
          if (cents != null) link.priceCents = cents;
        });
      })).then(function () { emit(); });
    }

    /* Probe swatch images in the background; re-emit once to upgrade ONLY if any exist */
    if (colorSwatches.length) {
      Promise.all(colorSwatches.map(function (sw) {
        return probeImage(sw.imageUrl).then(function (ok) { sw.useImage = ok; return ok; });
      })).then(function (results) {
        if (results.some(Boolean)) emit();
      });
    }
  }

  fetchAllProducts(buildData);
})();
</script>
