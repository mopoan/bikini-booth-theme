{%- comment -%}
  Resolves the opposite bikini Top/Bottom for the current product.
  Sets: bb_paired_product, bb_paired_piece, bb_active_money_format
{%- endcomment -%}
{%- liquid
  assign bb_paired_product = nil
  assign bb_paired_piece = nil

  assign bb_title_parts = product.title | split: ' in '
  if bb_title_parts.size >= 2
    assign bb_color = bb_title_parts | last | strip
    assign bb_base = bb_title_parts | first | strip
    assign bb_opp_title = nil

    assign bb_base_tail = bb_base | split: ' ' | last

    if bb_base_tail == 'Top'
      assign bb_paired_piece = 'Bottom'
      if bb_base == 'Top'
        assign bb_opp_title = 'Bottom in ' | append: bb_color
      else
        assign bb_style = bb_base | remove: ' Top' | strip
        assign bb_opp_title = bb_style | append: ' Bottom in ' | append: bb_color
      endif
    elsif bb_base_tail == 'Bottom'
      assign bb_paired_piece = 'Top'
      if bb_base == 'Bottom'
        assign bb_opp_title = 'Top in ' | append: bb_color
      else
        assign bb_style = bb_base | remove: ' Bottom' | strip
        assign bb_opp_title = bb_style | append: ' Top in ' | append: bb_color
      endif
    endif

    if bb_opp_title != blank
      if product.handle contains '-top-'
        assign bb_opp_handle = product.handle | replace: '-top-', '-bottom-'
        assign bb_paired_product = all_products[bb_opp_handle]
      elsif product.handle contains '-bottom-'
        assign bb_opp_handle = product.handle | replace: '-bottom-', '-top-'
        assign bb_paired_product = all_products[bb_opp_handle]
      endif

      if bb_paired_product == blank
        for p in collections.all.products
          if p.title == bb_opp_title
            assign bb_paired_product = p
            break
          endif
        endfor
      endif
    endif
  endif

  case cart.currency.iso_code
    when 'EUR'
      assign bb_active_money_format = '€{{amount_with_comma_separator}}'
    when 'THB'
      assign bb_active_money_format = '{{amount}} ฿'
    else
      assign bb_active_money_format = shop.money_format
  endcase
-%}
