{%- comment -%}
  Snippet: size-chart-modal.liquid
  Usage: {% render 'size-chart-modal' %}

  Renders a size guide modal overlay.
  Content is fetched from /pages/size-guide on first open and cached in memory.
  Triggered by any element with class bb-info__size-guide-trigger on the page.
  No section.blocks dependency — data always comes from the live size guide page.
{%- endcomment -%}

<div
  id="bb-size-chart-modal"
  class="scm-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Size Guide"
  hidden
>
  <div class="scm-backdrop" data-scm-close></div>

  <div class="scm-dialog">

    <div class="scm-header">
      <h2 class="scm-heading">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
        Size Guide
      </h2>
      <button type="button" class="scm-close" data-scm-close aria-label="Close size guide">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="scm-body" id="bb-scm-body">
      <div class="scm-loading" id="bb-scm-loading" aria-live="polite">
        <div class="scm-loading__dot"></div>
        <div class="scm-loading__dot"></div>
        <div class="scm-loading__dot"></div>
      </div>
    </div>

  </div>
</div>


<style>
  .scm-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  @media (min-width: 768px) { .scm-overlay { align-items: center; } }
  .scm-overlay[hidden] { display: none; }

  .scm-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(42,37,32,0.5);
    cursor: pointer;
    animation: scm-fade-in 0.25s ease;
  }

  .scm-dialog {
    position: relative;
    z-index: 1;
    background: #ffffff;
    width: 100%;
    max-width: 680px;
    max-height: 92dvh;
    overflow-y: auto;
    border-radius: 16px 16px 0 0;
    padding: 22px 18px 32px;
    animation: scm-slide-up 0.3s cubic-bezier(0.22,1,0.36,1);
    overscroll-behavior: contain;
  }
  @media (min-width: 768px) {
    .scm-dialog {
      border-radius: 14px;
      padding: 28px 28px 32px;
      max-height: 85vh;
      animation: scm-fade-scale 0.25s cubic-bezier(0.22,1,0.36,1);
    }
  }

  .scm-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .scm-heading {
    flex: 1;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #2a2520;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .scm-close {
    background: none;
    border: none;
    padding: 5px;
    cursor: pointer;
    color: #a09890;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.15s, background 0.15s;
  }
  .scm-close:hover { color: #2a2520; background: #f0ece6; }

  /* Loading dots */
  .scm-loading {
    display: flex;
    gap: 6px;
    justify-content: center;
    padding: 40px 0;
  }
  .scm-loading__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #49c6be;
    animation: scm-dot-pulse 1.2s ease-in-out infinite;
  }
  .scm-loading__dot:nth-child(2) { animation-delay: 0.2s; }
  .scm-loading__dot:nth-child(3) { animation-delay: 0.4s; }

  /* Injected content — mirrors size-chart.liquid sc-card internals */
  .scm-body .sc-top-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
    padding: 0;
  }
  .scm-body .sc-unit-toggle {
    display: inline-flex;
    border: 1.5px solid #49c6be;
    border-radius: 999px;
    overflow: hidden;
  }
  .scm-body .sc-unit-btn {
    display: inline-block;
    padding: 3px 12px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    border: none;
    transition: background 0.15s, color 0.15s;
  }
  .scm-body .sc-unit-on  { background: #49c6be; color: #ffffff; }
  .scm-body .sc-unit-off { background: #ffffff;  color: #49c6be; }

  .scm-body .sc-tabs {
    display: flex;
    border-bottom: 1px solid #e8e4dd;
    margin-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .scm-body .sc-tabs::-webkit-scrollbar { display: none; }

  .scm-body .sc-tab {
    display: inline-block;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 9px 13px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #a09890;
    cursor: pointer;
    white-space: nowrap;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .scm-body .sc-tab.is-active {
    color: #49c6be;
    border-bottom-color: #49c6be;
    font-weight: 500;
  }
  .scm-body .sc-tab:not(.is-active):hover {
    color: #2a2520;
    border-bottom-color: #c5e8e6;
  }

  .scm-body .sc-panels { padding: 16px 0 0; }

  .scm-body .sc-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 14px;
    border: 0.5px solid #e8e4dd;
    border-radius: 8px;
    overflow: hidden;
  }
  .scm-body .sc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    color: #2a2520;
    min-width: 300px;
  }
  .scm-body .sc-table thead tr { background: #faf8f4; }
  .scm-body .sc-table th {
    padding: 9px 13px;
    text-align: left;
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #8a8077;
    white-space: nowrap;
    border-bottom: 0.5px solid #e8e4dd;
  }
  .scm-body .sc-table td {
    padding: 10px 13px;
    border-top: 0.5px solid #f0ece6;
  }
  .scm-body .sc-table tbody tr:last-child td { border-bottom: none; }
  .scm-body .sc-table tbody tr:hover td { background: #faf8f4; }
  .scm-body .sc-size-label { font-weight: 500; }

  .scm-body .sc-fit-notes {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    background: #f5fbfa;
    border-left: 1.5px solid #49c6be;
    border-radius: 0;
    padding: 10px 14px;
    margin-bottom: 12px;
    font-size: 0.8125rem;
    color: #3a3530;
    line-height: 1.65;
  }
  .scm-body .sc-fit-notes svg { flex-shrink: 0; margin-top: 2px; }
  .scm-body .sc-fit-notes__text p { margin: 0; }

  .scm-body .sc-between-sizes {
    background: #faf8f4;
    border-radius: 6px;
    padding: 11px 14px;
    margin-bottom: 6px;
    font-size: 0.8125rem;
    color: #6a6560;
    line-height: 1.65;
  }
  .scm-body .sc-between-sizes strong {
    display: flex;
    align-items: center;
    gap: 7px;
    color: #2a2520;
    font-weight: 500;
    margin-bottom: 4px;
    font-size: 0.8125rem;
  }
  .scm-body .sc-between-sizes strong svg { flex-shrink: 0; }
  .scm-body .sc-between-sizes p { margin: 0; }

  .scm-body .sc-empty {
    font-size: 0.8125rem;
    color: #a09890;
    padding: 24px 0;
    text-align: center;
    margin: 0;
  }

  /* Hide elements from the standalone page that aren't needed in modal */
  .scm-body .sc-measure-link { display: none; }

  .scm-error {
    font-size: 0.8125rem;
    color: #a09890;
    text-align: center;
    padding: 32px 0;
  }
  .scm-error a {
    color: #49c6be;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @keyframes scm-fade-in {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes scm-slide-up {
    from { transform: translateY(40px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  @keyframes scm-fade-scale {
    from { transform: scale(0.97); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }
  @keyframes scm-dot-pulse {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40%           { transform: scale(1);   opacity: 1;   }
  }
  @media (prefers-reduced-motion: reduce) {
    .scm-backdrop,
    .scm-dialog,
    .scm-loading__dot { animation: none; }
  }
</style>


<script>
(function () {
  'use strict';

  var modal         = document.getElementById('bb-size-chart-modal');
  var body          = document.getElementById('bb-scm-body');
  var lastTrigger   = null;
  var contentLoaded = false;

  if (!modal || !body) return;

  /* ── Open / close ── */
  function openModal(triggerEl) {
    lastTrigger   = triggerEl || null;
    modal.hidden  = false;
    document.body.style.overflow = 'hidden';
    loadContent();
    var first = modal.querySelector('button:not([data-scm-close])');
    if (first) first.focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
    if (lastTrigger) lastTrigger.focus();
  }

  /* Event delegation — works for any .bb-info__size-guide-trigger on the page */
  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('.bb-info__size-guide-trigger');
    if (trigger) {
      e.preventDefault();
      openModal(trigger);
      return;
    }
    if (!modal.hidden && e.target.closest('[data-scm-close]')) {
      closeModal();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (!modal.hidden && e.key === 'Escape') closeModal();
  });

  /* Focus trap */
  modal.addEventListener('keydown', function (e) {
    if (modal.hidden || e.key !== 'Tab') return;
    var focusable = Array.from(
      modal.querySelectorAll('button, [href], input, [tabindex]:not([tabindex="-1"])')
    ).filter(function (el) {
      return !el.disabled && !el.closest('[hidden]');
    });
    if (!focusable.length) return;
    var first = focusable[0];
    var last  = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault(); last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault(); first.focus();
    }
  });

  /* ── Fetch size guide content from /pages/size-guide ── */
  function loadContent() {
    if (contentLoaded) return;

    fetch('/pages/size-guide')
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.text();
      })
      .then(function (html) {
        var parser = new DOMParser();
        var doc    = parser.parseFromString(html, 'text/html');

        /* Extract the sc-card element which holds all tabs and rows */
        var card = doc.querySelector('.sc-card');

        if (!card) {
          showError();
          return;
        }

        body.innerHTML = '';
        var wrap = document.createElement('div');
        wrap.className = 'scm-body-inner';
        wrap.innerHTML = card.innerHTML;
        body.appendChild(wrap);

        contentLoaded = true;
        initTabs(wrap);
        initUnits(wrap);
      })
      .catch(function () {
        showError();
      });
  }

  function showError() {
    body.innerHTML = '<p class="scm-error">Could not load size guide. <a href="/pages/size-guide">View full page →</a></p>';
  }

  /* ── Re-initialise tab switching on injected DOM ── */
  function initTabs(root) {
    var tabs   = root.querySelectorAll('.sc-tab');
    var panels = root.querySelectorAll('.sc-panel');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var targetId = tab.getAttribute('aria-controls');

        tabs.forEach(function (t) {
          var active = t === tab;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        panels.forEach(function (panel) {
          var active = panel.id === targetId;
          panel.classList.toggle('is-active', active);
          panel.hidden = !active;
        });
      });
    });
  }

  /* ── Re-initialise cm/in unit toggle on injected DOM ── */
  function initUnits(root) {
    var unitBtns = root.querySelectorAll('.sc-unit-btn');

    unitBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var unit = btn.dataset.unit;

        unitBtns.forEach(function (b) {
          b.classList.toggle('sc-unit-on',  b.dataset.unit === unit);
          b.classList.toggle('sc-unit-off', b.dataset.unit !== unit);
          b.setAttribute('aria-pressed', b.dataset.unit === unit ? 'true' : 'false');
        });

        root.querySelectorAll('.unit-in').forEach(function (el) { el.hidden = unit !== 'in'; });
        root.querySelectorAll('.unit-cm').forEach(function (el) { el.hidden = unit !== 'cm'; });
      });
    });
  }

})();
</script>
