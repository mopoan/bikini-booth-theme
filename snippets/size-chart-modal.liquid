{%- comment -%}
  Snippet: size-chart-modal.liquid
  Usage: {% render 'size-chart-modal', section: section %}
  Renders a "Size Guide" trigger link + full modal overlay.
  Rows belong to the tab block that precedes them in block order — no Tab ID needed.
{%- endcomment -%}

<button
  type="button"
  class="scm-trigger"
  aria-haspopup="dialog"
  aria-controls="size-chart-modal-{{ section.id }}"
  aria-expanded="false"
>
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
  {{- section.settings.trigger_label | default: 'Size Guide' -}}
</button>

<div
  id="size-chart-modal-{{ section.id }}"
  class="scm-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Size Guide"
  hidden
>
  <div class="scm-backdrop" data-scm-close></div>

  <div class="scm-dialog">

    <div class="scm-header">
      <h2 class="scm-heading">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
        {{- section.settings.modal_heading | default: 'Size Guide' -}}
      </h2>
      <div class="scm-unit-toggle" role="group" aria-label="Unit of measurement">
        <button type="button" class="scm-unit-btn scm-unit-on" data-unit="in" aria-pressed="true">in</button>
        <button type="button" class="scm-unit-btn scm-unit-off" data-unit="cm" aria-pressed="false">cm</button>
      </div>
      <button type="button" class="scm-close" data-scm-close aria-label="Close size guide">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    {%- liquid
      assign tab_count = 0
      for block in section.blocks
        if block.type == 'tab'
          assign tab_count = tab_count | plus: 1
        endif
      endfor
    -%}

    {%- if tab_count > 0 -%}

      <div class="scm-tabs" role="tablist" aria-label="Size categories">
        {%- assign tab_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'tab' -%}
            <button
              type="button"
              class="scm-tab{%- if tab_index == 0 %} is-active{%- endif -%}"
              role="tab"
              aria-selected="{%- if tab_index == 0 -%}true{%- else -%}false{%- endif -%}"
              aria-controls="scm-panel-{{ section.id }}-{{ block.id }}"
              id="scm-tab-{{ section.id }}-{{ block.id }}"
              data-tab="{{ block.id }}"
            >
              {{- block.settings.tab_label | default: 'Tops' -}}
            </button>
            {%- assign tab_index = tab_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="scm-panels">
        {%- assign current_tab = nil -%}
        {%- assign tab_index = 0 -%}
        {%- assign open_panel = false -%}
        {%- assign panel_has_rows = false -%}

        {%- for block in section.blocks -%}

          {%- if block.type == 'tab' -%}

            {%- if open_panel -%}
                  {%- unless panel_has_rows -%}
                    <tr><td colspan="4" class="scm-empty-cell">No sizing data added yet.</td></tr>
                  {%- endunless -%}
                  </tbody></table></div>
                {%- if current_tab.settings.fit_notes != blank -%}
                  <div class="scm-fit-notes">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                    <div class="scm-fit-notes__text">{{ current_tab.settings.fit_notes }}</div>
                  </div>
                {%- endif -%}
                {%- if current_tab.settings.between_sizes != blank -%}
                  <div class="scm-between-sizes">
                    <strong>
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12H3M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4"/></svg>
                      Between sizes?
                    </strong>
                    {{ current_tab.settings.between_sizes }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- assign current_tab = block -%}
            {%- assign is_first = false -%}
            {%- if tab_index == 0 -%}{%- assign is_first = true -%}{%- endif -%}
            <div
              id="scm-panel-{{ section.id }}-{{ block.id }}"
              class="scm-panel{%- if is_first %} is-active{%- endif -%}"
              role="tabpanel"
              aria-labelledby="scm-tab-{{ section.id }}-{{ block.id }}"
              {%- unless is_first %} hidden{%- endunless -%}
            >
              <div class="scm-table-wrap">
                <table class="scm-table" aria-label="{{ block.settings.tab_label }} size chart">
                  <thead>
                    <tr>
                      <th scope="col">Size</th>
                      <th scope="col"><span class="unit-in">Bust (in)</span><span class="unit-cm" hidden>Bust (cm)</span></th>
                      <th scope="col"><span class="unit-in">Waist (in)</span><span class="unit-cm" hidden>Waist (cm)</span></th>
                      <th scope="col"><span class="unit-in">Hips (in)</span><span class="unit-cm" hidden>Hips (cm)</span></th>
                    </tr>
                  </thead>
                  <tbody>
            {%- assign open_panel = true -%}
            {%- assign tab_index = tab_index | plus: 1 -%}
            {%- assign panel_has_rows = false -%}

          {%- elsif block.type == 'size_row' and open_panel -%}
            {%- assign panel_has_rows = true -%}
            <tr>
              <td class="scm-size-label">{{ block.settings.size_label | default: 'XS' }}</td>
              <td><span class="unit-in">{{ block.settings.bust_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.bust_cm | default: '—' }}</span></td>
              <td><span class="unit-in">{{ block.settings.waist_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.waist_cm | default: '—' }}</span></td>
              <td><span class="unit-in">{{ block.settings.hips_in | default: '—' }}</span><span class="unit-cm" hidden>{{ block.settings.hips_cm | default: '—' }}</span></td>
            </tr>
          {%- endif -%}

        {%- endfor -%}

        {%- if open_panel -%}
                {%- unless panel_has_rows -%}
                  <tr><td colspan="4" class="scm-empty-cell">No sizing data added yet.</td></tr>
                {%- endunless -%}
                </tbody></table></div>
              {%- if current_tab.settings.fit_notes != blank -%}
                <div class="scm-fit-notes">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                  <div class="scm-fit-notes__text">{{ current_tab.settings.fit_notes }}</div>
                </div>
              {%- endif -%}
              {%- if current_tab.settings.between_sizes != blank -%}
                <div class="scm-between-sizes">
                  <strong>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12H3M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4"/></svg>
                    Between sizes?
                  </strong>
                  {{ current_tab.settings.between_sizes }}
                </div>
              {%- endif -%}
            </div>
        {%- endif -%}

      </div>

    {%- else -%}
      <p class="scm-empty">No size data available yet.</p>
    {%- endif -%}

  </div>
</div>


<style>
  .scm-trigger {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 0.8125rem;
    font-family: inherit;
    color: #49c6be;
    text-decoration: underline;
    text-underline-offset: 2px;
    letter-spacing: 0.02em;
    transition: opacity 0.15s;
  }
  .scm-trigger:hover { opacity: 0.75; }

  .scm-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  @media (min-width: 768px) { .scm-overlay { align-items: center; } }
  .scm-overlay[hidden] { display: none; }

  .scm-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(42,37,32,0.5);
    cursor: pointer;
    animation: scm-fade-in 0.25s ease;
  }

  .scm-dialog {
    position: relative;
    z-index: 1;
    background: #ffffff;
    width: 100%;
    max-width: 680px;
    max-height: 92dvh;
    overflow-y: auto;
    border-radius: 16px 16px 0 0;
    padding: 22px 18px 32px;
    animation: scm-slide-up 0.3s cubic-bezier(0.22,1,0.36,1);
    overscroll-behavior: contain;
  }
  @media (min-width: 768px) {
    .scm-dialog {
      border-radius: 14px;
      padding: 28px 28px 32px;
      max-height: 85vh;
      animation: scm-fade-scale 0.25s cubic-bezier(0.22,1,0.36,1);
    }
  }

  .scm-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .scm-heading {
    flex: 1;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #2a2520;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .scm-unit-toggle {
    display: inline-flex;
    border: 1.5px solid #49c6be;
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .scm-unit-btn {
    display: inline-block;
    padding: 3px 12px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    border: none;
    transition: background 0.15s, color 0.15s;
  }

  .scm-unit-on  { background: #49c6be; color: #ffffff; }
  .scm-unit-off { background: #ffffff;  color: #49c6be; }

  .scm-close {
    background: none;
    border: none;
    padding: 5px;
    cursor: pointer;
    color: #a09890;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.15s, background 0.15s;
  }
  .scm-close:hover { color: #2a2520; background: #f0ece6; }

  .scm-tabs {
    display: flex;
    border-bottom: 1px solid #e8e4dd;
    margin-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .scm-tabs::-webkit-scrollbar { display: none; }

  .scm-tab {
    display: inline-block;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 9px 13px;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #a09890;
    cursor: pointer;
    white-space: nowrap;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .scm-tab.is-active { color: #49c6be; border-bottom-color: #49c6be; font-weight: 500; }
  .scm-tab:not(.is-active):hover { color: #2a2520; border-bottom-color: #c5e8e6; }

  .scm-panels { padding: 16px 0 0; }

  .scm-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 14px;
    border: 0.5px solid #e8e4dd;
    border-radius: 8px;
    overflow: hidden;
  }

  .scm-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    color: #2a2520;
    min-width: 300px;
  }
  .scm-table thead tr { background: #faf8f4; }
  .scm-table th {
    padding: 9px 13px;
    text-align: left;
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #8a8077;
    white-space: nowrap;
    border-bottom: 0.5px solid #e8e4dd;
  }
  .scm-table td { padding: 10px 13px; border-top: 0.5px solid #f0ece6; }
  .scm-table tbody tr:last-child td { border-bottom: none; }
  .scm-table tbody tr:hover td { background: #faf8f4; }
  .scm-size-label { font-weight: 500; }

  .scm-empty-cell {
    text-align: center;
    color: #a09890;
    font-size: 0.8125rem;
    padding: 24px 13px;
  }

  .scm-fit-notes {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    background: #f5fbfa;
    border-left: 1.5px solid #49c6be;
    padding: 10px 14px;
    margin-bottom: 12px;
    font-size: 0.8125rem;
    color: #3a3530;
    line-height: 1.65;
  }
  .scm-fit-notes svg { flex-shrink: 0; margin-top: 2px; }
  .scm-fit-notes__text p { margin: 0; }

  .scm-between-sizes {
    background: #faf8f4;
    border-radius: 6px;
    padding: 11px 14px;
    margin-bottom: 6px;
    font-size: 0.8125rem;
    color: #6a6560;
    line-height: 1.65;
  }
  .scm-between-sizes strong {
    display: flex;
    align-items: center;
    gap: 7px;
    color: #2a2520;
    font-weight: 500;
    margin-bottom: 4px;
    font-size: 0.8125rem;
  }
  .scm-between-sizes strong svg { flex-shrink: 0; }
  .scm-between-sizes p { margin: 0; }

  .scm-empty {
    font-size: 0.8125rem;
    color: #a09890;
    padding: 24px 0;
    text-align: center;
  }

  @keyframes scm-fade-in {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes scm-slide-up {
    from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; }
  }
  @keyframes scm-fade-scale {
    from { transform: scale(0.97); opacity: 0; } to { transform: scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scm-backdrop, .scm-dialog { animation: none !important; }
  }
</style>


<script>
(function () {
  'use strict';

  var modalId = 'size-chart-modal-{{ section.id }}';
  var modal   = document.getElementById(modalId);
  var trigger = modal ? modal.previousElementSibling : null;
  if (!modal || !trigger) return;

  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    trigger.setAttribute('aria-expanded', 'true');
    var first = modal.querySelector('button:not([data-scm-close])');
    if (first) first.focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
    trigger.setAttribute('aria-expanded', 'false');
    trigger.focus();
  }

  trigger.addEventListener('click', openModal);
  modal.addEventListener('click', function (e) {
    if (e.target.closest('[data-scm-close]')) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (!modal.hidden && e.key === 'Escape') closeModal();
  });

  modal.addEventListener('keydown', function (e) {
    if (modal.hidden || e.key !== 'Tab') return;
    var focusable = Array.from(
      modal.querySelectorAll('button, [href], input, [tabindex]:not([tabindex="-1"])')
    ).filter(function (el) { return !el.disabled && !el.closest('[hidden]'); });
    if (!focusable.length) return;
    var first = focusable[0], last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });

  var unitBtns = modal.querySelectorAll('.scm-unit-btn');
  unitBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var unit = btn.dataset.unit;
      unitBtns.forEach(function (b) {
        b.classList.toggle('scm-unit-on', b.dataset.unit === unit);
        b.classList.toggle('scm-unit-off', b.dataset.unit !== unit);
        b.setAttribute('aria-pressed', b.dataset.unit === unit ? 'true' : 'false');
      });
      modal.querySelectorAll('.unit-in').forEach(function (el) { el.hidden = unit !== 'in'; });
      modal.querySelectorAll('.unit-cm').forEach(function (el) { el.hidden = unit !== 'cm'; });
    });
  });

  var tabs   = modal.querySelectorAll('.scm-tab');
  var panels = modal.querySelectorAll('.scm-panel');
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var targetId = 'scm-panel-{{ section.id }}-' + tab.dataset.tab;
      tabs.forEach(function (t) {
        var active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach(function (panel) {
        var active = panel.id === targetId;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    });
  });

})();
</script>
