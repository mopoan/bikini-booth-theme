{% comment %}
  Subframe-style product tile. Args: product, section, tile_index (optional, for stock fallback)
{% endcomment %}
{%- liquid
  assign featured = product.featured_media
  assign tile_img_alt = product.title | escape
  assign color_opt = product.options_by_name['Color']
  if color_opt == blank
    assign color_opt = product.options_by_name['Colour']
  endif
  assign swatch_hex = '#ff6b5a,#1a1a1a,#9e3b5c,#8b7355,#c4a87a,#6b3a3a,#2d5a27,#c9a84c,#f5f0e8,#5a7a6a' | split: ','
  assign ti = tile_index | default: 0
-%}
{%- capture stock_fallback_src -%}{%- render 'bb-subframe-stock-url', index: ti -%}{%- endcapture -%}
<article class="bb-subframe-ptile">
  <a class="bb-subframe-ptile__media" href="{{ product.url }}">
    {%- if featured != blank -%}
      {%- assign tile_ar = featured.aspect_ratio | default: 1 -%}
      {%- if tile_ar == 0 -%}{%- assign tile_ar = 1 -%}{%- endif -%}
      {%- assign tile_img_h = 700 | divided_by: tile_ar | round -%}
      <img
        src="{{ featured | image_url: width: 700 }}"
        alt="{{ tile_img_alt }}"
        loading="lazy"
        width="700"
        height="{{ tile_img_h }}"
        decoding="async"
      >
    {%- else -%}
      <img src="{{ stock_fallback_src | strip }}" alt="{{ product.title | escape }}" width="400" height="533" loading="lazy">
    {%- endif -%}
    {%- if section.settings.badge_text != blank -%}
      <span class="bb-subframe-ptile__badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}
  </a>
  <div class="bb-subframe-ptile__info">
    <a href="{{ product.url }}">
      <h3 class="bb-subframe-ptile__title">{{ product.title | downcase }}</h3>
    </a>
    {%- if settings.cart_type != 'catalog_mode' -%}
      <div class="bb-subframe-ptile__price">
        {%- comment -%} body2 keeps price smaller than theme card h4/h5; styling in bb-subframe-homepage.css {%- endcomment -%}
        {%- render 'price', product: product, size: 'body2' -%}
      </div>
    {%- endif -%}
    {%- if color_opt != blank and color_opt.values.size > 0 -%}
      <div class="bb-subframe-ptile__swatches">
        {%- for value in color_opt.values limit: 4 -%}
          {%- assign ci = forloop.index0 | modulo: swatch_hex.size -%}
          <span class="bb-subframe-swatch" style="background: {{ swatch_hex[ci] }};" aria-hidden="true"></span>
        {%- endfor -%}
        {%- if color_opt.values.size > 4 -%}
          <a class="bb-subframe-ptile__more-colors" href="{{ product.url }}">+{{ color_opt.values.size | minus: 4 }} colors</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</article>
