{%- comment -%}
  Snippet: bb-product-form.liquid
  Purpose: Product purchase form for Bikini Booth.
  Renders: piece toggle, color swatches, size selector, ATC button, wishlist.

  Requires: bb-product-auto-connect.liquid rendered before this snippet.
  Listens for: bb:productDataReady custom event.

  Usage: {% render 'bb-product-form' %}

  Wishlist:
    Hooks into the theme's existing wishlist button via data-wishlist-handle.
    If your theme uses a different selector, update .bb-wl-btn below.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_price = current_variant.price | money
-%}

<div class="bb-form" id="bb-form-{{ section.id }}" data-product-id="{{ product.id }}" data-section-id="{{ section.id }}">

  {%- comment -%} ── Product meta ── {%- endcomment -%}
  <div class="bb-form__meta">
    <h1 class="bb-form__title">{{ product.title | split: ' - ' | first }}</h1>
    {%- if product.metafields.custom.tagline != blank -%}
      <p class="bb-form__tagline">{{ product.metafields.custom.tagline }}</p>
    {%- elsif product.description != blank -%}
      <p class="bb-form__tagline">{{ product.description | strip_html | truncate: 120 }}</p>
    {%- endif -%}
    <div class="bb-form__stock">
      {%- if current_variant.available -%}
        <span class="bb-form__in-stock">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3a7d44" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          In stock
        </span>
      {%- else -%}
        <span class="bb-form__out-of-stock">Out of stock</span>
      {%- endif -%}
    </div>
    <div class="bb-form__price-row">
      <span class="bb-form__price" id="bb-price">{{ product_price }}</span>
      <span class="bb-form__price-note">{{ section.settings.price_note | default: 'Top and bottom sold separately.' }}</span>
    </div>
    <div class="bb-form__links">
      {%- if section.settings.ask_question_url != blank -%}
        <a href="{{ section.settings.ask_question_url }}" class="bb-form__link">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Ask a question
        </a>
      {%- endif -%}
      <span class="bb-form__link-divider"></span>
      <button type="button" class="bb-form__link bb-size-guide-trigger" aria-haspopup="dialog" aria-controls="size-chart-modal-{{ section.id }}">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
        Size guide
      </button>
    </div>
  </div>

  {%- comment -%} ── Piece toggle (bikinis only) ── {%- endcomment -%}
  <div class="bb-form__section bb-piece-section" id="bb-piece-section" hidden>
    <div class="bb-form__section-label">Choose your piece</div>
    <div class="bb-piece-toggle" role="group" aria-label="Choose your piece">
      <a class="bb-piece-btn" id="bb-piece-top" href="#" aria-label="Shop Top">
        <span class="bb-piece-btn__name">Top</span>
        <span class="bb-piece-btn__price" id="bb-piece-top-price"></span>
      </a>
      <a class="bb-piece-btn" id="bb-piece-bottom" href="#" aria-label="Shop Bottom">
        <span class="bb-piece-btn__name">Bottom</span>
        <span class="bb-piece-btn__price" id="bb-piece-bottom-price"></span>
      </a>
    </div>
  </div>

  {%- comment -%} ── Color swatches ── {%- endcomment -%}
  <div class="bb-form__section">
    <div class="bb-form__section-label">
      Choose your color
      <span class="bb-form__section-value" id="bb-color-label"></span>
    </div>
    <div class="bb-swatches" id="bb-swatches" role="list" aria-label="Color options">
      {%- comment -%} Populated by bb:productDataReady event {%- endcomment -%}
      <div class="bb-swatches__loading" aria-live="polite">
        <div class="bb-swatch-placeholder"></div>
        <div class="bb-swatch-placeholder"></div>
        <div class="bb-swatch-placeholder"></div>
      </div>
    </div>
  </div>

  {%- comment -%} ── Size selector ── {%- endcomment -%}
  <div class="bb-form__section">
    <div class="bb-form__section-label">Choose your size</div>
    <div class="bb-sizes" role="group" aria-label="Choose your size" id="bb-sizes">
      {%- for variant in product.variants -%}
        {%- assign opt = variant.title -%}
        <button
          type="button"
          class="bb-size-btn{%- if variant == current_variant %} is-active{%- endif -%}{%- unless variant.available %} is-sold-out{%- endunless -%}"
          data-variant-id="{{ variant.id }}"
          data-variant-price="{{ variant.price | money }}"
          data-available="{{ variant.available }}"
          {%- unless variant.available %} aria-label="{{ opt }} — sold out"{%- else %} aria-label="{{ opt }}"{%- endunless -%}
          {%- unless variant.available %} aria-disabled="true"{%- endunless -%}
        >
          {{ opt }}
        </button>
      {%- endfor -%}
    </div>
    <button type="button" class="bb-form__link bb-size-guide-trigger" style="margin-top: 6px;" aria-haspopup="dialog" aria-controls="size-chart-modal-{{ section.id }}">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h18M3 10h18M3 15h18M3 20h18"/><path d="M5 3v4M9 3v2M13 3v4M17 3v2M21 3v4"/></svg>
      Not sure? View size guide
    </button>
    <div class="bb-size-error" id="bb-size-error" role="alert" aria-live="polite" hidden>
      Please select a size before adding to cart.
    </div>
  </div>

  {%- comment -%} ── Add to cart + wishlist ── {%- endcomment -%}
  <div class="bb-form__atc-row">
    <form method="post" action="/cart/add" id="bb-atc-form" class="bb-atc-form">
      <input type="hidden" name="id" id="bb-variant-id" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button
        type="submit"
        class="bb-atc-btn"
        id="bb-atc-btn"
        {%- unless current_variant.available %} disabled aria-disabled="true"{%- endunless -%}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span id="bb-atc-label">Add to cart</span>
        <span class="bb-atc-btn__price" id="bb-atc-price">— {{ product_price }}</span>
      </button>
    </form>

    {%- comment -%} Wishlist — hooks into theme's existing wishlist functionality {%- endcomment -%}
    <button
      type="button"
      class="bb-wl-btn"
      data-wishlist-handle="{{ product.handle }}"
      data-wishlist-product-id="{{ product.id }}"
      aria-label="Add {{ product.title }} to wishlist"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>
  </div>

  {%- comment -%} ── Trust bar ── {%- endcomment -%}
  <div class="bb-trust-bar">
    <div class="bb-trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      <span>Free shipping over $250</span>
    </div>
    <div class="bb-trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>Ships from Thailand</span>
    </div>
    <div class="bb-trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>
      <span>30-day returns</span>
    </div>
    <div class="bb-trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span>Secure checkout</span>
    </div>
  </div>

  {%- comment -%} ── Fit note ── {%- endcomment -%}
  {%- if section.settings.fit_note != blank -%}
    <div class="bb-fit-note">
      <div class="bb-fit-note__text">
        <div class="bb-fit-note__label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#49c6be" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Fit note
        </div>
        <div class="bb-fit-note__body">{{ section.settings.fit_note }}</div>
      </div>
      {%- if section.settings.fit_note_image != blank -%}
        <div class="bb-fit-note__img">
          <img
            src="{{ section.settings.fit_note_image | image_url: width: 120 }}"
            alt="Model wearing {{ product.title }}"
            width="60"
            height="75"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>


<style>
  .bb-form {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #ffffff;
    padding: 22px 22px 0;
  }

  /* Meta */
  .bb-form__meta { padding-bottom: 14px; border-bottom: 0.5px solid #f0ece6; margin-bottom: 14px; }
  .bb-form__title { font-size: 1rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: #2a2520; margin-bottom: 4px; }
  .bb-form__tagline { font-size: 0.75rem; color: #8a8077; line-height: 1.5; margin-bottom: 8px; }
  .bb-form__stock { margin-bottom: 5px; }
  .bb-form__in-stock { display: inline-flex; align-items: center; gap: 5px; font-size: 0.75rem; color: #3a7d44; }
  .bb-form__out-of-stock { font-size: 0.75rem; color: #a09890; }
  .bb-form__price-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
  .bb-form__price { font-size: 1rem; font-weight: 500; color: #2a2520; }
  .bb-form__price-note { font-size: 0.6875rem; color: #49c6be; }
  .bb-form__links { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
  .bb-form__link { display: inline-flex; align-items: center; gap: 4px; font-size: 0.6875rem; color: #49c6be; text-decoration: underline; text-underline-offset: 2px; background: none; border: none; padding: 0; cursor: pointer; font-family: inherit; transition: opacity 0.15s; }
  .bb-form__link:hover { opacity: 0.75; }
  .bb-form__link-divider { width: 0.5px; height: 11px; background: #d8d3cc; flex-shrink: 0; }
  .bb-form__section-value { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.75rem; color: #2a2520; }

  /* Section wrapper */
  .bb-form__section { padding-bottom: 14px; margin-bottom: 14px; border-bottom: 0.5px solid #f0ece6; }
  .bb-form__section-label { font-size: 0.625rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: #2a2520; margin-bottom: 9px; display: flex; align-items: center; gap: 6px; }

  /* Piece toggle */
  .bb-piece-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .bb-piece-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 9px 8px; border: 1.5px solid #e0dbd3; border-radius: 8px; background: #ffffff; text-decoration: none; text-align: center; transition: border-color 0.15s, background 0.15s; }
  .bb-piece-btn.is-active { border-color: #49c6be; background: #f0faf9; }
  .bb-piece-btn__name { font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: #2a2520; margin-bottom: 2px; }
  .bb-piece-btn.is-active .bb-piece-btn__name { color: #49c6be; }
  .bb-piece-btn__price { font-size: 0.625rem; color: #8a8077; }
  .bb-piece-btn.is-active .bb-piece-btn__price { color: #49c6be; }

  /* Color swatches */
  .bb-swatches { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .bb-swatches__loading { display: flex; gap: 8px; }
  .bb-swatch-placeholder { width: 26px; height: 26px; border-radius: 50%; background: #f0ece6; }
  .bb-swatch { width: 26px; height: 26px; border-radius: 50%; cursor: pointer; display: block; border: none; padding: 0; background-size: cover; background-position: center; transition: opacity 0.15s; flex-shrink: 0; }
  .bb-swatch:hover { opacity: 0.85; }
  .bb-swatch.is-active { outline: 2px solid #49c6be; outline-offset: 3px; }
  .bb-swatch.is-unavailable { opacity: 0.4; cursor: not-allowed; }

  /* Size buttons */
  .bb-sizes { display: flex; gap: 6px; flex-wrap: wrap; }
  .bb-size-btn { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; border: 1px solid #d0cbc4; background: #ffffff; color: #2a2520; font-size: 0.6875rem; font-family: inherit; cursor: pointer; transition: border-color 0.15s, background 0.15s, color 0.15s; }
  .bb-size-btn.is-active { border: 1.5px solid #2a2520; font-weight: 500; }
  .bb-size-btn.is-sold-out { border-color: #e8e4dd; background: #faf8f4; color: #c8c0b8; text-decoration: line-through; cursor: not-allowed; }
  .bb-size-btn:not(.is-sold-out):hover { border-color: #2a2520; }
  .bb-size-error { font-size: 0.75rem; color: #c0392b; margin-top: 8px; display: flex; align-items: center; gap: 5px; }

  /* ATC row */
  .bb-form__atc-row { display: flex; gap: 8px; align-items: center; padding-bottom: 14px; margin-bottom: 0; }
  .bb-atc-form { flex: 1; }
  .bb-atc-btn { width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 7px; background: #49c6be; color: #ffffff; border: none; border-radius: 999px; padding: 13px 16px; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; cursor: pointer; font-family: inherit; transition: opacity 0.15s; }
  .bb-atc-btn:hover { opacity: 0.9; }
  .bb-atc-btn:disabled { background: #c8c0b8; cursor: not-allowed; opacity: 1; }
  .bb-atc-btn svg { flex-shrink: 0; stroke: #ffffff; }
  .bb-atc-btn__price { opacity: 0.85; font-weight: 400; }
  .bb-wl-btn { width: 44px; height: 44px; border-radius: 50%; border: 1.5px solid #e0dbd3; background: #ffffff; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; transition: border-color 0.15s; }
  .bb-wl-btn:hover { border-color: #49c6be; }
  .bb-wl-btn svg { stroke: #a09890; }
  .bb-wl-btn.is-active svg { stroke: #49c6be; fill: #49c6be; }

  /* Trust bar */
  .bb-trust-bar { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; padding: 12px 0; border-top: 0.5px solid #f0ece6; border-bottom: 0.5px solid #f0ece6; }
  .bb-trust-item { display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; }
  .bb-trust-item span { font-size: 0.5625rem; color: #6a6560; line-height: 1.35; }

  /* Fit note */
  .bb-fit-note { background: #f0faf9; margin: 0 -22px; padding: 12px 22px; display: flex; gap: 12px; align-items: flex-start; }
  .bb-fit-note__text { flex: 1; }
  .bb-fit-note__label { font-size: 0.625rem; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; color: #2a7a74; margin-bottom: 5px; display: flex; align-items: center; gap: 5px; }
  .bb-fit-note__body { font-size: 0.6875rem; color: #3a6a65; line-height: 1.6; }
  .bb-fit-note__img { flex-shrink: 0; }
  .bb-fit-note__img img { width: 60px; height: 75px; object-fit: cover; border-radius: 5px; display: block; }

  @media (max-width: 767px) {
    .bb-form { padding: 14px 14px 0; }
    .bb-fit-note { margin: 0 -14px; padding: 12px 14px; }
    .bb-trust-bar { grid-template-columns: repeat(2,1fr); gap: 8px; }
    .bb-trust-item { flex-direction: row; text-align: left; gap: 6px; }
  }
</style>


<script>
(function () {
  'use strict';

  var form       = document.getElementById('bb-form-{{ section.id }}');
  if (!form) return;

  var swatchWrap    = document.getElementById('bb-swatches');
  var pieceSection  = document.getElementById('bb-piece-section');
  var pieceTopBtn   = document.getElementById('bb-piece-top');
  var pieceBottomBtn= document.getElementById('bb-piece-bottom');
  var pieceTopPrice = document.getElementById('bb-piece-top-price');
  var pieceBotPrice = document.getElementById('bb-piece-bottom-price');
  var colorLabel    = document.getElementById('bb-color-label');
  var sizeButtons   = form.querySelectorAll('.bb-size-btn');
  var variantInput  = document.getElementById('bb-variant-id');
  var atcBtn        = document.getElementById('bb-atc-btn');
  var atcPrice      = document.getElementById('bb-atc-price');
  var atcLabel      = document.getElementById('bb-atc-label');
  var sizeError     = document.getElementById('bb-size-error');
  var selectedVariantId = null;

  /* ── Listen for auto-connect data ── */
  document.addEventListener('bb:productDataReady', function (e) {
    var data = e.detail;

    /* Piece toggle */
    if (data.hasPieceToggle) {
      pieceSection.hidden = false;

      var currentPiece = data.piece;
      var oppPiece     = currentPiece === 'Top' ? 'Bottom' : 'Top';

      if (currentPiece === 'Top') {
        pieceTopBtn.classList.add('is-active');
        pieceTopBtn.href = data.url;
        if (data.pieceLinks['Bottom']) {
          pieceBottomBtn.href = data.pieceLinks['Bottom'].url;
          if (data.pieceLinks['Bottom'].price) {
            pieceBotPrice.textContent = formatPrice(data.pieceLinks['Bottom'].price);
          }
        }
      } else {
        pieceBottomBtn.classList.add('is-active');
        pieceBottomBtn.href = data.url;
        if (data.pieceLinks['Top']) {
          pieceTopBtn.href = data.pieceLinks['Top'].url;
          if (data.pieceLinks['Top'].price) {
            pieceTopPrice.textContent = formatPrice(data.pieceLinks['Top'].price);
          }
        }
      }

      /* Set price for current piece from first available variant */
      var currentPrice = '{{ current_variant.price | money }}';
      if (currentPiece === 'Top') {
        pieceTopPrice.textContent = currentPrice;
      } else {
        pieceBotPrice.textContent = currentPrice;
      }
    }

    /* Color swatches */
    if (data.colorSwatches && data.colorSwatches.length > 0) {
      swatchWrap.innerHTML = '';
      if (colorLabel) colorLabel.textContent = data.color || '';

      data.colorSwatches.forEach(function (swatch) {
        var btn = document.createElement('a');
        btn.href        = swatch.url;
        btn.className   = 'bb-swatch' +
          (swatch.active      ? ' is-active'      : '') +
          (!swatch.available  ? ' is-unavailable' : '');
        btn.setAttribute('aria-label', swatch.color + (swatch.available ? '' : ' — sold out'));
        btn.setAttribute('role', 'listitem');
        btn.title = swatch.color;

        if (swatch.useImage) {
          btn.style.backgroundImage = 'url(' + swatch.imageUrl + ')';
          btn.style.backgroundSize  = 'cover';
        } else {
          btn.style.background = swatch.hex;
          if (swatch.hex === '#ffffff') {
            btn.style.border = '1px solid #e0dbd3';
          }
        }

        swatchWrap.appendChild(btn);
      });
    }
  });

  /* ── Size selection ── */
  sizeButtons.forEach(function (btn) {
    if (btn.dataset.available === 'false') return;
    btn.addEventListener('click', function () {
      sizeButtons.forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      selectedVariantId = btn.dataset.variantId;
      if (variantInput) variantInput.value = selectedVariantId;
      if (atcPrice) atcPrice.textContent = '— ' + btn.dataset.variantPrice;
      if (sizeError) sizeError.hidden = true;
    });
  });

  /* ── ATC validation ── */
  if (atcBtn) {
    atcBtn.closest('form').addEventListener('submit', function (e) {
      var hasSelected = form.querySelector('.bb-size-btn.is-active');
      if (!hasSelected) {
        e.preventDefault();
        if (sizeError) sizeError.hidden = false;
        form.querySelector('.bb-size-btn:not(.is-sold-out)').focus();
        return;
      }
      if (atcLabel) atcLabel.textContent = 'Adding...';
      atcBtn.disabled = true;
      setTimeout(function () {
        if (atcLabel) atcLabel.textContent = 'Add to cart';
        atcBtn.disabled = false;
      }, 1800);
    });
  }

  /* ── Wishlist — hook into theme ── */
  var wlBtn = form.querySelector('.bb-wl-btn');
  if (wlBtn) {
    wlBtn.addEventListener('click', function () {
      var handle = wlBtn.dataset.wishlistHandle;
      wlBtn.classList.toggle('is-active');
      /* Fire theme wishlist event if available */
      document.dispatchEvent(new CustomEvent('wishlist:toggle', {
        detail: { handle: handle, productId: wlBtn.dataset.wishlistProductId }
      }));
    });
  }

  function formatPrice(cents) {
    if (!cents) return '';
    var amount = (parseInt(cents, 10) / 100).toFixed(2);
    return amount.replace(/\B(?=(\d{3})+(?!\d))/g, ',') + ' THB';
  }

})();
