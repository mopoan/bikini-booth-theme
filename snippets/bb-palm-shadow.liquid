{%- liquid
  assign bb_palm_shadow_url = 'https://cdn.shopify.com/s/files/1/1006/3341/1874/files/palm_leaf.png?v=1782343118'
  if src != blank
    assign bb_palm_shadow_url = src
  endif
  assign palm_mod = modifier | default: 'default'
  assign palm_width = width | default: 200
  assign palm_height = height | default: 280
-%}
<img
  class="bb-palm-shadow bb-palm-shadow--{{ palm_mod }}"
  src="{{ bb_palm_shadow_url }}"
  alt=""
  width="{{ palm_width }}"
  height="{{ palm_height }}"
  loading="lazy"
  decoding="async"
  aria-hidden="true"
>
