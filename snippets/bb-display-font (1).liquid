{%- comment -%}
  Snippet: bb-display-font.liquid
  Purpose: Loads Cormorant Garamond (self-hosted) and applies it as the
           editorial display font for MAJOR headings site-wide (h1 + h2),
           while leaving the rounded Futura UI font in place everywhere else.

  Additive only — never changes the global body / UI font.

  Usage (rendered once from <head> in layout/theme.liquid):
      {%- render 'bb-display-font' -%}

  Requires in /assets:
    CormorantGaramond-Medium.woff2     (weight 500)
    CormorantGaramond-SemiBold.woff2   (weight 600)

  How application works:
    - h1 + h2 under body.bb-root -> Cormorant (section & page titles).
      Only font-family is forced, so weight auto-maps to the loaded
      500/600 faces: bold headings render 600, normal ones render 500.
    - Functional UI that happens to be an h1/h2 (footer, header logo)
      is reset back to the rounded font.
    - class "bb-keep-rounded"   -> force ANY heading back to Futura.
    - class "bb-display-heading" -> promote an h3+ heading to Cormorant.
    - "bb-display-heading--medium" -> lighter 500 treatment.
{%- endcomment -%}

<link rel="preload" as="font" type="font/woff2" crossorigin
      href="{{ 'CormorantGaramond-SemiBold.woff2' | asset_url }}">
<link rel="preload" as="font" type="font/woff2" crossorigin
      href="{{ 'CormorantGaramond-Medium.woff2' | asset_url }}">

<style>
  @font-face {
    font-family: "Cormorant Garamond";
    font-style: normal;
    font-weight: 500;
    font-display: swap;
    src: url("{{ 'CormorantGaramond-Medium.woff2' | asset_url }}") format("woff2");
  }
  @font-face {
    font-family: "Cormorant Garamond";
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: url("{{ 'CormorantGaramond-SemiBold.woff2' | asset_url }}") format("woff2");
  }

  :root {
    --font-display: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  }

  /* ── Major headings → editorial display font (site-wide) ──
     Only font-family is forced; weight maps to the loaded 500/600 faces. */
  body.bb-root h1,
  body.bb-root h2 {
    font-family: var(--font-display) !important;
    letter-spacing: -0.015em;
  }

  /* ── Keep functional / small UI in the rounded sans (Futura) ──
     Footer column titles, header logo, and anything opted out. */
  body.bb-root .footer__content :is(h1, h2),
  body.bb-root .section-header :is(h1, h2),
  body.bb-root .bb-keep-rounded,
  body.bb-root .bb-keep-rounded :is(h1, h2, h3, h4, h5, h6) {
    font-family: var(--bb-font-futura) !important;
    letter-spacing: normal;
  }

  /* ── Opt-in: promote a non-h1/h2 heading (e.g. an h3 section title) ── */
  .bb-display-heading {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .bb-display-heading--medium {
    font-weight: 500;
  }

  /* Mobile: relax tracking so display type stays readable */
  @media (max-width: 749px) {
    body.bb-root h1,
    body.bb-root h2,
    .bb-display-heading {
      letter-spacing: -0.01em;
    }
  }
</style>
