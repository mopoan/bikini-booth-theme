{% doc %}
  @prompt
    Create a custom Instagram Reels gallery section for a Shopify theme. The section should allow the merchant to add multiple reel items, each with a link URL (to the Instagram reel) and a vertical thumbnail image (portrait/9:16 ratio like a reel). The merchant should be able to configure how many reels to display via a section setting. Each reel thumbnail should be clickable and open the link in a new tab. Display the reels in a horizontal scrollable row with a play button icon overlay on each thumbnail, and an optional title/label below. The section should be fully mobile responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reels-gallery-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-reels-gallery-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
  }

  .ai-reels-gallery-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: {{ block.settings.title_spacing }}px;
  }

  .ai-reels-gallery-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-reels-gallery-scroll-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-reels-gallery-scroll-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.reel_spacing }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 10px 0;
  }

  .ai-reels-gallery-scroll-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-reels-gallery-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.reel_width }}px;
    position: relative;
  }

  .ai-reels-gallery-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-reels-gallery-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background-color: {{ block.settings.placeholder_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-reels-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-reels-gallery-link-{{ ai_gen_id }}:hover .ai-reels-gallery-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-reels-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-reels-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-reels-gallery-play-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_icon_size }}px;
    height: {{ block.settings.play_icon_size }}px;
    background-color: {{ block.settings.play_icon_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    pointer-events: none;
    z-index: 2;
  }

  .ai-reels-gallery-link-{{ ai_gen_id }}:hover .ai-reels-gallery-play-overlay-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1.1);
    background-color: {{ block.settings.play_icon_bg_hover_color }};
  }

  .ai-reels-gallery-play-icon-{{ ai_gen_id }} {
    width: 50%;
    height: 50%;
    color: {{ block.settings.play_icon_color }};
    margin-left: 4px;
  }

  .ai-reels-gallery-label-{{ ai_gen_id }} {
    margin-top: {{ block.settings.label_spacing }}px;
    text-align: center;
  }

  .ai-reels-gallery-label-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-decoration: none;
    display: block;
  }

  .ai-reels-gallery-link-{{ ai_gen_id }}:hover .ai-reels-gallery-label-text-{{ ai_gen_id }} {
    color: {{ block.settings.label_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-reels-gallery-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 0;
    }

    .ai-reels-gallery-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-reels-gallery-item-{{ ai_gen_id }} {
      width: {{ block.settings.reel_width_mobile }}px;
    }

    .ai-reels-gallery-scroll-container-{{ ai_gen_id }} {
      gap: {{ block.settings.reel_spacing_mobile }}px;
    }

    .ai-reels-gallery-play-overlay-{{ ai_gen_id }} {
      width: {{ block.settings.play_icon_size_mobile }}px;
      height: {{ block.settings.play_icon_size_mobile }}px;
    }

    .ai-reels-gallery-label-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size_mobile }}px;
    }
  }
{% endstyle %}

<instagram-reels-gallery-{{ ai_gen_id }} class="ai-reels-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reels-gallery-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <div class="ai-reels-gallery-header-{{ ai_gen_id }}">
        <h2 class="ai-reels-gallery-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      </div>
    {% endif %}

    <div class="ai-reels-gallery-scroll-wrapper-{{ ai_gen_id }}">
      <div class="ai-reels-gallery-scroll-container-{{ ai_gen_id }}">
        {% for i in (1..block.settings.reels_count) %}
          {% liquid
            assign reel_url_key = 'reel_' | append: i | append: '_url'
            assign reel_image_key = 'reel_' | append: i | append: '_image'
            assign reel_label_key = 'reel_' | append: i | append: '_label'
            
            assign reel_url = block.settings[reel_url_key]
            assign reel_image = block.settings[reel_image_key]
            assign reel_label = block.settings[reel_label_key]
          %}

          <div class="ai-reels-gallery-item-{{ ai_gen_id }}">
            {% if reel_url != blank %}
              <a 
                href="{{ reel_url }}" 
                class="ai-reels-gallery-link-{{ ai_gen_id }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="{% if reel_label != blank %}{{ reel_label }}{% else %}View Instagram Reel {{ i }}{% endif %}"
              >
            {% else %}
              <div class="ai-reels-gallery-link-{{ ai_gen_id }}">
            {% endif %}

              <div class="ai-reels-gallery-image-wrapper-{{ ai_gen_id }}">
                {% if reel_image %}
                  <img
                    src="{{ reel_image | image_url: width: 600 }}"
                    alt="{% if reel_label != blank %}{{ reel_label }}{% else %}Instagram Reel {{ i }}{% endif %}"
                    loading="lazy"
                    width="600"
                    height="1067"
                    class="ai-reels-gallery-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-reels-gallery-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                <div class="ai-reels-gallery-play-overlay-{{ ai_gen_id }}">
                  <svg 
                    class="ai-reels-gallery-play-icon-{{ ai_gen_id }}"
                    viewBox="0 0 24 24" 
                    fill="currentColor"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>

              {% if reel_label != blank and block.settings.show_labels %}
                <div class="ai-reels-gallery-label-{{ ai_gen_id }}">
                  <span class="ai-reels-gallery-label-text-{{ ai_gen_id }}">{{ reel_label }}</span>
                </div>
              {% endif %}

            {% if reel_url != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</instagram-reels-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class InstagramReelsGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.scrollContainer = this.querySelector('.ai-reels-gallery-scroll-container-{{ ai_gen_id }}');
        this.setupTouchScroll();
      }

      setupTouchScroll() {
        if (!this.scrollContainer) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.scrollContainer.addEventListener('mousedown', (e) => {
          isDown = true;
          this.scrollContainer.style.cursor = 'grabbing';
          startX = e.pageX - this.scrollContainer.offsetLeft;
          scrollLeft = this.scrollContainer.scrollLeft;
        });

        this.scrollContainer.addEventListener('mouseleave', () => {
          isDown = false;
          this.scrollContainer.style.cursor = 'grab';
        });

        this.scrollContainer.addEventListener('mouseup', () => {
          isDown = false;
          this.scrollContainer.style.cursor = 'grab';
        });

        this.scrollContainer.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.scrollContainer.offsetLeft;
          const walk = (x - startX) * 2;
          this.scrollContainer.scrollLeft = scrollLeft - walk;
        });

        this.scrollContainer.style.cursor = 'grab';
      }
    }

    customElements.define('instagram-reels-gallery-{{ ai_gen_id }}', InstagramReelsGallery{{ ai_gen_id }});
  })();
</script>

