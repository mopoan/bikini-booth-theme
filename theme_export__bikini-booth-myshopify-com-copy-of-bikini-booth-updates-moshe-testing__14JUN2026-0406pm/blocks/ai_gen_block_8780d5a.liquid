{% doc %}
  @prompt
    viewed items slider
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-viewed-items-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: block;
  }

  .ai-viewed-items-container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-viewed-items-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
  }

  .ai-viewed-items-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-viewed-items-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-viewed-items-slider-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-viewed-items-slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-viewed-items-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_desktop }});
    min-width: 0;
  }

  .ai-viewed-items-product-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-viewed-items-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-viewed-items-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-viewed-items-product-{{ ai_gen_id }}:hover .ai-viewed-items-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-viewed-items-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-viewed-items-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-viewed-items-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-viewed-items-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background-color: {{ block.settings.arrow_bg_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease;
  }

  .ai-viewed-items-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_bg_hover_color }};
  }

  .ai-viewed-items-nav-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    stroke: {{ block.settings.arrow_color }};
  }

  .ai-viewed-items-nav-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.arrow_hover_color }};
  }

  .ai-viewed-items-nav-prev-{{ ai_gen_id }} {
    left: -{{ block.settings.arrow_size | divided_by: 2 }}px;
  }

  .ai-viewed-items-nav-next-{{ ai_gen_id }} {
    right: -{{ block.settings.arrow_size | divided_by: 2 }}px;
  }

  .ai-viewed-items-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-viewed-items-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-viewed-items-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.products_per_row_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_mobile }});
    }

    .ai-viewed-items-header-{{ ai_gen_id }} {
      margin-bottom: 20px;
    }

    .ai-viewed-items-nav-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<recently-viewed-{{ ai_gen_id }} class="ai-viewed-items-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-viewed-items-container-{{ ai_gen_id }}">
    <div class="ai-viewed-items-header-{{ ai_gen_id }}">
      <h2 class="ai-viewed-items-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>

    <div class="ai-viewed-items-slider-wrapper-{{ ai_gen_id }}">
      <button
        class="ai-viewed-items-nav-{{ ai_gen_id }} ai-viewed-items-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous"
        disabled
      >
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-viewed-items-slider-{{ ai_gen_id }}">
      </div>

      <button
        class="ai-viewed-items-nav-{{ ai_gen_id }} ai-viewed-items-nav-next-{{ ai_gen_id }}"
        aria-label="Next"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <div class="ai-viewed-items-empty-{{ ai_gen_id }}" style="display: none;">
      {{ block.settings.empty_message }}
    </div>
  </div>
</recently-viewed-{{ ai_gen_id }}>

<script>
  (function() {
    class RecentlyViewed{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.storageKey = 'recentlyViewedProducts';
        this.maxProducts = {{ block.settings.max_products }};
        this.slider = this.querySelector('.ai-viewed-items-slider-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-viewed-items-nav-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-viewed-items-nav-next-{{ ai_gen_id }}');
        this.emptyState = this.querySelector('.ai-viewed-items-empty-{{ ai_gen_id }}');
        this.sliderWrapper = this.querySelector('.ai-viewed-items-slider-wrapper-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.saveCurrentProduct();
        this.loadRecentlyViewed();
        this.setupNavigation();
      }

      saveCurrentProduct() {
        if (window.location.pathname.includes('/products/')) {
          const productHandle = window.location.pathname.split('/products/')[1].split('?')[0];
          
          if (productHandle) {
            let viewedProducts = this.getViewedProducts();
            viewedProducts = viewedProducts.filter(handle => handle !== productHandle);
            viewedProducts.unshift(productHandle);
            viewedProducts = viewedProducts.slice(0, this.maxProducts);
            
            try {
              localStorage.setItem(this.storageKey, JSON.stringify(viewedProducts));
            } catch (e) {
              console.error('Failed to save to localStorage:', e);
            }
          }
        }
      }

      getViewedProducts() {
        try {
          const stored = localStorage.getItem(this.storageKey);
          return stored ? JSON.parse(stored) : [];
        } catch (e) {
          console.error('Failed to read from localStorage:', e);
          return [];
        }
      }

      async loadRecentlyViewed() {
        let viewedProducts = this.getViewedProducts();
        
        if (window.location.pathname.includes('/products/')) {
          const currentHandle = window.location.pathname.split('/products/')[1].split('?')[0];
          viewedProducts = viewedProducts.filter(handle => handle !== currentHandle);
        }

        if (viewedProducts.length === 0) {
          this.showEmptyState();
          return;
        }

        const products = await this.fetchProducts(viewedProducts);
        this.renderProducts(products);
      }

      async fetchProducts(handles) {
        const products = [];
        
        for (const handle of handles) {
          try {
            const response = await fetch(`/products/${handle}.js`);
            if (response.ok) {
              const product = await response.json();
              products.push(product);
            }
          } catch (e) {
            console.error(`Failed to fetch product ${handle}:`, e);
          }
        }
        
        return products;
      }

      renderProducts(products) {
        if (products.length === 0) {
          this.showEmptyState();
          return;
        }

        this.slider.innerHTML = products.map(product => {
          const price = this.formatMoney(product.price);
          const imageUrl = product.featured_image || '';
          
          return `
            <div class="ai-viewed-items-slide-{{ ai_gen_id }}">
              <a href="/products/${product.handle}" class="ai-viewed-items-product-{{ ai_gen_id }}">
                <div class="ai-viewed-items-image-wrapper-{{ ai_gen_id }}">
                  ${imageUrl ? `<img src="${imageUrl}" alt="${this.escapeHtml(product.title)}" class="ai-viewed-items-image-{{ ai_gen_id }}" loading="lazy">` : ''}
                </div>
                <div class="ai-viewed-items-info-{{ ai_gen_id }}">
                  <h3 class="ai-viewed-items-product-title-{{ ai_gen_id }}">${this.escapeHtml(product.title)}</h3>
                  <div class="ai-viewed-items-price-{{ ai_gen_id }}">${price}</div>
                </div>
              </a>
            </div>
          `;
        }).join('');

        this.updateNavButtons();
      }

      formatMoney(cents) {
        const amount = (cents / 100).toFixed(2);
        return `$${amount}`;
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      showEmptyState() {
        this.sliderWrapper.style.display = 'none';
        this.emptyState.style.display = 'block';
      }

      setupNavigation() {
        this.prevBtn.addEventListener('click', () => this.scroll('prev'));
        this.nextBtn.addEventListener('click', () => this.scroll('next'));
        this.slider.addEventListener('scroll', () => this.updateNavButtons());
      }

      scroll(direction) {
        const slideWidth = this.slider.querySelector('.ai-viewed-items-slide-{{ ai_gen_id }}').offsetWidth;
        const gap = {{ block.settings.gap }};
        const scrollAmount = slideWidth + gap;
        
        if (direction === 'prev') {
          this.slider.scrollLeft -= scrollAmount;
        } else {
          this.slider.scrollLeft += scrollAmount;
        }
      }

      updateNavButtons() {
        const maxScroll = this.slider.scrollWidth - this.slider.clientWidth;
        
        this.prevBtn.disabled = this.slider.scrollLeft <= 0;
        this.nextBtn.disabled = this.slider.scrollLeft >= maxScroll - 1;
      }
    }

    customElements.define('recently-viewed-{{ ai_gen_id }}', RecentlyViewed{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Viewed items slider",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty message",
      "default": "No recently viewed items"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products to track",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "label": "Products per row on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Products per row on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between products",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Product style"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "image_bg_color",
      "label": "Image background",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Navigation arrows"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_bg_hover_color",
      "label": "Background hover",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_hover_color",
      "label": "Arrow hover color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Viewed items slider"
    }
  ]
}
{% endschema %}
