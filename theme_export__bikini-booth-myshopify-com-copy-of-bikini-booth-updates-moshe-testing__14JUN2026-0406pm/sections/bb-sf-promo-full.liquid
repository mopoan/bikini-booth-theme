<section class="bb-subframe bb-subframe-promo-full" id="bb-subframe-promo-{{ section.id }}" style="min-height: {{ section.settings.min_height }}px;" {{ section.shopify_attributes }}>
  {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
    {%- assign promo_img_alt = section.settings.heading | escape -%}
    <picture class="bb-subframe-promo-full__bg-wrap">
      {%- if section.settings.image_mobile != blank -%}
        <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}">
      {%- endif -%}
      {%- if section.settings.image != blank -%}
        <img
          class="bb-subframe-promo-full__bg"
          src="{{ section.settings.image | image_url: width: 2400 }}"
          alt="{{ promo_img_alt }}"
          loading="lazy"
          sizes="100vw"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          srcset="{{ section.settings.image | image_url: width: 1600 }} 1600w, {{ section.settings.image | image_url: width: 2200 }} 2200w, {{ section.settings.image | image_url: width: 2800 }} 2800w, {{ section.settings.image | image_url: width: 3600 }} 3600w"
        >
      {%- else -%}
        <img
          class="bb-subframe-promo-full__bg"
          src="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          alt="{{ promo_img_alt }}"
          loading="lazy"
          sizes="100vw"
          width="{{ section.settings.image_mobile.width }}"
          height="{{ section.settings.image_mobile.height }}"
        >
      {%- endif -%}
    </picture>
  {%- elsif section.settings.image_url != blank -%}
    <img class="bb-subframe-promo-full__bg" src="{{ section.settings.image_url }}" alt="" width="1920" height="800" loading="lazy">
  {%- else -%}
    {%- capture promo_stock -%}{%- render 'bb-subframe-stock-url', index: 4 -%}{%- endcapture -%}
    <img class="bb-subframe-promo-full__bg" src="{{ promo_stock | strip }}" alt="" width="1920" height="1080" loading="lazy">
  {%- endif -%}
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.button_label != blank -%}
    <div class="bb-subframe-promo-full__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bb-subframe-promo-full__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-subframe-promo-full__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a class="bb-subframe-promo-full__btn bb-subframe-cta-cohesive" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "BB - Promo banner",
  "tag": "section",
  "class": "bb-subframe-promo-full-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image — desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image — mobile"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Image URL (fallback)",
      "info": "Optional full HTTPS URL if no image is uploaded."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Summer 2025 Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Escape to Paradise"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 240,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum height",
      "default": 380
    }
  ],
  "presets": [
    {
      "name": "BB - Promo banner"
    }
  ]
}
{% endschema %}
