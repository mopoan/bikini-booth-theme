{%- comment -%}
  Three-column “What we believe” band for About Us (cream panel, teal eyebrow, icon + title + copy).
{%- endcomment -%}
<section
  class="bb-about-beliefs"
  id="bb-about-beliefs-{{ section.id }}"
  data-section-name="bb-about-beliefs"
  {{ section.shopify_attributes }}
>
  <div class="bb-about-beliefs__inner page-width">
    <header class="bb-about-beliefs__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="bb-about-beliefs__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-about-beliefs__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </header>

    <div class="bb-about-beliefs__grid">
      <article class="bb-about-beliefs__card">
        <div class="bb-about-beliefs__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" width="28" height="28" aria-hidden="true">
            <path d="M24 42V22" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M24 22c-6-4-10-10-10-16 4 2 8 6 10 12M24 22c6-5 9-11 9-17-4 1-8 5-9 11M24 22c-1-8 1-15 5-19-3 5-4 11-3 17M24 22c2-7 7-12 13-14-5 4-9 10-11 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        {%- if section.settings.col1_title != blank -%}
          <h3 class="bb-about-beliefs__card-title">{{ section.settings.col1_title | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.col1_text != blank -%}
          <p class="bb-about-beliefs__card-text">{{ section.settings.col1_text | escape }}</p>
        {%- endif -%}
      </article>

      <article class="bb-about-beliefs__card">
        <div class="bb-about-beliefs__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" width="28" height="28" aria-hidden="true">
            <circle cx="17" cy="17" r="6" stroke="currentColor" stroke-width="1.6"/>
            <circle cx="31" cy="31" r="6" stroke="currentColor" stroke-width="1.6"/>
            <path d="M21 21l12 12M27 15L15 27" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </div>
        {%- if section.settings.col2_title != blank -%}
          <h3 class="bb-about-beliefs__card-title">{{ section.settings.col2_title | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.col2_text != blank -%}
          <p class="bb-about-beliefs__card-text">{{ section.settings.col2_text | escape }}</p>
        {%- endif -%}
      </article>

      <article class="bb-about-beliefs__card">
        <div class="bb-about-beliefs__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" width="28" height="28" aria-hidden="true">
            <path d="M24 6l1.2 6.2L31 14l-6.2 1.2L24 22l-1.2-6.8L17 14l6.8-1.8L24 6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            <path d="M34 26l.8 4 4.2.8-4.2.8L34 36l-.8-4.4-4.2-.8 4.2-.8L34 26zM12 28l.7 3.2 3.3.6-3.3.6L12 36l-.7-3.6-3.3-.6 3.3-.6L12 28z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
          </svg>
        </div>
        {%- if section.settings.col3_title != blank -%}
          <h3 class="bb-about-beliefs__card-title">{{ section.settings.col3_title | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.col3_text != blank -%}
          <p class="bb-about-beliefs__card-text">{{ section.settings.col3_text | escape }}</p>
        {%- endif -%}
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BB - What we believe",
  "tag": "section",
  "class": "bb-about-beliefs-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What we believe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for life in the sun"
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Title",
      "default": "Tropical soul"
    },
    {
      "type": "textarea",
      "id": "col1_text",
      "label": "Text",
      "default": "From Phuket to Koh Phangan, Bikini Booth is rooted in island life—sunsets, sea breeze, and prints that feel like a holiday you can wear every day."
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Title",
      "default": "Sun-ready cuts"
    },
    {
      "type": "textarea",
      "id": "col2_text",
      "label": "Text",
      "default": "Swimwear and resort wear shaped for real bodies and real plans—flattering lines, confident fits, and pieces that move with you from beach clubs to boardwalks."
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Title",
      "default": "Own your shine"
    },
    {
      "type": "textarea",
      "id": "col3_text",
      "label": "Text",
      "default": "We’re here for color, joy, and self-expression—the carefree energy you see on our site is the same spirit we stitch into every collection."
    }
  ],
  "presets": [{ "name": "BB - What we believe" }]
}
{% endschema %}
